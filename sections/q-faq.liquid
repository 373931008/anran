{%- comment -%}
  Section: q-faq
  
  功能说明：
  - FAQ 常见问题板块，支持 Tab 分类切换
  - 每个 Tab 下有多个手风琴式问答条目（slide down 动画）
  - summary 行有 #D9E2F2 背景，答案区无背景
  - 内容区最大宽度 968px
  - Tab 切换使用 Islands 架构（faq-tabs 自定义元素）
  - 复用通用头部 snippet（q-section-header）
  
  技术栈：
  - Islands: frontend/islands/faq-tabs.js
  - Snippet: snippets/q-section-header.liquid
  
  版本：1.1.0
{%- endcomment -%}

{%- liquid
  assign tab_blocks = section.blocks | where: 'type', 'tab'
  assign item_blocks = section.blocks | where: 'type', 'item'
  assign has_tabs = false
  if tab_blocks.size > 0
    assign has_tabs = true
  endif
  assign first_tab_index = '1'
-%}

<style>
  .section-{{ section.id }} {
    --faq-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --faq-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --faq-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --faq-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --faq-tab-border-color: {{ section.settings.tab_border_color }};
    --faq-tab-text-color: {{ section.settings.tab_text_color }};
    --faq-tab-active-bg: {{ section.settings.tab_active_bg }};
    --faq-tab-active-text-color: {{ section.settings.tab_active_text_color }};
  }

  .section-{{ section.id }}.q-faq {
    font-family: var(--font-body-family);
    padding-top: var(--faq-padding-top-mobile, 40px);
    padding-bottom: var(--faq-padding-bottom-mobile, 40px);
    background: #F3F7FF;
  }

  .section-{{ section.id }} .q-faq__inner, .section-{{ section.id }} .q-section-header {
    max-width: 968px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .q-faq__tab-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .section-{{ section.id }} .q-faq__tab-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 204px;
    height: 38px;
    border-radius: 100px;
    border: 1.5px solid var(--faq-tab-border-color, #d9e2f2);
    background: transparent;
    color: var(--faq-tab-text-color, #2d4e76);
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s, opacity 0.2s;
  }

  .section-{{ section.id }} .q-faq__tab-btn:hover:not(.q-faq__tab-btn--active) {
    background: rgba(45, 78, 118, 0.08);
    border-color: var(--faq-tab-text-color, #2d4e76);
  }

  .section-{{ section.id }} .q-faq__tab-btn:active:not(.q-faq__tab-btn--active) {
    background: rgba(45, 78, 118, 0.18);
  }

  .section-{{ section.id }} .q-faq__tab-btn--active {
    background: var(--faq-tab-active-bg, #2d4e76);
    color: var(--faq-tab-active-text-color, #ffffff);
    border-color: transparent;
    font-weight: 500;
  }

  .section-{{ section.id }} .q-faq__tab-btn--active:hover {
    opacity: 0.85;
  }

  .section-{{ section.id }} .q-faq__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-{{ section.id }} .q-faq__item {
    background: transparent;
    border-radius: 5px;
    overflow: hidden;
  }

  .section-{{ section.id }} .q-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    height: 51px;
    background: #d9e2f2;
    border-radius: 5px;
    color: #2d4e76;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    gap: 12px;
  }

  .section-{{ section.id }} .q-faq__summary::-webkit-details-marker {
    display: none;
  }

  .section-{{ section.id }} .q-faq__question {
    flex: 1;
    line-height: 1.4;
  }

  .section-{{ section.id }} .q-faq__icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .section-{{ section.id }} .q-faq__item[data-open] .q-faq__icon {
    transform: rotate(180deg);
  }

  .section-{{ section.id }} .q-faq__answer-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .section-{{ section.id }} .q-faq__answer {
    padding: 14px 16px 16px;
    color: #2d4e76;
    font-size: 12px;
    line-height: 1.6;
  }

  .section-{{ section.id }} .q-faq__answer p {
    margin: 0;
  }

  .section-{{ section.id }} .q-faq__answer p + p {
    margin-top: 8px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-faq {
      padding-top: var(--faq-padding-top-desktop, 60px);
      padding-bottom: var(--faq-padding-bottom-desktop, 60px);
    }

    .section-{{ section.id }} .q-faq__tab-bar {
      flex-direction: row;
      justify-content: center;
      gap: 16px;
      margin-bottom: 40px;
    }

    .section-{{ section.id }} .q-faq__tab-btn {
      width: 204px;
      height: 48px;
    }

    .section-{{ section.id }} .q-faq__item {
      border-radius: 10px;
    }

    .section-{{ section.id }} .q-faq__summary {
      height: 74px;
      padding: 0 24px;
      font-size: 20px;
      border-radius: 10px;
    }

    .section-{{ section.id }} .q-faq__icon {
      width: 34px;
      height: 34px;
    }

    .section-{{ section.id }} .q-faq__answer {
      padding: 16px 24px 20px;
      font-size: 16px;
    }

    .section-{{ section.id }} .q-faq__list {
      gap: 10px;
    }
  }

  .section-{{ section.id }} .q-section-header__title {
    font-weight: 500 !important;
  }
</style>

<div class="q-faq section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    <faq-tabs client:visible>
      <div class="q-faq__inner">
        {%- if has_tabs -%}
          <div class="q-faq__tab-bar" role="tablist">
            {%- for block in tab_blocks -%}
              {%- assign tab_num = forloop.index | append: '' -%}
              <button
                class="q-faq__tab-btn{% if forloop.first %} q-faq__tab-btn--active{% endif %}"
                data-tab="{{ tab_num }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.tab_label | default: 'Tab' -}}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="q-faq__list">
          {%- for block in item_blocks -%}
            {%- assign tab_group = block.settings.tab_index | default: '1' -%}
            <div
              class="q-faq__item{% if forloop.first and tab_group == first_tab_index %} q-faq__item--default-open{% endif %}"
              data-tab-group="{{ tab_group }}"
              {% unless tab_group == first_tab_index %}hidden{% endunless %}
              {{ block.shopify_attributes }}
            >
              <div class="q-faq__summary" role="button" tabindex="0" aria-expanded="{% if forloop.first and tab_group == first_tab_index %}true{% else %}false{% endif %}">
                <span class="q-faq__question">{{- block.settings.question -}}</span>
                <span class="q-faq__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 9L12 15L18 9" stroke="#2d4e76" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              {%- if block.settings.answer != blank -%}
                <div class="q-faq__answer-wrap">
                  <div class="q-faq__answer">
                    {{- block.settings.answer -}}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </faq-tabs>
  </div>
</div>

