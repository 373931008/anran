{%- comment -%}
  Section: q-service-features
  功能说明：
  - 服务特色展示板块，展示品牌核心服务优势
  - 桌面端：4列横排卡片布局
  - 移动端：2×2网格布局
  - 每张卡片包含图标、标题、描述文字
  - 纯展示类板块，无 JS 交互

  技术栈：
  - Snippet: snippets/q-section-header.liquid
  版本：1.0.0
{%- endcomment -%}

<style>
  .section-{{ section.id }} {
    --sf-bg: {{ section.settings.bg_color }};
    --sf-card-bg: {{ section.settings.card_bg_color }};
    --sf-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --sf-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --sf-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --sf-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  }

  .section-{{ section.id }}.q-service-features {
    background: var(--sf-bg, #ffffff);
    padding-top: var(--sf-padding-top-mobile, 40px);
    padding-bottom: var(--sf-padding-bottom-mobile, 40px);
    font-family: var(--font-body-family);
  }

  .section-{{ section.id }} .q-sf__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .section-{{ section.id }} .q-sf__card {
    background: var(--sf-card-bg, #f9f9f9);
    border-radius: 10px;
    padding: 24px 16px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .section-{{ section.id }} .q-sf__icon-wrap {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }

  .section-{{ section.id }} .q-sf__icon-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .section-{{ section.id }} .q-sf__title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    color: #1e1e1e;
    margin: 0;
  }

  .section-{{ section.id }} .q-sf__desc {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: #1e1e1e;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-service-features {
      padding-top: var(--sf-padding-top-desktop, 60px);
      padding-bottom: var(--sf-padding-bottom-desktop, 60px);
    }

    .section-{{ section.id }} .q-sf__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .section-{{ section.id }} .q-sf__card {
      border-radius: 30px;
      padding: 40px 24px 32px;
      gap: 10px;
    }

    .section-{{ section.id }} .q-sf__icon-wrap {
      width: 54px;
      height: 54px;
      margin-bottom: 6px;
    }

    .section-{{ section.id }} .q-sf__title {
      font-size: 20px;
    }

    .section-{{ section.id }} .q-sf__desc {
      font-size: 16px;
      line-height: 1.5;
    }
  }
</style>

<div class="q-service-features section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    {%- if section.blocks.size > 0 -%}
      <div class="q-sf__grid">
        {%- for block in section.blocks -%}
          <div class="q-sf__card" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="q-sf__icon-wrap">
                <img
                  src="{{ block.settings.icon | image_url: width: 108 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="54"
                  height="54"
                  loading="lazy"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class="q-sf__title">{{ block.settings.title }}</p>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p class="q-sf__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "q-service-features",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Why Choose Anran?" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": true },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "#FF6B35" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "板块背景" },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "背景色",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "card_bg_color",
      "label": "卡片背景色",
      "default": "#f9f9f9"
    },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "特色卡片",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "图标",
          "info": "推荐尺寸：54×54px，PNG 格式（透明背景）"
        },
        {
          "type": "text",
          "id": "title",
          "label": "标题",
          "default": "Free Shipping"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "描述",
          "default": "Enjoy fast, free delivery on all orders, returns within 30 days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-service-features",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Free Shipping",
            "description": "Enjoy fast, free delivery on all orders, returns within 30 days."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Official Warranty",
            "description": "All Anran cameras are backed by our quality guarantee."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Flexible Payment",
            "description": "Pay in installments for your camera."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Expert Support",
            "description": "Our team is here to help you every step of the way."
          }
        }
      ]
    }
  ]
}
{% endschema %}
