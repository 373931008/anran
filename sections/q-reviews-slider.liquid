{%- comment -%}
  Section: q-reviews-slider
  功能说明：客户评价轮播 —— 第一张为评分汇总卡，其余为个人评论卡，swiper-container + 左右导航
  技术栈：
  - swiper-container Web Component（slides-per-view: auto，固定宽度 slide）
  - Snippet: snippets/q-section-header.liquid
  版本：1.0.0
{%- endcomment -%}

{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign show_nav = false
  if review_blocks.size > 0
    assign show_nav = true
  endif
-%}

<style>
  .section-{{ section.id }} {
    --rs-bg: {{ section.settings.bg_color }};
    --rs-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --rs-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --rs-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --rs-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --rs-slide-width-mobile: 208px;
    --rs-slide-width-desktop: 258px;
    --rs-gap-mobile: 16px;
    --rs-gap-desktop: 21px;
    --rs-card-radius: 50px;
    --rs-card-height-mobile: 217px;
    --rs-card-height-desktop: 250px;
    /* 桌面端箭头贴在滑块左右外侧的间距（不占用轮播宽度） */
    --rs-nav-out-gap: 12px;

    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      overflow: visible;
    }
  }

  .section-{{ section.id }}.q-reviews-slider {
    background: var(--rs-bg, #f4f7ff);
    padding-top: var(--rs-pt-mobile, 40px);
    padding-bottom: var(--rs-pb-mobile, 40px);
    font-family: var(--font-body-family);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-reviews-slider {
      padding-top: var(--rs-pt-desktop, 60px);
      padding-bottom: var(--rs-pb-desktop, 60px);
    }
  }

  .section-{{ section.id }} .q-rs__wrap {
    position: relative;
  }

  .section-{{ section.id }} .q-rs__swiper swiper-container {
    display: flex;
    gap: var(--rs-gap-mobile);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__swiper swiper-container {
      gap: var(--rs-gap-desktop);
    }

    .section-{{ section.id }} .q-rs__wrap {
      padding: 0 10px;
      overflow: visible;
    }
  }

  .section-{{ section.id }} .q-rs__swiper swiper-slide {
    flex-shrink: 0;
    width: var(--rs-slide-width-mobile);
    height: auto;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__swiper swiper-slide {
      width: var(--rs-slide-width-desktop);
    }
  }

  .section-{{ section.id }} .q-rs__card {
    background: #ffffff;
    border-radius: var(--rs-card-radius);
    padding: 28px 24px;
    min-height: var(--rs-card-height-mobile);
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__card {
      padding: 34px 30px;
      min-height: var(--rs-card-height-desktop);
    }
  }

  .section-{{ section.id }} .q-rs__card--summary {
    align-items: center;
    text-align: center;
    justify-content: center;
  }

  .section-{{ section.id }} .q-rs__card--review {
    align-items: flex-start;
    text-align: left;
  }

  .section-{{ section.id }} .q-rs__score {
    font-size: 32px;
    font-weight: 700;
    color: #1e1e1e;
    margin: 0 0 8px;
    line-height: 1.25;
  }

  .section-{{ section.id }} .q-rs__score .q-rs__score-max {
    font-size: 20px;
    font-weight: 400;
  }

  .section-{{ section.id }} .q-rs__stars-big {
    width: 110px;
    height: 19px;
    flex-shrink: 0;
    margin-bottom: 8px;
  }

  .section-{{ section.id }} .q-rs__stars-big svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__stars-big {
      width: 136px;
      height: 22px;
    }
  }

  .section-{{ section.id }} .q-rs__review-count {
    font-size: 13px;
    font-weight: 600;
    color: #1e1e1e;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__review-count {
      font-size: 14px;
    }
  }

  .section-{{ section.id }} .q-rs__stars-small {
    width: 80px;
    height: 14px;
    flex-shrink: 0;
    margin-bottom: 8px;
  }

  .section-{{ section.id }} .q-rs__stars-small svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__stars-small {
      width: 99px;
      height: 16px;
      margin-bottom: 16px;
    }
  }

  .section-{{ section.id }} .q-rs__author {
    font-size: 14px;
    font-weight: 500;
    color: #1e1e1e;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .section-{{ section.id }} .q-rs__meta {
    font-size: 12px;
    color: #4e5357;
    margin: 0 0 2px;
    line-height: 1.4;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__meta {
      margin: 0 0 12px;
    }
  }

  .section-{{ section.id }} .q-rs__body {
    font-size: 12px;
    color: #1e1e1e;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .section-{{ section.id }} .q-rs__nav {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    padding: 0;
  }

  /* 桌面端：箭头绝对定位到滑块区域左右外侧，不挤占 swiper 宽度 */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__nav {
      display: block;
      height: 0;
      overflow: visible;
    }

    .section-{{ section.id }} .q-rs__nav-btn {
      position: absolute;
      top: 50%;
    }

    .section-{{ section.id }} .q-rs__nav-btn--prev {
      left: 0;
      transform: translate(calc(-100% - var(--rs-nav-out-gap, 12px)), -50%);
    }

    .section-{{ section.id }} .q-rs__nav-btn--next {
      right: 0;
      left: auto;
      transform: translate(calc(100% + var(--rs-nav-out-gap, 12px)), -50%);
    }
  }

  .section-{{ section.id }} .q-rs__nav-btn {
    pointer-events: auto;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #367cf6;
    transition: opacity 0.2s, color 0.2s;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-rs__nav-btn {
      width: 36px;
      height: 36px;
    }
  }

  .section-{{ section.id }} .q-rs__nav-btn:hover:not(:disabled):not(.swiper-button-disabled) {
    opacity: 0.8;
  }

  .section-{{ section.id }} .q-rs__nav-btn:active:not(:disabled):not(.swiper-button-disabled) {
    opacity: 0.6;
  }

  .section-{{ section.id }} .q-rs__nav-btn:disabled,
  .section-{{ section.id }} .q-rs__nav-btn.swiper-button-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .section-{{ section.id }} .q-rs__nav-btn svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-{{ section.id }} .q-rs__footer {
    text-align: end;
    margin-top: 24px;
    font-size: 14px;
    color: #4e5357;
  }

  .section-{{ section.id }} .q-rs__footer-logo {
    height: 20px;
    width: auto;
    vertical-align: middle;
    display: inline-block;
  }

  .section-{{ section.id }} swiper-container::part(container) {
    overflow: visible;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} swiper-container::part(container) {
      overflow: hidden;
    }
  }
</style>

<div class="q-reviews-slider section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    <div class="q-rs__wrap">
      <reviews-slider-element
        client:visible
        data-autoplay-enabled="{% if section.settings.autoplay_carousel %}true{% else %}false{% endif %}"
      >
        <div class="q-rs__swiper">
          <swiper-container
            id="q-rs-swiper-{{ section.id }}"
            slides-per-view="auto"
            space-between="16"
            grab-cursor="true"
            loop="{% if section.settings.seamless_loop %}true{% else %}false{% endif %}"
            navigation="true"
            navigation-prev-el="[data-carousel-prev='{{ section.id }}']"
            navigation-next-el="[data-carousel-next='{{ section.id }}']"
            breakpoints='{"750":{"spaceBetween":22}}'
            {% if section.settings.autoplay_carousel %}autoplay="true" autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}" autoplay-disable-on-interaction="false"{% endif %}
          >
          {%- comment -%} 第一张：评分汇总卡 {%- endcomment -%}
          <swiper-slide>
            <div class="q-rs__card q-rs__card--summary">
              <p class="q-rs__score">{{ section.settings.rating_score | default: '4.7' }}<span class="q-rs__score-max"> / {{ section.settings.rating_max | default: '5' }}</span></p>
              <div class="q-rs__stars-big" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="136" height="22" viewBox="0 0 136 22" fill="none">
                  <path d="M10.8182 0L13.8831 6.59967L21.1069 7.47518L15.7773 12.4295L17.177 19.5703L10.8182 16.0325L4.45941 19.5703L5.85903 12.4295L0.52948 7.47518L7.75326 6.59967L10.8182 0Z" fill="#EB7100"/>
                  <path d="M39.3733 0L42.4382 6.59967L49.662 7.47518L44.3325 12.4295L45.7321 19.5703L39.3733 16.0325L33.0145 19.5703L34.4141 12.4295L29.0846 7.47518L36.3084 6.59967L39.3733 0Z" fill="#EB7100"/>
                  <path d="M67.9284 0L70.9933 6.59967L78.2171 7.47518L72.8876 12.4295L74.2872 19.5703L67.9284 16.0325L61.5696 19.5703L62.9693 12.4295L57.6397 7.47518L64.8635 6.59967L67.9284 0Z" fill="#EB7100"/>
                  <path d="M96.4836 0L99.5485 6.59967L106.772 7.47518L101.443 12.4295L102.842 19.5703L96.4836 16.0325L90.1248 19.5703L91.5244 12.4295L86.1949 7.47518L93.4186 6.59967L96.4836 0Z" fill="#EB7100"/>
                  <path d="M125.039 0L128.104 6.59967L135.327 7.47518L129.998 12.4295L131.397 19.5703L125.039 16.0325L118.68 19.5703L120.08 12.4295L114.75 7.47518L121.974 6.59967L125.039 0Z" fill="#EB7100"/>
                </svg>
              </div>
              <p class="q-rs__review-count">{{ section.settings.review_count | default: '82 Verified Reviews' }}</p>
            </div>
          </swiper-slide>

          {%- for block in review_blocks -%}
            <swiper-slide {{ block.shopify_attributes }}>
              <div class="q-rs__card q-rs__card--review">
                <div class="q-rs__stars-small" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="136" height="22" viewBox="0 0 136 22" fill="none">
                    <path d="M10.8182 0L13.8831 6.59967L21.1069 7.47518L15.7773 12.4295L17.177 19.5703L10.8182 16.0325L4.45941 19.5703L5.85903 12.4295L0.52948 7.47518L7.75326 6.59967L10.8182 0Z" fill="#EB7100"/>
                    <path d="M39.3733 0L42.4382 6.59967L49.662 7.47518L44.3325 12.4295L45.7321 19.5703L39.3733 16.0325L33.0145 19.5703L34.4141 12.4295L29.0846 7.47518L36.3084 6.59967L39.3733 0Z" fill="#EB7100"/>
                    <path d="M67.9284 0L70.9933 6.59967L78.2171 7.47518L72.8876 12.4295L74.2872 19.5703L67.9284 16.0325L61.5696 19.5703L62.9693 12.4295L57.6397 7.47518L64.8635 6.59967L67.9284 0Z" fill="#EB7100"/>
                    <path d="M96.4836 0L99.5485 6.59967L106.772 7.47518L101.443 12.4295L102.842 19.5703L96.4836 16.0325L90.1248 19.5703L91.5244 12.4295L86.1949 7.47518L93.4186 6.59967L96.4836 0Z" fill="#EB7100"/>
                    <path d="M125.039 0L128.104 6.59967L135.327 7.47518L129.998 12.4295L131.397 19.5703L125.039 16.0325L118.68 19.5703L120.08 12.4295L114.75 7.47518L121.974 6.59967L125.039 0Z" fill="#EB7100"/>
                  </svg>
                </div>
                {%- if block.settings.author_name != blank -%}<p class="q-rs__author">{{ block.settings.author_name }}</p>{%- endif -%}
                {%- if block.settings.date_place != blank -%}<p class="q-rs__meta">{{ block.settings.date_place }}</p>{%- endif -%}
                {%- if block.settings.body != blank -%}<div class="q-rs__body">{{ block.settings.body }}</div>{%- endif -%}
              </div>
            </swiper-slide>
          {%- endfor -%}
          </swiper-container>
        </div>
      </reviews-slider-element>

      {%- if show_nav -%}
        <div class="q-rs__nav">
          <button
            type="button"
            class="q-rs__nav-btn q-rs__nav-btn--prev"
            data-carousel-prev="{{ section.id }}"
            aria-label="{{ 'general.previous' | t | default: 'Previous' }}"
            tabindex="0"
          >
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button
            type="button"
            class="q-rs__nav-btn q-rs__nav-btn--next"
            data-carousel-next="{{ section.id }}"
            aria-label="{{ 'general.next' | t | default: 'Next' }}"
            tabindex="0"
          >
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.footer_logo != blank -%}
      <div class="q-rs__footer">
        {{- section.settings.footer_logo | image_url: height: 40 | image_tag: class: 'q-rs__footer-logo', loading: 'lazy', alt: '' -}}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "q-reviews-slider",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Customer Reviews" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": false },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "#FF6B35" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "评分汇总卡" },
    { "type": "text", "id": "rating_score", "label": "评分", "default": "4.7" },
    { "type": "text", "id": "rating_max", "label": "满分", "default": "5" },
    { "type": "text", "id": "review_count", "label": "评论数文案", "default": "82 Verified Reviews" },
    { "type": "header", "content": "轮播" },
    { "type": "checkbox", "id": "seamless_loop", "label": "无缝轮播（循环）", "default": false },
    { "type": "checkbox", "id": "autoplay_carousel", "label": "自动播放", "default": false },
    { "type": "range", "id": "autoplay_delay", "label": "播放间隔（秒）", "min": 2, "max": 15, "step": 1, "unit": "s", "default": 5 },
    { "type": "header", "content": "页脚" },
    { "type": "image_picker", "id": "footer_logo", "label": "品牌 Logo（如 Shopper Approved）" },
    { "type": "header", "content": "板块背景" },
    { "type": "color_background", "id": "bg_color", "label": "板块背景颜色", "default": "#f4f7ff" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "单条评论",
      "settings": [
        { "type": "text", "id": "author_name", "label": "用户姓名", "default": "Lynda C." },
        { "type": "text", "id": "date_place", "label": "日期与地区", "default": "02-05-26-CA, US" },
        { "type": "richtext", "id": "body", "label": "评论内容", "default": "<p>Great product, easy to set up.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-reviews-slider",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author_name": "Lynda C.",
            "date_place": "02-05-26-CA, US",
            "body": "<p>Great product, easy to set up and use daily.</p>"
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Christopher H.",
            "date_place": "01-28-26-US",
            "body": "<p>Very satisfied with the quality and customer service.</p>"
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Maria S.",
            "date_place": "01-15-26-UK",
            "body": "<p>Exactly what I was looking for. Highly recommend.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
