{%- comment -%}
  Section: q-wifi-connected
  功能说明：Wi-Fi 6 "Always Connected" 展示板块
  特点：
  - 全宽图片（可配置，支持电脑端/移动端分别配置）
  - 支持通用头部标题（标准 q-section-header）
  - 纯展示类板块，无 JS 交互
  技术栈：
  - Snippet: snippets/q-section-header.liquid
  版本：1.0.0
{%- endcomment -%}

<style>
  .section-{{ section.id }} {
    --wifi-bg: {{ section.settings.bg_color }};
    --wifi-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --wifi-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --wifi-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --wifi-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --wifi-img-radius-mobile: 10px;
    --wifi-img-radius-desktop: 15px;
  }

  .section-{{ section.id }}.q-wifi-connected {
    background: var(--wifi-bg, #F5F6F7);
    padding-top: var(--wifi-padding-top-mobile, 40px);
    padding-bottom: var(--wifi-padding-bottom-mobile, 40px);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-wifi-connected {
      padding-top: var(--wifi-padding-top-desktop, 60px);
      padding-bottom: var(--wifi-padding-bottom-desktop, 60px);
    }
  }

  /* 图片容器：高度随图片自适应，不裁剪 */
  .section-{{ section.id }} .q-wifi-connected__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--wifi-img-radius-mobile, 10px);
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-wifi-connected__image-wrap {
      border-radius: var(--wifi-img-radius-desktop, 15px);
    }
  }

  .section-{{ section.id }} .q-wifi-connected__image-wrap img,
  .section-{{ section.id }} .q-wifi-connected__image-wrap .placeholder-svg {
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  /* 显隐：选择器需高于上方 img 规则，避免 display: block 覆盖 display: none */
  .section-{{ section.id }} .q-wifi-connected__image-wrap img.q-wifi-connected__img--desktop,
  .section-{{ section.id }} .q-wifi-connected__image-wrap .placeholder-svg.q-wifi-connected__img--desktop {
    display: none;
  }

  .section-{{ section.id }} .q-wifi-connected__image-wrap img.q-wifi-connected__img--mobile,
  .section-{{ section.id }} .q-wifi-connected__image-wrap .placeholder-svg.q-wifi-connected__img--mobile {
    display: block;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-wifi-connected__image-wrap img.q-wifi-connected__img--desktop,
    .section-{{ section.id }} .q-wifi-connected__image-wrap .placeholder-svg.q-wifi-connected__img--desktop {
      display: block;
    }

    .section-{{ section.id }} .q-wifi-connected__image-wrap img.q-wifi-connected__img--mobile,
    .section-{{ section.id }} .q-wifi-connected__image-wrap .placeholder-svg.q-wifi-connected__img--mobile {
      display: none;
    }
  }

  .section-{{ section.id }} .q-section-header__desc {
    max-width: 1064px;
    margin-left: auto !important;
    margin-right: auto !important;
  }
</style>

<div class="q-wifi-connected section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    <div class="q-wifi-connected__image-wrap">
      {%- comment -%} 桌面端图片（≥750px 显示）{%- endcomment -%}
      {%- if section.settings.image_desktop != blank -%}
        {{-
          section.settings.image_desktop
          | image_url: width: 1500
          | image_tag:
            loading: 'lazy',
            class: 'q-wifi-connected__img--desktop',
            sizes: '(min-width: 750px) min(1500px, 100vw), 0px',
            widths: '800,1000,1200,1500',
            alt: section.settings.image_desktop.alt
        -}}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg q-wifi-connected__img--desktop' }}
      {%- endif -%}

      {%- comment -%} 移动端图片（<750px 显示，未配置时使用电脑端图片）{%- endcomment -%}
      {%- if section.settings.image_mobile != blank -%}
        {%- assign mobile_image = section.settings.image_mobile -%}
      {%- else -%}
        {%- assign mobile_image = section.settings.image_desktop -%}
      {%- endif -%}
      {%- if mobile_image != blank -%}
        {{-
          mobile_image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            class: 'q-wifi-connected__img--mobile',
            sizes: '(max-width: 749px) 100vw, 0px',
            widths: '400,600,800',
            alt: mobile_image.alt
        -}}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg q-wifi-connected__img--mobile' }}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "q-wifi-connected",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Always <em>Connected</em>" },
    { "type": "richtext", "id": "header_description", "label": "描述", "default": "<p>Built with <strong>Wi-Fi 6</strong> for faster, more stable wireless performance—so live view stays smooth and alerts arrive right when they matter. Bluetooth is used for quick setup.</p>" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": true },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "linear-gradient(90deg, #6CBCE7 0%, #367CF6 100%)" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "图片" },
    { "type": "image_picker", "id": "image_desktop", "label": "电脑端图片" },
    { "type": "image_picker", "id": "image_mobile", "label": "移动端图片", "info": "不选则使用电脑端图片" },
    { "type": "header", "content": "板块背景" },
    { "type": "color_background", "id": "bg_color", "label": "背景色", "default": "#F5F6F7" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "presets": [
    {
      "name": "q-wifi-connected",
      "settings": {
        "header_title": "Always <em>Connected</em>",
        "header_center": true
      }
    }
  ]
}
{% endschema %}
