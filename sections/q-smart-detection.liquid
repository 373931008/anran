          }
        },
        {
          "type": "detection_type",
          "settings": {
            "label": "Pets",
            "icon_svg": "<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg' fill='white'><path d='M4.5 9.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm15 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm-7.5-7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM9 9.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm10 4c0-3.3-3.1-6-7-6s-7 2.7-7 6c0 1.5.7 2.8 1.7 3.8L5 21h14l-1.7-3.7c1-.9 1.7-2.3 1.7-3.8z'/></svg>"
          }
        },
        {
          "type": "detection_type",
