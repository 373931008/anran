{%- comment -%}
  Section: q-smart-detection
  功能说明：智能检测追踪板块，左侧展示标题+检测类型图标+描述，右侧为上传视频（视口内自动循环播放）+ 两侧竖向图片
  技术栈：
  - Islands: frontend/islands/smart-detection-element.js（视口内自动播放视频）
  - Snippet: snippets/q-section-header.liquid
  版本：1.0.0
{%- endcomment -%}

<style>
  .section-{{ section.id }} {
    --sd-bg: {{ section.settings.bg_color }};
    --sd-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --sd-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --sd-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --sd-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --sd-icon-size: 55px;
    --sd-icon-radius: 10px;
    --sd-icon-gap: 16px;
    /* 移动端：设计稿 58:1757 — 中心 170.24×346，侧图 84.23×243.11 */
    --sd-phone-width: 170px;
    --sd-phone-aspect: 170 / 346;
    --sd-side-img-width: 84px;
    --sd-side-img-height: 243px;
    --sd-visual-height: 360px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --sd-icon-size: 70px;
      --sd-icon-gap: 24px;
      /* 桌面端：设计稿 1:305 — 中心 337.52×686，侧图 167×482 */
      --sd-phone-width: 338px;
      --sd-phone-aspect: 338 / 686;
      --sd-side-img-width: 167px;
      --sd-side-img-height: 482px;
      --sd-visual-height: 686px;
    }
  }

  .section-{{ section.id }}.q-smart-detection {
    background: var(--sd-bg, #f3f7ff);
    padding-top: var(--sd-pt-mobile, 40px);
    padding-bottom: var(--sd-pb-mobile, 40px);
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-smart-detection {
      padding-top: var(--sd-pt-desktop, 60px);
      padding-bottom: var(--sd-pb-desktop, 60px);
    }
  }

  /* 内容布局 */
  .section-{{ section.id }} .q-smart-detection__inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__inner {
      flex-direction: row;
      gap: 70px;
      align-items: center;
      justify-content: space-between;
    }
  }

  /* 左侧文字区 */
  .section-{{ section.id }} .q-smart-detection__content {
    flex: 0 0 auto;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__content {
      width: 428px;
    }
  }

  /* 图标列表 */
  .section-{{ section.id }} .q-smart-detection__icons {
    display: flex;
    gap: var(--sd-icon-gap);
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__icons {
      margin-bottom: 24px;
    }
  }

  .section-{{ section.id }} .q-smart-detection__icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .section-{{ section.id }} .q-smart-detection__icon-btn {
    width: var(--sd-icon-size);
    height: var(--sd-icon-size);
    border-radius: var(--sd-icon-radius);
    background: linear-gradient(180deg, #6cbce7 0%, #367cf6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .q-smart-detection__icon-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .section-{{ section.id }} .q-smart-detection__icon-label {
    font-size: 12px;
    font-weight: 500;
    color: #2d4e76;
    text-align: center;
    line-height: 1.5;
    white-space: nowrap;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__icon-label {
      font-size: 16px;
    }
  }

  /* 描述文字 */
  .section-{{ section.id }} .q-smart-detection__desc {
    font-size: 12px;
    line-height: 1.5;
    color: #4e5357;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__desc {
      font-size: 16px;
      line-height: 1.5;
      max-width: 429px;
    }
  }

  /* 右侧视觉区：设计稿 1:305(桌面) / 58:1757(移动) */
  .section-{{ section.id }} .q-smart-detection__visual {
    flex: 0 0 auto;
    width: 100%;
    height: var(--sd-visual-height);
    display: flex;
    {% comment %} align-items: center; {% endcomment %}
    justify-content: center;
    gap: 13px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__visual {
      width: 877px;
    }
  }

  /* 中心视频容器（设计稿无外框，仅视频区域） */
  .section-{{ section.id }} .q-smart-detection__phone { 
    width: var(--sd-phone-width);
    flex: 0 0 auto;
  }

  .section-{{ section.id }} .q-smart-detection__phone-frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--sd-phone-aspect);
    overflow: hidden;
    background: #f3f7ff;
    border-radius: 10px;
  }

  .section-{{ section.id }} .q-smart-detection__phone-screen {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
  }

  .section-{{ section.id }} .q-smart-detection__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 侧边竖向图片：设计稿 167×482(桌面) / 84×243(移动)，圆角 10px */
  .section-{{ section.id }} .q-smart-detection__side-imgs {
    display: flex;
    flex-direction: column;
    gap: 24px;
    flex: 0 0 auto;
  }

  .section-{{ section.id }} .q-smart-detection__side-img {
    width: var(--sd-side-img-width);
    height: var(--sd-side-img-height);
    border-radius: 10px;
    overflow: hidden;
  }

  .section-{{ section.id }} .q-smart-detection__side-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }

  /* 桌面端侧图列：与视频并排，flex + gap 26px 已在视觉区设置 */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-smart-detection__side-imgs {
      justify-content: space-between;
    }

    .section-{{ section.id }} .q-smart-detection__side-img--left-top {
      margin-top: 35px;
    }

    .section-{{ section.id }} .q-smart-detection__side-img--left-mid {
      margin-top: 160px;
    }

    .section-{{ section.id }} .q-smart-detection__side-img--right-top {
      margin-top: 86px;
    }
  }

  /* 移动端侧图上边距 */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .q-smart-detection__side-img--left-top {
      margin-top: 18px;
    }

    .section-{{ section.id }} .q-smart-detection__side-img--left-mid {
      margin-top: 80px;
    }

    .section-{{ section.id }} .q-smart-detection__side-img--right-top {
      margin-top: 43px;
    }
  }


</style>

<div class="q-smart-detection section-{{ section.id }}">
  <div class="page-width">
    <div class="q-smart-detection__inner">

      {%- comment -%} 左侧文字区 {%- endcomment -%}
      <div class="q-smart-detection__content">
        {%- render 'q-section-header', section: section -%}

        <div class="q-smart-detection__icons">
          {%- for block in section.blocks -%}
            {%- if block.type == 'detection_type' -%}
              <div class="q-smart-detection__icon-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_image != blank -%}
                  <div class="q-smart-detection__icon-btn" aria-hidden="true">
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 80 }}"
                      alt="{{ block.settings.label | escape }}"
                      loading="lazy"
                      width="40"
                      height="40"
                    >
                  </div>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="q-smart-detection__icon-label">{{ block.settings.label }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.description != blank -%}
          <p class="q-smart-detection__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} 右侧上传视频区（视口内自动循环播放）{%- endcomment -%}
      <smart-detection-element client:visible>
        <div class="q-smart-detection__visual">
          {%- comment -%} 侧边装饰图片 {%- endcomment -%}
          {%- if section.settings.side_image_1 != blank -%}
            <div class="q-smart-detection__side-img q-smart-detection__side-img--left-top">
              <img
                src="{{ section.settings.side_image_1 | image_url: width: 340 }}"
                alt=""
                loading="lazy"
                width="167"
                height="482"
              >
            </div>
          {%- endif -%}

          {%- if section.settings.side_image_2 != blank -%}
            <div class="q-smart-detection__side-img q-smart-detection__side-img--left-mid">
              <img
                src="{{ section.settings.side_image_2 | image_url: width: 340 }}"
                alt=""
                loading="lazy"
                width="167"
                height="482"
              >
            </div>
          {%- endif -%}

          <div class="q-smart-detection__phone">
            <div class="q-smart-detection__phone-frame">
              <div class="q-smart-detection__phone-screen">
                {%- if section.settings.video != blank -%}
                  {{ section.settings.video | video_tag: class:'q-smart-detection__video', image_size: '800x', autoplay: true, loop: true, muted: true, playsinline: true }}
                {%- endif -%}
              </div>
            </div>
          </div>

          {%- if section.settings.side_image_3 != blank -%}
            <div class="q-smart-detection__side-img q-smart-detection__side-img--right-top">
              <img
                src="{{ section.settings.side_image_3 | image_url: width: 340 }}"
                alt=""
                loading="lazy"
                width="167"
                height="482"
              >
            </div>
          {%- endif -%}
        </div>
      </smart-detection-element>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "q-smart-detection",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Smarter Detection Camera Tracking" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": false },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "#FF6B35" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 46 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "描述文字" },
    {
      "type": "textarea",
      "id": "description",
      "label": "描述文字",
      "default": "AI-powered detection recognizes, and filters out false alerts—so you stay informed without constant interruptions."
    },
    { "type": "header", "content": "上传视频" },
    {
      "type": "video",
      "id": "video",
      "label": "视频"
    },
    { "type": "header", "content": "侧边装饰图片" },
    { "type": "image_picker", "id": "side_image_1", "label": "左侧图片 1（靠左）" },
    { "type": "image_picker", "id": "side_image_2", "label": "左侧图片 2（居中左）" },
    { "type": "image_picker", "id": "side_image_3", "label": "右侧图片" },
    { "type": "header", "content": "板块背景" },
    { "type": "color_background", "id": "bg_color", "label": "背景色", "default": "#f3f7ff" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "detection_type",
      "name": "检测类型",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "标签",
          "default": "People"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "图标图片"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-smart-detection",
      "settings": {
        "header_title": "Smarter Detection Camera Tracking",
        "description": "AI-powered detection recognizes, and filters out false alerts—so you stay informed without constant interruptions."
      },
      "blocks": [
        {
          "type": "detection_type",
          "settings": {
            "label": "People"
          }
        },
        {
          "type": "detection_type",
          "settings": {
            "label": "Pets"
          }
        },
        {
          "type": "detection_type",
          "settings": {
            "label": "Vehicles"
          }
        },
        {
          "type": "detection_type",
          "settings": {
            "label": "Motion"
          }
        }
      ]
    }
  ]
}
{% endschema %}
