{%- comment -%}
  Section: q-app-features
  功能说明：App 功能展示板块
  - 卡片可配置为图片或视频（Shopify video）；视频进入视口/当前页自动播放，播完自动下一个
  - 移动端：固定宽度 slide 横向滑动，当前页自动播放，滑动后播放当前页视频
  - 桌面端：固定宽度 slide + 仅箭头导航；进入视口播放第一个视频，移入卡片播放该视频，播完继续下一个

  技术栈：
  - Swiper Web Component（breakpoints 统一响应式）
  - Islands: frontend/islands/app-features-element.js（视频自动播放与联动）
  - Snippet: snippets/q-section-header.liquid
  版本：1.2.0
{%- endcomment -%}

<style>
  .section-{{ section.id }} {
    --af-bg: {{ section.settings.bg_color }};
    --af-card-bg: {{ section.settings.card_bg_color }};
    --af-img-bg: {{ section.settings.img_bg_color }};
    --af-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --af-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --af-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --af-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;

    --af-card-radius: 10px;
    --af-card-title-size: 14px;
    --af-card-title-lh: 1.3;
    --af-card-desc-size: 12px;
    --af-card-desc-lh: 1.5;
    --af-card-text-padding: 12px 16px 16px;
    --af-img-ratio: 258 / 285;
  }

  .section-{{ section.id }}.q-app-features {
    background: var(--af-bg, #ffffff);
    padding-top: var(--af-padding-top-mobile, 40px);
    padding-bottom: var(--af-padding-bottom-mobile, 40px);
    font-family: var(--font-body-family);
    overflow: hidden;
  }

  /* ========== Swiper：flex + gap，slide 固定宽度 ========== */
  .section-{{ section.id }} .q-af__swiper {
    width: 100%;
    display: flex;
    gap: 14px;
  }

  .section-{{ section.id }} .q-af__swiper swiper-slide {
    width: 258px;
    flex-shrink: 0;
    height: auto;
    display: flex;
  }

  /* ========== 卡片 ========== */
  .section-{{ section.id }} .q-af__card {
    background: var(--af-card-bg, #ffffff);
    border: 1px solid #e6eff6;
    border-radius: var(--af-card-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .section-{{ section.id }} .q-af__img-area {
    background: var(--af-img-bg, #f3f7ff);
    overflow: hidden;
    aspect-ratio: var(--af-img-ratio);
  }

  .section-{{ section.id }} .q-af__img-area img,
  .section-{{ section.id }} .q-af__img-area video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .q-af__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #bcd0e5;
  }

  .section-{{ section.id }} .q-af__text {
    padding: var(--af-card-text-padding);
    flex: 1;
  }

  .section-{{ section.id }} .q-af__card-title {
    font-size: var(--af-card-title-size);
    font-weight: 500;
    line-height: var(--af-card-title-lh);
    color: #1e1e1e;
    margin: 0 0 6px;
  }

  .section-{{ section.id }} .q-af__card-desc {
    font-size: var(--af-card-desc-size);
    font-weight: 400;
    line-height: var(--af-card-desc-lh);
    color: #4e5357;
    margin: 0;
  }

  .section-{{ section.id }} .q-af__swiper::part(container) {
    overflow: visible;
  }

  /* ========== 导航箭头（默认隐藏，桌面端显示；仅多页时显示） ========== */
  .section-{{ section.id }} .q-af__nav {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --af-card-title-size: 22px;
      --af-card-title-lh: 1.36;
      --af-card-desc-size: 16px;
      --af-card-desc-lh: 1.5;
      --af-card-text-padding: 18px 24px 24px;
      --af-img-ratio: 489 / 538;
    }

    .section-{{ section.id }}.q-app-features {
      padding-top: var(--af-padding-top-desktop, 60px);
      padding-bottom: var(--af-padding-bottom-desktop, 60px);
    }

    .section-{{ section.id }} .q-af__swiper {
      gap: 24px;
    }

    .section-{{ section.id }} .q-af__swiper swiper-slide {
      width: 488px;
    }

    .section-{{ section.id }} .q-af__nav {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
    }

    .section-{{ section.id }} .q-af__nav-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: none;
      background: rgba(105, 115, 134, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #ffffff;
      transition: background 0.2s, border-color 0.2s, opacity 0.2s;
      flex-shrink: 0;
    }

    .section-{{ section.id }} .q-af__nav-btn:hover:not(:disabled):not(.swiper-button-disabled) {
      background: rgba(105, 115, 134, 0.7);
      border-color: rgba(105, 115, 134, 0.7);
    }

    .section-{{ section.id }} .q-af__nav-btn:active:not(:disabled):not(.swiper-button-disabled) {
      background: rgba(105, 115, 134, 0.85);
      border-color: rgba(105, 115, 134, 0.85);
    }

    .section-{{ section.id }} .q-af__nav-btn:disabled,
    .section-{{ section.id }} .q-af__nav-btn.swiper-button-disabled {
      opacity: 0.4;
      cursor: not-allowed;
      pointer-events: none;
    }

    .section-{{ section.id }} .q-af__nav-btn svg {
      width: 16px;
      height: 16px;
      display: block;
    }
  }
</style>

<div class="q-app-features section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    {%- if section.blocks.size > 0 -%}
      <app-features-element client:visible>
        <swiper-container
          class="q-af__swiper"
          slides-per-view="auto"
          space-between="14"
          grab-cursor="true"
          navigation="true"
          navigation-prev-el="[data-carousel-prev='{{ section.id }}']"
          navigation-next-el="[data-carousel-next='{{ section.id }}']"
          breakpoints='{"750": {"spaceBetween": 24}}'
        >
          {%- for block in section.blocks -%}
            <swiper-slide>
              <div class="q-af__card" {{ block.shopify_attributes }} data-card-index="{{ forloop.index0 }}">
                <div class="q-af__img-area">
                  {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                    {{- block.settings.video | video_tag:
                      class: 'q-af__media-video',
                      muted: true,
                      playsinline: true,
                      loop: false,
                      autoplay: false,
                      preload: 'metadata',
                      image_size: '600x'
                    -}}
                  {%- elsif block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.title | escape }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                      sizes="(min-width: 750px) 25vw, 44vw"
                    >
                  {%- else -%}
                    <div class="q-af__img-placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="2" width="20" height="20" rx="4"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>
                <div class="q-af__text">
                  {%- if block.settings.title != blank -%}
                    <p class="q-af__card-title">{{ block.settings.title }}</p>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="q-af__card-desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            </swiper-slide>
          {%- endfor -%}
        </swiper-container>

        {%- if section.blocks.size > 1 -%}
        <div class="q-af__nav">
          <button
            class="q-af__nav-btn"
            type="button"
            aria-label="Previous"
            data-carousel-prev="{{ section.id }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button
            class="q-af__nav-btn"
            type="button"
            aria-label="Next"
            data-carousel-next="{{ section.id }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        {%- endif -%}
      </app-features-element>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "q-app-features",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "App Control, Right from Your <em>Phone</em>" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": false },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "linear-gradient(90deg, rgba(108,188,231,0.81) 0%, #367CF6 100%)" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "颜色配置" },
    { "type": "color_background", "id": "bg_color", "label": "板块背景色", "default": "#FFFFFF" },
    { "type": "color_background", "id": "card_bg_color", "label": "卡片背景色", "default": "#FFFFFF" },
    { "type": "color_background", "id": "img_bg_color", "label": "图片区背景色", "default": "#F3F7FF" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "功能卡片",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "媒体类型",
          "options": [
            { "value": "image", "label": "图片" },
            { "value": "video", "label": "视频" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片",
          "info": "推荐尺寸：489×538px（桌面端）",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "视频",
          "info": "进入视口或当前页自动播放，播完自动播放下一个",
          "visible_if": "{{ block.settings.media_type == 'video' }}"
        },
        {
          "type": "text",
          "id": "title",
          "label": "功能标题",
          "default": "Live View & Event Playback"
        },
        {
          "type": "text",
          "id": "description",
          "label": "功能描述",
          "default": "Watch live video and replay key moments anytime, from anywhere."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-app-features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Live View & Event Playback",
            "description": "Watch live video and replay key moments anytime, from anywhere."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Smart Alerts That Matter",
            "description": "Get real-time notifications with visual previews, so you never miss what matters."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Connected Devices",
            "description": "View, manage, and securely share devices with family from one app."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Security & Privacy Controls",
            "description": "Manage permissions, access, and key security settings to keep your data protected."
          }
        }
      ]
    }
  ]
}
{% endschema %}
