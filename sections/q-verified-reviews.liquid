{%- comment -%}
  Section: q-verified-reviews
  功能说明：Shopper Approved 徽标 + 证言轮播卡片（上图、标题、评价、用户信息、星级 / Judge.me）
  设计稿：桌面 155:218 / 移动 345:72
  技术栈：swiper-container；frontend/islands/verified-reviews-element.js；snippets/q-section-header.liquid
  版本：1.2.0 — verified-reviews-element：isLocked 时隐藏控件；watch-overflow；仍仅多 block 时渲染控件 DOM
{%- endcomment -%}

{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign vr_carousel = false
  if review_blocks.size > 1
    assign vr_carousel = true
  endif
-%}

<style>
  .section-{{ section.id }} {
    --vr-bg: {{ section.settings.bg_color }};
    --vr-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --vr-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --vr-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --vr-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --vr-gap-mobile: {{ section.settings.slide_gap_mobile }}px;
    --vr-gap-desktop: {{ section.settings.slide_gap_desktop }}px;
    --vr-slide-mobile: {{ section.settings.slide_width_mobile }}px;
    --vr-card-radius-mobile: {{ section.settings.card_radius_mobile }}px;
    --vr-card-radius-desktop: {{ section.settings.card_radius_desktop }}px;
    --vr-trust-gap: {{ section.settings.trust_row_gap }}px;
    --vr-meta-color: #656565;
    --vr-body-color: #656565;
    --vr-name-color: #1e1e1e;
    --vr-accent: #1565d8;
    --vr-star: #ffb800;
    --vr-card-bg: #f5f6f7;
    --vr-nav-border: #e8e8e8;
    --vr-nav-arrow: #1e1e1e;
    --vr-avatar-bg: #e3f2fd;
  }

  .section-{{ section.id }}.q-verified-reviews {
    background: var(--vr-bg, #ffffff);
    padding-top: var(--vr-pt-mobile, 40px);
    padding-bottom: var(--vr-pb-mobile, 40px);
    overflow: hidden;
    font-family: var(--font-body-family);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-verified-reviews {
      padding-top: var(--vr-pt-desktop, 60px);
      padding-bottom: var(--vr-pb-desktop, 60px);
    }
  }

  /* 顶部：信任徽标行 */
  .section-{{ section.id }} .q-vr__trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--vr-trust-gap, 12px);
    margin-bottom: {{ section.settings.trust_margin_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__trust {
      margin-bottom: {{ section.settings.trust_margin_bottom_desktop }}px;
    }
  }

  .section-{{ section.id }} .q-vr__trust-logo {
    display: block;
    line-height: 0;
    max-height: 22px;
    width: auto;
  }

  .section-{{ section.id }} .q-vr__trust-logo img {
    display: block;
    max-height: 22px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__trust-logo {
      max-height: 28px;
    }

    .section-{{ section.id }} .q-vr__trust-logo img {
      max-height: 28px;
    }
  }

  .section-{{ section.id }} .q-vr__trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .section-{{ section.id }} .q-vr__trust-badge-label {
    margin: 0;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
    color: #3c4043;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__trust-badge-label {
      font-size: 18px;
    }
  }

  .section-{{ section.id }} .q-vr__trust-badge-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: #367cf6;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__trust-badge-icon {
      width: 30px;
      height: 30px;
    }
  }

  /* Swiper：contain 减轻首帧与 swiper 初始化时的布局抖动 */
  .section-{{ section.id }} .q-vr__swiper {
    overflow: hidden;
    contain: layout paint;
  }

  .section-{{ section.id }} .q-vr__swiper swiper-container {
    width: 100%;
    display: flex;
    min-width: 0;
    align-items: stretch;
    gap: var(--vr-gap-mobile);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__swiper swiper-container {
      gap: var(--vr-gap-desktop);
    }
  }

  .section-{{ section.id }} .q-vr__swiper swiper-slide {
    flex-shrink: 0;
    width: var(--vr-slide-mobile);
    height: auto;
    align-self: stretch;
    display: flex;
    box-sizing: border-box;
  }

  /* 桌面端：每张宽 (100% − 2×间距) ÷ 3 ≈ 1/3；间距来自 --vr-gap-desktop（主题默认 20px），与 breakpoints.spaceBetween 一致 */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__swiper swiper-slide {
      width: calc((100% - 2 * var(--vr-gap-desktop)) / 3);
      max-width: calc((100% - 2 * var(--vr-gap-desktop)) / 3);
    }

    /* 仅一条评价时铺满整轨，避免出现 1/3 空白 */
    .section-{{ section.id }} .q-vr__swiper--single swiper-slide {
      width: 100%;
      max-width: 100%;
    }
  }

  .section-{{ section.id }} .q-vr__card {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 100%;
    height: 100%;
    background: var(--vr-card-bg);
    border-radius: var(--vr-card-radius-mobile);
    overflow: hidden;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__card {
      border-radius: var(--vr-card-radius-desktop);
    }
  }

  .section-{{ section.id }} .q-vr__media {
    position: relative;
    width: 100%;
    aspect-ratio: 228 / 212;
    overflow: hidden;
    background: #e0e0e0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__media {
      aspect-ratio: 460 / 296;
    }
  }

  .section-{{ section.id }} .q-vr__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .q-vr__media .q-vr__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }

  .section-{{ section.id }} .q-vr__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 14px 12px 16px;
    min-height: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__body {
      padding: 18px 20px 22px;
    }
  }

  .section-{{ section.id }} .q-vr__quote-title {
    margin: 0;
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.28;
    color: var(--vr-name-color);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__quote-title {
      font-size: 18px;
      line-height: 1.2;
    }
  }

  .section-{{ section.id }} .q-vr__quote-body {
    margin: 8px 0 0;
    flex: 1 1 auto;
    min-height: 0;
    font-size: 12px;
    line-height: 1.33;
    color: var(--vr-body-color);
  }

  .section-{{ section.id }} .q-vr__quote-body p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__quote-body {
      font-size: 14px;
      line-height: 1.57;
    }
  }

  /* 页脚：贴卡片底部（body 为 column flex，正文 flex:1，footer margin-top:auto） */
  .section-{{ section.id }} .q-vr__footer {
    margin-top: auto;
    padding-top: 14px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__footer {
      padding-top: 18px;
    }

    .section-{{ section.id }} .q-vr__footer--has-avatar {
      grid-template-columns: 65px minmax(0, 1fr);
      column-gap: 16px;
      row-gap: 6px;
    }

    .section-{{ section.id }} .q-vr__footer--has-avatar .q-vr__avatar {
      grid-column: 1;
      grid-row: 1 / -1;
      align-self: start;
    }

    .section-{{ section.id }} .q-vr__footer--has-avatar .q-vr__footer-inner {
      grid-column: 2;
      grid-row: 1 / -1;
    }

    .section-{{ section.id }} .q-vr__reviewer-name {
      font-size: 18px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--vr-name-color);
    }

    .section-{{ section.id }} .q-vr__badge {
      padding: 2px 8px;
      font-size: 12px;
      line-height: 1.4;
    }

    .section-{{ section.id }} .q-vr__date {
      font-size: 12px;
    }
  }

  .section-{{ section.id }} .q-vr__avatar {
    display: flex;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--vr-avatar-bg);
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__avatar {
      width: 65px;
      height: 65px;
    }

    .section-{{ section.id }} .q-vr__avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

  }

  .section-{{ section.id }} .q-vr__top-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    width: 100%;
  }

  .section-{{ section.id }} .q-vr__top-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    width: 100%;
  }

  .section-{{ section.id }} .q-vr__name-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    min-width: 0;
  }

  .section-{{ section.id }} .q-vr__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1px 6px;
    border-radius: 2px;
    background: #ff791b;
    color: #ffffff;
    font-size: 11px;
    line-height: 1.4;
  }

  .section-{{ section.id }} .q-vr__date {
    font-size: 12px;
    color: var(--vr-name-color);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .q-vr__footer-inner {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .q-vr__reviewer-name {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.3;
      color: var(--vr-name-color);
    }

    .section-{{ section.id }} .q-vr__stars svg {
      width: 10px;
      height: 10px;
    }
  }

  .section-{{ section.id }} .q-vr__stars {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  .section-{{ section.id }} .q-vr__stars svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__stars svg {
      width: 17px;
      height: 17px;
    }
  }

  .section-{{ section.id }} .q-vr__stars-wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .section-{{ section.id }} .q-vr__stars-wrap .jdgm-widget.jdgm-preview-badge {
    display: flex;
    justify-content: flex-end;
  }

  /* 导航 + 分页（圆点） */
  .section-{{ section.id }} .q-vr__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: {{ section.settings.controls_margin_mobile }}px;
    flex-wrap: wrap;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__controls {
      margin-top: {{ section.settings.controls_margin_desktop }}px;
      gap: 24px;
    }
  }

  /* JS：Swiper isLocked 时设 hidden，避免主题按钮样式撑开占位 */
  .section-{{ section.id }} .q-vr__controls[hidden] {
    display: none !important;
    margin-top: 0 !important;
  }

  .section-{{ section.id }} .q-vr__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .section-{{ section.id }} .q-vr__pagination .swiper-pagination-bullet {
    width: 6px;
    height: 6px;
    border-radius: 8px;
    background: #c4c4c4;
    opacity: 1;
    transition: background 0.2s, transform 0.2s;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__pagination .swiper-pagination-bullet {
      width: 8px;
      height: 8px;
    }
  }

  .section-{{ section.id }} .q-vr__pagination .swiper-pagination-bullet-active {
    background: #1e1e1e;
    transform: scale(1.15);
  }

  .section-{{ section.id }} .q-vr__nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--vr-nav-border);
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, opacity 0.2s, border-color 0.2s;
    -webkit-tap-highlight-color: transparent;
    color: var(--vr-nav-arrow);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-vr__nav-btn {
      width: 44px;
      height: 44px;
    }
  }

  .section-{{ section.id }} .q-vr__nav-btn:hover:not(:disabled):not(.swiper-button-disabled) {
    background: #f7f7f7;
    border-color: #d0d0d0;
  }

  .section-{{ section.id }} .q-vr__nav-btn:focus-visible {
    outline: 2px solid rgba(54, 124, 246, 0.45);
    outline-offset: 2px;
  }

  .section-{{ section.id }} .q-vr__nav-btn:disabled,
  .section-{{ section.id }} .q-vr__nav-btn.swiper-button-disabled {
    opacity: 0.38;
    cursor: not-allowed;
    pointer-events: none;
  }

  .section-{{ section.id }} .q-vr__nav-btn svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .section-{{ section.id }} .q-vr__nav-btn svg path {
    stroke: var(--vr-nav-arrow);
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .page-width {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

<div class="q-verified-reviews section-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.trust_logo != blank or section.settings.trust_badge_label != blank -%}
      <div class="q-vr__trust">
        {%- if section.settings.trust_logo != blank -%}
          {%- assign vr_trust_alt = section.settings.trust_logo.alt | default: 'Shopper Approved' -%}
          <span class="q-vr__trust-logo">
            {{
              section.settings.trust_logo
              | image_url: width: 360
              | image_tag:
                loading: 'lazy',
                widths: '180,240,360',
                alt: vr_trust_alt
            }}
          </span>
        {%- endif -%}
        {%- if section.settings.trust_badge_label != blank -%}
          <div class="q-vr__trust-badge">
            <svg class="q-vr__trust-badge-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2L14.09 8.26L21 9.27L16 14.14L17.18 21.02L12 17.77L6.82 21.02L8 14.14L3 9.27L9.91 8.26L12 2Z" fill="currentColor" opacity="0.15"/>
              <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p class="q-vr__trust-badge-label">{{ section.settings.trust_badge_label | escape }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- render 'q-section-header', section: section -%}

    {%- if review_blocks.size > 0 -%}
      <verified-reviews-element client:visible>
      <div class="q-vr__swiper{% unless vr_carousel %} q-vr__swiper--single{% endunless %}">
        <swiper-container
          slides-per-view="auto"
          space-between="{{ section.settings.slide_gap_mobile }}"
          grab-cursor="{% if vr_carousel %}true{% else %}false{% endif %}"
          {% if vr_carousel %}
            watch-overflow="true"
            navigation="true"
            navigation-prev-el="[data-vr-prev='{{ section.id }}']"
            navigation-next-el="[data-vr-next='{{ section.id }}']"
            pagination="true"
            pagination-clickable="true"
            pagination-el="[data-vr-pagination='{{ section.id }}']"
          {% else %}
            navigation="false"
            pagination="false"
          {% endif %}
          breakpoints='{"750":{"slidesPerView":"auto","spaceBetween":{{ section.settings.slide_gap_desktop }}}}'
        >
          {%- for block in review_blocks -%}
            {%- liquid
              assign vr_product = block.settings.product
              assign vr_avatar = block.settings.avatar_image
              assign vr_stars = block.settings.star_rating | default: 5
              if vr_stars > 5
                assign vr_stars = 5
              elsif vr_stars < 1
                assign vr_stars = 1
              endif
              assign vr_img_alt = block.settings.image.alt | default: block.settings.quote_title
              assign vr_av_alt = block.settings.reviewer_name
              if vr_avatar != blank
                assign vr_av_alt = vr_avatar.alt | default: block.settings.reviewer_name
              endif
            -%}
            <swiper-slide {{ block.shopify_attributes }}>
              <article class="q-vr__card">
                <div class="q-vr__media">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 920
                      | image_tag:
                        loading: 'lazy',
                        widths: '228,300,460,620,920',
                        alt: vr_img_alt
                    }}
                  {%- else -%}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'q-vr__placeholder' }}
                  {%- endif -%}
                </div>

                <div class="q-vr__body">
                  {%- if block.settings.quote_title != blank -%}
                    <h3 class="q-vr__quote-title">{{ block.settings.quote_title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.quote_body != blank -%}
                    <div class="q-vr__quote-body rte">{{ block.settings.quote_body }}</div>
                  {%- endif -%}

                  <div class="q-vr__footer{% if vr_avatar != blank %} q-vr__footer--has-avatar{% endif %}">
                    {%- if vr_avatar != blank -%}
                      <div class="q-vr__avatar">
                        {{
                          vr_avatar
                          | image_url: width: 200
                          | image_tag:
                            loading: 'lazy',
                            widths: '100,130,200',
                            alt: vr_av_alt
                        }}
                      </div>
                    {%- endif -%}

                    <div class="q-vr__footer-inner">
                      <div class="q-vr__top-line">
                        <div class="q-vr__top-left">
                          <div class="q-vr__name-row">
                            {%- if block.settings.reviewer_name != blank -%}
                              <span class="q-vr__reviewer-name">{{ block.settings.reviewer_name | escape }}</span>
                            {%- endif -%}
                            {%- if block.settings.verified_label != blank -%}
                              <span class="q-vr__badge">{{ block.settings.verified_label | escape }}</span>
                            {%- endif -%}
                          </div>

                          <div class="q-vr__stars-wrap">
                            {%- if vr_product != blank -%}
                              <div class="jdgm-widget jdgm-preview-badge" data-id="{{ vr_product.id }}">
                                {{- vr_product.metafields.judgeme.badge -}}
                              </div>
                            {%- else -%}
                              <div class="q-vr__stars" aria-hidden="true">
                                {%- for i in (1..vr_stars) -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path fill="var(--vr-star)" d="M12 3.5l2.7 5.47 6.04.88-4.37 4.26 1.03 6.02L12 17.77l-5.4 2.84 1.03-6.02L3.26 9.85l6.04-.88L12 3.5z"/>
                                  </svg>
                                {%- endfor -%}
                              </div>
                            {%- endif -%}

                            {%- if block.settings.reviewer_meta != blank -%}
                              <div class="q-vr__date">{{ block.settings.reviewer_meta | escape }}</div>
                            {%- endif -%}
                          </div>

                          
                        </div>

                        
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            </swiper-slide>
          {%- endfor -%}
        </swiper-container>
      </div>

      {%- if vr_carousel -%}
        <div class="q-vr__controls">
          <button
            type="button"
            class="q-vr__nav-btn q-vr__nav-btn--prev"
            data-vr-prev="{{ section.id }}"
            aria-label="{{ 'general.pagination.previous' | t | default: 'Previous slide' }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="q-vr__pagination" data-vr-pagination="{{ section.id }}"></div>
          <button
            type="button"
            class="q-vr__nav-btn q-vr__nav-btn--next"
            data-vr-next="{{ section.id }}"
            aria-label="{{ 'general.pagination.next' | t | default: 'Next slide' }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
      </verified-reviews-element>
    {%- endif -%}
  </div>
</div>

