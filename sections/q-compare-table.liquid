{%- comment -%}
  Section: q-compare-table
  功能说明：
  - 产品规格对比表格，左侧固定特征列，右侧产品列
  - 桌面端（≥750px）：静态横排展示，左侧特征列 + 多列产品卡片
  - 移动端（<750px）：左侧特征列固定，右侧 swiper-container 横向滑动
  - 产品图片悬浮于卡片顶部，底部"Shop now"按钮
  技术栈：
  - 纯展示类板块，Swiper breakpoints 实现多端适配，无需 Islands JS
  版本：1.0.0
{%- endcomment -%}

{%- liquid
  assign feature_rows = section.settings.feature_rows | newline_to_br | split: '<br />'
  assign product_blocks = section.blocks | where: 'type', 'product'
-%}

<style>
  .section-{{ section.id }} {
    --ct-bg: {{ section.settings.bg_color }};
    --ct-card-bg: {{ section.settings.card_bg_color }};
    --ct-btn-bg: {{ section.settings.btn_color }};
    --ct-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ct-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --ct-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --ct-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;

    overflow: hidden;
  }

  .section-{{ section.id }}.q-compare-table {
    background: var(--ct-bg, #F5F6F7);
    padding-top: var(--ct-padding-top-mobile, 40px);
    padding-bottom: var(--ct-padding-bottom-mobile, 40px);
    font-family: var(--font-body-family);
  }

  /* ===================== 外层布局 ===================== */
  .section-{{ section.id }} .q-ct__layout {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding-top: 132px;
  }

  /* ===================== 左侧特征列 ===================== */
  .section-{{ section.id }} .q-ct__feature-col {
    flex-shrink: 0;
    width: 173px;
    /* 移动端：与右侧 swiper 保持对齐 */
  }

  .section-{{ section.id }} .q-ct__feature-card {
    background: var(--ct-card-bg, #F5F6F7);
    border-radius: 10px;
    padding: 0 0 0px;
  }

  /* 产品图片占位区域（对齐右侧卡片图片区高度） */
  .section-{{ section.id }} .q-ct__feature-img-placeholder {
    height: 25px;
    display: flex;
    align-items: flex-end;
    {% comment %} padding: 0 10px 8px; {% endcomment %}
  }

  .section-{{ section.id }} .q-ct__feature-title {
    font-size: 16px;
    font-weight: 700;
    color: #2d4e76;
    margin: 0;
    padding: 0 10px 0;
    line-height: 36px;
    margin-bottom: 8px;
  }

  .section-{{ section.id }} .q-ct__feature-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .section-{{ section.id }} .q-ct__feature-list li {
    font-size: 11px;
    font-weight: 700;
    color: #2d4e76;
    padding: 0 10px;
    line-height: 1.2;
    height: 56px;
    display: flex;
    align-items: center;
    border-top: 1px solid #e8edf5;
    box-sizing: border-box;
  }

  .section-{{ section.id }} .q-ct__feature-list li:first-child {
    border-top: none;
  }

  /* ===================== 右侧 swiper ===================== */
  .section-{{ section.id }} .q-ct__swiper-wrap {
    flex: 1;
    min-width: 0;
  }

  .section-{{ section.id }} .q-ct__swiper {
    width: 100%;
  }
  .section-{{ section.id }} .q-ct__swiper {
    display: flex;
    gap: 10px;
  }

  .section-{{ section.id }} .q-ct__swiper swiper-slide {
    width: 173px;
    flex-shrink: 0;
    overflow: visible;
  }


  /* ===================== 产品卡 ===================== */
  .section-{{ section.id }} .q-ct__product-card {
    background: var(--ct-card-bg, #F5F6F7);
    border-radius: 10px;
    border: 1px solid #f3f7ff;
    position: relative;
    {% comment %} height: 100%; {% endcomment %}
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    overflow: visible;
  }


  /* 图片区域：从卡片顶部向上溢出 */
  .section-{{ section.id }} .q-ct__product-img-wrap {
    position: relative;
    height: 157px;
    overflow: visible;
    flex-shrink: 0;
    margin-top: -132px;
  }

  .section-{{ section.id }} .q-ct__product-img {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
  }

  .section-{{ section.id }} .q-ct__product-name {
    font-size: 16px;
    font-weight: 700;
    color: #2d4e76;
    margin: 0;
    padding: 0 10px;
    line-height: 36px;
    margin-bottom: 8px;
  }

  /* 规格行列表 */
  .section-{{ section.id }} .q-ct__spec-list {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .section-{{ section.id }} .q-ct__spec-list li {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #1e1e1e;
    padding: 0 10px;
    height: 56px;
    border-top: 1px solid #e8edf5;
    line-height: 1.2;
    box-sizing: border-box;
  }

  .section-{{ section.id }} .q-ct__spec-list li:first-child {
    border-top: none;
  }

  .section-{{ section.id }} .q-ct__check-icon {
    flex-shrink: 0;
    width: 22px;
    height: 24px;
  }

  /* Shop now 按钮 */
  .section-{{ section.id }} .q-ct__shop-btn {
    margin: 16px auto 0;
    background: var(--ct-btn-bg, #faa61a);
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    border-radius: 30px;
    height: 32px;
    width: 146px;
    transition: background 0.2s, opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-{{ section.id }} .q-ct__shop-btn:hover {
    background: #e8940f;
  }

  .section-{{ section.id }} .q-ct__shop-btn:active {
    opacity: 0.8;
  }

  /* ===================== Swiper 进度条分页 ===================== */
  .section-{{ section.id }} .q-ct__swiper::part(pagination) {
    position: relative;
    width: 142px;
    height: 4px;
    margin: 32px auto 0;
    background: #c8d4e8;
    border-radius: 2px;
    overflow: hidden;
    --swiper-pagination-color: #1e1e1e;
  }

  .section-{{ section.id }} .q-ct__swiper::part(pagination-progressbar-fill) {
    background: #1e1e1e;
    border-radius: 2px;
    height: 100%;
  }

  .section-{{ section.id }} .q-ct__swiper::part(container) {
    overflow: visible;
  }

  /* ===================== 桌面端（≥750px） ===================== */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-compare-table {
      padding-top: var(--ct-padding-top-desktop, 60px);
      padding-bottom: var(--ct-padding-bottom-desktop, 60px);
    }

    /* 桌面端外层：flex 布局，特征列 + 产品列 */
    .section-{{ section.id }} .q-ct__layout {
      gap: 19px;
      align-items: stretch;
    }

    .section-{{ section.id }} .q-ct__feature-col {
      width: 340px;
    }

    .section-{{ section.id }} .q-ct__feature-img-placeholder {
      height: 93px;
      margin-bottom: 42px;
    }

    .section-{{ section.id }} .q-ct__feature-title {
      font-size: 18px;
      padding: 0 18px 0;
      margin-bottom: 18px;
    }

    .section-{{ section.id }} .q-ct__feature-list li {
      font-size: 14px;
      padding: 0 18px;
      height: 66px;
    }

    .section-{{ section.id }} .q-ct__product-img-wrap {
      height: 224px;
      margin-top: -132px;
      margin-bottom: 42px;
    }

    .section-{{ section.id }} .q-ct__product-img {
      width: 100%;
      height: 100%;
    }

    .section-{{ section.id }} .q-ct__product-name {
      font-size: 22px;
      padding: 0 18px;
      margin-bottom: 18px;
    }

    .section-{{ section.id }} .q-ct__swiper swiper-slide {
      width: 340px;
    }

    .section-{{ section.id }} .q-ct__swiper {
      gap: 12px;
    }

    .section-{{ section.id }} .q-ct__spec-list li {
      font-size: 16px;
      padding: 0 18px;
      min-height: 66px;
      gap: 8px;
    }

    .section-{{ section.id }} .q-ct__check-icon {
      width: 22px;
      height: 24px;
    }

    .section-{{ section.id }} .q-ct__shop-btn {
      font-size: 18px;
      width: 188px;
      height: 46px;
    }

    /* 桌面端：swiper 不滑动，所有产品卡横排 */
    .section-{{ section.id }} .q-ct__swiper-wrap {
      overflow: visible;
    }
  }
</style>

<div class="q-compare-table section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    <div class="q-ct__layout">
      <div class="q-ct__swiper-wrap">
        <swiper-container
          class="q-ct__swiper"
          slides-per-view="auto"
          space-between="10"
          pagination="true"
          pagination-type="progressbar"
          breakpoints='{"750":{"spaceBetween":12}}'
        >
          {%- comment -%} 左侧特征列 {%- endcomment -%}
          <swiper-slide>
            <div class="q-ct__feature-col">
              <div class="q-ct__feature-card">
                <div class="q-ct__feature-img-placeholder"></div>
                <p class="q-ct__feature-title">{{ section.settings.feature_col_title | default: 'Feature' }}</p>
                <ul class="q-ct__feature-list">
                  {%- for row in feature_rows -%}
                    {%- assign row_text = row | strip -%}
                    {%- if row_text != blank -%}
                      <li>{{ row_text }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          </swiper-slide>
          {%- comment -%} 右侧产品列（swiper） {%- endcomment -%}
          {%- for block in product_blocks -%}
            {%- comment -%}
              规格字段使用 richtext（支持动态源），这里兼容两种格式：
              - 旧数据：纯文本 + 换行（不含 <p>），按换行拆分
              - 新数据：richtext HTML（<p>...</p>），按段落拆分
            {%- endcomment -%}
            {%- comment -%}
              规格拆分（统一一条流水线，避免分支遗漏）：
              1. 多段 <p> 先合并为分隔符（须在 newline_to_br 之前，避免 </p>\\n<p> 变成 </p><br /><p>）
              2. newline_to_br：把「段内真实换行」转成 <br />（单段 <p> 多行、纯文本多行都靠这步）
              3. 所有 <br> 变分隔符，去 <p>，再 split
            {%- endcomment -%}
            {%- assign spec_row_delim = '##q-ct-spec-row##' -%}
            {%- assign raw_specs = block.settings.specs | default: '' | strip -%}
            {%- if raw_specs == blank -%}
              {%- assign spec_rows = '' | split: '@@q-ct-empty@@' -%}
            {%- else -%}
              {%- assign specs_work = raw_specs
                | replace: '</p><p>', spec_row_delim
                | replace: '</p> <p>', spec_row_delim
                | replace: "</p>\n<p>", spec_row_delim
                | replace: "</p>\r\n<p>", spec_row_delim
                | replace: '</p><br /><p>', spec_row_delim
                | replace: '</p><br/><p>', spec_row_delim
              -%}
              {%- assign specs_work = specs_work | newline_to_br -%}
              {%- assign specs_work = specs_work
                | replace: '<br />', spec_row_delim
                | replace: '<br/>', spec_row_delim
                | replace: '<br>', spec_row_delim
              -%}
              {%- assign specs_work = specs_work
                | replace: '<p>', ''
                | replace: '</p>', ''
              -%}
              {%- assign spec_rows = specs_work | split: spec_row_delim -%}
            {%- endif -%}
            <swiper-slide {{ block.shopify_attributes }}>
              <div class="q-ct__product-card">

                {%- comment -%} 产品图片区 {%- endcomment -%}
                <div class="q-ct__product-img-wrap">
                  {%- if block.settings.product_image != blank -%}
                    {{- block.settings.product_image | image_url: width: 800 | image_tag:
                      class: 'q-ct__product-img',
                      loading: 'lazy'
                    -}}
                  {%- endif -%}
                </div>

                <p class="q-ct__product-name">{{ block.settings.product_name }}</p>

                {%- comment -%} 规格行 {%- endcomment -%}
                <ul class="q-ct__spec-list">
                  {%- for spec in spec_rows -%}
                    {%- assign spec_text = spec | strip_html | strip -%}
                    {%- if spec_text != blank -%}
                      <li>
                        <svg class="q-ct__check-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="24" viewBox="0 0 22 24" fill="none" aria-hidden="true">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M18.1509 10.222C18.2701 10.794 18.3333 11.389 18.3333 12C18.3333 16.415 15.0471 20 11 20C6.9529 20 3.66665 16.415 3.66665 12C3.66665 7.585 6.9529 4 11 4C11.8461 4 12.6582 4.156 13.4145 4.444C13.8921 4.626 14.4146 4.351 14.5814 3.83C14.7482 3.308 14.4961 2.738 14.0186 2.556C13.0726 2.196 12.0569 2 11 2C5.9409 2 1.83331 6.481 1.83331 12C1.83331 17.519 5.9409 22 11 22C16.0591 22 20.1666 17.519 20.1666 12C20.1666 11.237 20.0878 10.493 19.9393 9.778C19.8266 9.24 19.3352 8.903 18.8421 9.025C18.3489 9.147 18.0391 9.683 18.1509 10.222ZM10.0833 12.586L17.6852 4.293C18.0427 3.903 18.6239 3.903 18.9814 4.293C19.3389 4.683 19.3389 5.317 18.9814 5.707L10.7314 14.707C10.3739 15.098 9.79273 15.098 9.43523 14.707L6.68523 11.707C6.32773 11.317 6.32773 10.683 6.68523 10.293C7.04273 9.903 7.6239 9.903 7.9814 10.293L10.0833 12.586Z" fill="#1565D8"/>
                        </svg>
                        <span>{{ spec_text }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
              {%- comment -%} Shop now 按钮 {%- endcomment -%}
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link | default: '/' }}" class="q-ct__shop-btn">
                  {{ block.settings.button_label }}
                </a>
              {%- endif -%}
            </swiper-slide>
          {%- endfor -%}
        </swiper-container>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "q-compare-table",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Discover What's Popular" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": true },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "linear-gradient(90deg, #6cbce7 0%, #367cf6 67%)" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },

    { "type": "header", "content": "表格设置" },
    {
      "type": "text",
      "id": "feature_col_title",
      "label": "特征列标题",
      "default": "Feature"
    },
    {
      "type": "textarea",
      "id": "feature_rows",
      "label": "特征列（每行一项）",
      "info": "每行输入一个特征名称，与产品列规格一一对应",
      "default": "Video Capture Resolution\nViewing Angle\nNight Vision Range\nConnectivity Protocol\nController Type\nPower Source\nLow Light Technology\nBattery Power\nMax Supported"
    },

    { "type": "header", "content": "按钮颜色" },
    {
      "type": "color_background",
      "id": "btn_color",
      "label": "按钮背景色",
      "default": "#faa61a"
    },

    { "type": "header", "content": "板块背景" },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "背景色",
      "default": "#F5F6F7"
    },
    {
      "type": "color_background",
      "id": "card_bg_color",
      "label": "卡片背景色",
      "default": "#ffffff"
    },

    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "产品列",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "产品图片"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "产品名称",
          "default": "Q3M8"
        },
        {
          "type": "richtext",
          "id": "specs",
          "label": "规格列表（每行一项）",
          "info": "建议每条一个段落（一个回车），支持绑定 rich_text metafield",
          "default": "<p>2K / 3MP</p><p>360 Degrees</p><p>50 Feet</p><p>Wi-Fi</p><p>Alexa, Assistant</p><p>Solar &amp; Battery Powered</p><p>Night Color</p><p>5000 mAh, 5W, 5V</p><p>SD Card, up to 128GB</p>"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "按钮链接",
          "default": "/"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "按钮文字",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-compare-table",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "product_name": "Q3M8",
            "specs": "<p>2K / 3MP</p><p>360 Degrees</p><p>50 Feet</p><p>Wi-Fi</p><p>Alexa, Assistant</p><p>Solar &amp; Battery Powered</p><p>Night Color</p><p>5000 mAh, 5W, 5V</p><p>SD Card, up to 128GB</p>",
            "button_link": "/",
            "button_label": "Shop now"
          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "C3M5",
            "specs": "<p>3MP</p><p>135 Degrees</p><p>55 Feet</p><p>Wi-Fi</p><p>Amazon Alexa</p><p>Solar Powered</p><p>Night Color</p><p>5000 mAh, 5W, 5V</p><p>SD Card, up to 128GB</p>",
            "button_link": "/",
            "button_label": "Shop now"
          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "Q4M5",
            "specs": "<p>2K / 3MP</p><p>360 Degrees</p><p>50 Feet</p><p>Wi-Fi</p><p>Alexa, Assistant</p><p>Solar &amp; Battery Powered</p><p>Night Color</p><p>5000 mAh, 5W, 5V</p><p>SD Card, up to 128GB</p>",
            "button_link": "/",
            "button_label": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
