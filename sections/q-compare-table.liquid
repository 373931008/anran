          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "C3M5",
            "specs": "3MP\n135 Degrees\n55 Feet\nWi-Fi\nAmazon Alexa\nSolar Powered\nNight Color\n5000 mAh, 5W, 5V\nSD Card, up to 128GB",
            "button_link": "/",
            "button_label": "Shop now"
          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "Q4M5",
            "specs": "2K / 3MP\n360 Degrees\n50 Feet\nWi-Fi\nAlexa, Assistant\nSolar & Battery Powered\nNight Color\n5000 mAh, 5W, 5V\nSD Card, up to 128GB",
            "button_link": "/",
            "button_label": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
