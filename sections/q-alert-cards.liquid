{%- comment -%}
  Section: q-alert-cards
  功能说明：实时警报特性卡片展示板块
  - 桌面端：swiper-container，slidesPerView=3，每张卡片 1/3 宽，间距 24px
  - 移动端：swiper-container，slides-per-view="auto"，卡片固定宽度 260px，间距 12px，右侧自然露出
  技术栈：
  - swiper-container Web Component
  - 纯展示，无 Islands JS
  - Snippet: snippets/q-section-header.liquid
  版本：1.1.0
{%- endcomment -%}

<style>
  .section-{{ section.id }} {
    --ac-bg: {{ section.settings.bg_color }};
    --ac-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ac-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --ac-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --ac-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;

    /* 移动端变量 */
    --ac-gap: 12px;
    --ac-card-width: 300px;
    --ac-card-radius: 10px;
    --ac-card-ratio: 283 / 346;
    --ac-text-padding: 16px 20px;
    --ac-title-size: 18px;
    --ac-title-lh: 1.4;
    --ac-title-weight: 600;
    --ac-desc-size: 12px;
    --ac-desc-lh: 18px;
    --ac-desc-weight: 500;
    --ac-title-color: #F3F3F3;
    --ac-desc-color: #cacbcc;

    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      /* 桌面端覆盖 */
      --ac-gap: 24px;
      --ac-card-ratio: 437 / 534;
      --ac-text-padding: 32px 37px;
      --ac-title-size: 27px;
      --ac-title-lh: 1.4;
      --ac-title-weight: 500;
      --ac-desc-size: 16px;
      --ac-desc-lh: 24px;
      --ac-desc-weight: 400;
    }
  }

  .section-{{ section.id }}.q-alert-cards {
    background: var(--ac-bg, #ffffff);
    padding-top: var(--ac-padding-top-mobile, 40px);
    padding-bottom: var(--ac-padding-bottom-mobile, 40px);
    font-family: var(--font-body-family);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-alert-cards {
      padding-top: var(--ac-padding-top-desktop, 60px);
      padding-bottom: var(--ac-padding-bottom-desktop, 60px);
    }
  }

  /* swiper-container 布局：移动端需要 overflow 可见以露出右侧卡片 */
  {% comment %} .section-{{ section.id }} .q-ac__swiper-wrap {
    overflow: hidden;
  } {% endcomment %}

  .section-{{ section.id }} swiper-container {
    display: flex;
    gap: var(--ac-gap);
  }

  .section-{{ section.id }} swiper-container::part(container) {
    overflow: visible;
  }

  .section-{{ section.id }} swiper-slide {
    flex-shrink: 0;
    /* 移动端：固定宽度 */
    width: var(--ac-card-width);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} swiper-slide {
      /* 桌面端：1/3 容器宽度，减去两个间距平摊后每张卡片占用的间距量 */
      width: calc((100% - var(--ac-gap) * 2) / 3);
    }
  }

  /* 卡片：相对定位，撑开宽高比 */
  .section-{{ section.id }} .q-ac__card {
    position: relative;
    border-radius: var(--ac-card-radius);
    overflow: hidden;
    aspect-ratio: var(--ac-card-ratio);
    height: 100%;
  }

  /* 背景图片 */
  .section-{{ section.id }} .q-ac__card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .q-ac__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 文字层：全宽高 + 渐变背景，内容靠下 */
  .section-{{ section.id }} .q-ac__card-body {
    position: absolute;
    inset: 0;
    height: 100%;
    /* background: linear-gradient(180deg, rgba(0, 0, 0, 0.70) 0%, rgba(0, 0, 0, 0.00) 100%); */
    border-radius: var(--ac-card-radius);
    padding: var(--ac-text-padding);
    display: flex;
    flex-direction: column;
  }

  .section-{{ section.id }} .q-ac__card-title {
    font-size: var(--ac-title-size);
    line-height: var(--ac-title-lh);
    font-weight: var(--ac-title-weight);
    color: var(--ac-title-color);
    margin: 0 0 8px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-ac__card-title {
      margin: 0 0 14px;
    }
  }

  .section-{{ section.id }} .q-ac__card-desc {
    font-size: var(--ac-desc-size);
    line-height: var(--ac-desc-lh);
    font-weight: var(--ac-desc-weight);
    color: var(--ac-desc-color);
    margin: 0;
  }

  .section-{{ section.id }} .q-ac__card-desc p {
    margin: 0;
  }
</style>

<div class="q-alert-cards section-{{ section.id }}">
  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    {%- if section.blocks.size > 0 -%}
      <div class="q-ac__swiper-wrap">
        <swiper-container
          slides-per-view="auto"
          space-between="12"
          grab-cursor="true"
          loop="false"
          breakpoints='{"750":{"spaceBetween":24}}'
        >
          {%- for block in section.blocks -%}
            {%- if block.type == 'card' -%}
              <swiper-slide {{ block.shopify_attributes }}>
                <div class="q-ac__card">
                  {%- if block.settings.image != blank -%}
                    <div class="q-ac__card-image">
                      {{- block.settings.image
                        | image_url: width: 900
                        | image_tag:
                          loading: 'lazy',
                          sizes: '(min-width: 750px) calc((100vw - 80px) / 3), 260px',
                          widths: '300, 400, 600, 900'
                      -}}
                    </div>
                  {%- endif -%}

                  <div class="q-ac__card-body">
                    {%- if block.settings.title != blank -%}
                      <h3 class="q-ac__card-title">{{ block.settings.title }}</h3>
                    {%- endif -%}

                    {%- if block.settings.description != blank -%}
                      <div class="q-ac__card-desc">{{ block.settings.description }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </swiper-slide>
            {%- endif -%}
          {%- endfor -%}
        </swiper-container>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "q-alert-cards",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "<em>Real-Time Alerts</em> and Instant Siren" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": false },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "linear-gradient(90deg, #6CBCE7 0%, #367CF6 100%)" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 50 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "板块背景" },
    { "type": "color_background", "id": "bg_color", "label": "背景色", "default": "#FFFFFF" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "警报卡片",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "背景图片" },
        { "type": "text", "id": "title", "label": "标题", "default": "Alert Title" },
        { "type": "richtext", "id": "description", "label": "描述", "default": "<p>Alert feature description text goes here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-alert-cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Instant App Alerts",
            "description": "<p>Receive instant notifications on your phone when important motion is detected, so you can respond quickly.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Threat prevention",
            "description": "<p>Activate built-in spotlight or siren to deter intruders and add an extra layer of active protection.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Custom Alert Zones & All-Round Patrol",
            "description": "<p>Set custom detection zones and sensitivity to focus on important areas and reduce false alerts.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
