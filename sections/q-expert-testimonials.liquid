        <div class="q-et__nav" aria-label="{{ 'sections.expert_testimonials.nav_label' | t | default: 'Testimonials navigation' }}">
          <button
            class="q-et__nav-btn"
            type="button"
            aria-label="Previous"
            data-carousel-prev="{{ section.id }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button
            class="q-et__nav-btn"
            type="button"
            aria-label="Next"
            data-carousel-next="{{ section.id }}"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        {%- endif -%}
      </expert-testimonials-element>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "q-expert-testimonials",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "板块标题" },
    { "type": "inline_richtext", "id": "header_title", "label": "标题", "default": "Tested and trusted by <em>home security experts</em>" },
    { "type": "richtext", "id": "header_description", "label": "描述" },
    { "type": "checkbox", "id": "header_center", "label": "居中对齐", "default": true },
    { "type": "color_background", "id": "header_em_color", "label": "em 高亮色", "default": "linear-gradient(90deg, #6CBCE7 0%, #367CF6 100%)" },
    { "type": "range", "id": "header_title_size_desktop", "label": "标题字号（桌面端）", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 46 },
    { "type": "range", "id": "header_title_size_mobile", "label": "标题字号（移动端）", "min": 16, "max": 50, "step": 2, "unit": "px", "default": 22 },
    { "type": "range", "id": "header_desc_size_desktop", "label": "描述字号（桌面端）", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "header_desc_size_mobile", "label": "描述字号（移动端）", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "header_margin_bottom_desktop", "label": "标题下边距（桌面端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "header_margin_bottom_mobile", "label": "标题下边距（移动端）", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "header", "content": "板块背景" },
    { "type": "color_background", "id": "bg_color", "label": "背景色", "default": "#FFFFFF" },
    { "type": "image_picker", "id": "bg_image", "label": "背景图", "info": "图片将 100% 居中裁剪覆盖板块背景，设置后会覆盖背景色" },
    { "type": "header", "content": "上下边距" },
    { "type": "range", "id": "padding_top_mobile", "label": "上边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "下边距（移动端）", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top_desktop", "label": "上边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "下边距（桌面端）", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "header", "content": "轮播" },
    { "type": "checkbox", "id": "autoplay_carousel", "label": "自动轮播", "default": false },
    { "type": "range", "id": "autoplay_delay", "label": "轮播间隔（秒）", "min": 2, "max": 15, "step": 1, "unit": "s", "default": 5 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "评价卡片",
      "settings": [
        { "type": "header", "content": "媒体" },
        { "type": "video", "id": "local_video", "label": "本地视频", "info": "未填视频链接时使用：上传后可在卡片内自动播放，点击弹窗播放；封面使用视频预览图" },
        { "type": "video_url", "id": "video", "label": "视频链接（YouTube/Vimeo）", "accept": ["youtube", "vimeo"], "info": "优先使用。填写后固定显示播放按钮，点击弹窗播放" },
        { "type": "url", "id": "video_url_alt", "label": "视频链接（备用）", "default": "/", "info": "当上方链接无法保存时使用，支持 YouTube Shorts（如 youtube.com/shorts/xxx）等" },
        { "type": "header", "content": "特性标签" },
        { "type": "text", "id": "pill_1", "label": "标签 1", "default": "Cutting-edge Security Technology" },
        { "type": "text", "id": "pill_2", "label": "标签 2", "default": "Ideal for Homes, Apartments, and Small Businesses" },
        { "type": "text", "id": "pill_3", "label": "标签 3", "default": "Easy to Install and Simple to Use" },
        { "type": "header", "content": "引用语" },
        { "type": "richtext", "id": "quote", "label": "引用内容", "default": "<p>See for yourself how this versatile camera <strong>protects what matters most.</strong></p>" },
        { "type": "header", "content": "专家信息" },
        { "type": "image_picker", "id": "expert_avatar", "label": "头像" },
        { "type": "text", "id": "expert_name", "label": "姓名", "default": "Ava Martinez" },
        { "type": "text", "id": "expert_title", "label": "职称", "default": "Home Security Specialist" },
        { "type": "checkbox", "id": "show_verified_badge", "label": "认证徽章", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "q-expert-testimonials",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "pill_1": "Cutting-edge Security Technology",
            "pill_2": "Ideal for Homes, Apartments, and Small Businesses",
            "pill_3": "Easy to Install and Simple to Use",
            "expert_name": "Ava Martinez",
            "expert_title": "Home Security Specialist",
            "show_verified_badge": true
          }
        },
        {
          "type": "card",
          "settings": {
            "pill_1": "Advanced Motion Detection",
            "pill_2": "Night Vision Technology",
            "pill_3": "Cloud & Local Storage Support",
            "expert_name": "James Chen",
            "expert_title": "Smart Home Consultant",
            "show_verified_badge": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
