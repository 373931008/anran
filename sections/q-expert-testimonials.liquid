{%- comment -%}
  Section: q-expert-testimonials
  功能说明：专家评价/证言轮播板块
  - 每张卡片包含：视频/图片、特性标签、引用语、专家信息（头像、姓名、职称、认证图标）
  - 支持背景图配置，背景图 100% 居中裁剪覆盖
  - 使用 swiper-container 实现轮播
  技术栈：
  - Snippet: snippets/q-section-header.liquid
  版本：1.0.0
{%- endcomment -%}

{%- liquid
  assign bg_image = section.settings.bg_image
  assign bg_color = section.settings.bg_color
  assign cards = section.blocks | where: 'type', 'card'
-%}

<style>
  .section-{{ section.id }} {
    --et-bg: {{ bg_color }};
    --et-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --et-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --et-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --et-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;

    /* 移动端变量 */
    --et-card-radius: 0px;
    --et-media-ratio: 375 / 236;
    --et-pill-height: 30px;
    --et-pill-font: 12px;
    --et-pill-radius: 100px;
    --et-quote-font: 15px;
    --et-quote-line-height: 1.3;
    --et-expert-name-font: 14px;
    --et-expert-title-font: 12px;
    --et-avatar-size: 44px;
    --et-content-gap: 12px;
    --et-pill-gap: 8px;

    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      /* 桌面端覆盖 */
      --et-card-radius: 10px;
      --et-media-ratio: 730 / 455;
      --et-pill-height: 47px;
      --et-pill-font: 14px;
      --et-quote-font: 20px;
      --et-quote-line-height: 1.45;
      --et-expert-name-font: 18px;
      --et-expert-title-font: 14px;
      --et-avatar-size: 56px;
      --et-content-gap: 24px;
      --et-pill-gap: 12px;
    }
  }

  .section-{{ section.id }}.q-expert-testimonials {
    position: relative;
    background: var(--et-bg, #ffffff);
    padding-top: var(--et-pt-mobile, 40px);
    padding-bottom: var(--et-pb-mobile, 40px);
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.q-expert-testimonials {
      padding-top: var(--et-pt-desktop, 60px);
      padding-bottom: var(--et-pb-desktop, 60px);
    }
  }

  /* 背景图 */
  .section-{{ section.id }} .q-et__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .section-{{ section.id }} .q-et__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .section-{{ section.id }} .page-width {
    position: relative;
    z-index: 1;
  }
  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .page-width {
      padding-left: 0;
      padding-right: 0;
    }

    .section-{{ section.id }} .q-section-header {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  /* Swiper 容器 */
  .section-{{ section.id }} .q-et__swiper {
    overflow: hidden;
    contain: layout paint;
  }

  .section-{{ section.id }} .q-et__swiper swiper-container {
    width: 100%;
    display: block;
  }

  .section-{{ section.id }} .q-et__swiper swiper-slide {
    flex-shrink: 0;
  }

  /* 移动端：卡片垂直布局，单列 */
  .section-{{ section.id }} .q-et__card {
    border-radius: var(--et-card-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--et-content-gap);
    height: auto;
  }

  /* 桌面端：卡片水平两列布局 */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__card {
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }
  }

  /* 左列：媒体区 */
  .section-{{ section.id }} .q-et__media-col {
    flex-shrink: 0;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__media-col {
      width: 51%;
    }
  }

  .section-{{ section.id }} .q-et__media-wrap {
    position: relative;
    border-radius: var(--et-card-radius);
    overflow: hidden;
    aspect-ratio: var(--et-media-ratio);
    background: #000;
    width: 100%;
  }

  .section-{{ section.id }} .q-et__media-wrap img,
  .section-{{ section.id }} .q-et__media-wrap .q-et__inline-video,
  .section-{{ section.id }} .q-et__media-wrap iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .q-et__media-wrap--has-video {
    cursor: pointer;
  }

  .section-{{ section.id }} .q-et__inline-video {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .section-{{ section.id }} .q-et__media-poster,
  .section-{{ section.id }} .q-et__media-placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .section-{{ section.id }} .q-et__media-placeholder {
    display: block;
  }

  /* 播放按钮（整区可点，按钮仅视觉） */
  .section-{{ section.id }} .q-et__play-btn {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .section-{{ section.id }} .q-et__media-wrap--has-video:hover .q-et__play-btn {
    opacity: 0.9;
  }

  .section-{{ section.id }} .q-et__play-icon {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__play-icon {
      width: 80px;
      height: 80px;
    }
  }

  .section-{{ section.id }} .q-et__play-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* 右列：文字内容 */
  .section-{{ section.id }} .q-et__content-col {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--et-content-gap);
    padding: 0 16px 16px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__content-col {
      padding: 0px 0 0;
      justify-content: center;
    }
  }

  /* Pill 标签列表 */
  .section-{{ section.id }} .q-et__pills {
    display: flex;
    flex-direction: column;
    gap: var(--et-pill-gap);
    margin-bottom: 0px;
    margin-top: 0px;
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .q-et__pills {
      padding-left: 10px;
      margin-bottom: 0px;
      margin-top: 0px;
    }
  }

  .section-{{ section.id }} .q-et__pill {
    display: inline-flex;
    align-items: center;
    {% comment %} height: var(--et-pill-height); {% endcomment %}
    padding: 8px 16px;
    border-radius: var(--et-pill-radius);
    background: linear-gradient(180deg, #93b8ed 0%, #ffffff 100%);
    border: 1px solid #f3f7ff;
    font-size: var(--et-pill-font);
    color: #1565d8;
    font-weight: 400;
    width: fit-content;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__pill {
      padding: 10px 20px;
    }
  }

  /* 引用区 */
  .section-{{ section.id }} .q-et__quote-wrap {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .section-{{ section.id }} .q-et__quote-icon {
    flex-shrink: 0;
    width: 19px;
    height: 19px;
    margin-top: 4px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__quote-icon {
      width: 50px;
      height: 50px;
    }
  }

  .section-{{ section.id }} .q-et__quote-text {
    font-size: var(--et-quote-font);
    line-height: var(--et-quote-line-height);
    color: #4e5357;
    margin: 0;
  }

  .section-{{ section.id }} .q-et__quote-text strong {
    color: #4e5357;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__expert {
      padding-left: 40px;
    }
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .q-et__expert {
      padding-left: 10px;
    }
  }

  /* 专家信息 */
  .section-{{ section.id }} .q-et__expert {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-{{ section.id }} .q-et__avatar {
    width: var(--et-avatar-size);
    height: var(--et-avatar-size);
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .q-et__expert-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .section-{{ section.id }} .q-et__expert-name-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .section-{{ section.id }} .q-et__expert-name {
    font-size: var(--et-expert-name-font);
    font-weight: 600;
    color: #1e1e1e;
    margin: 0;
    line-height: 1.4;
  }

  .section-{{ section.id }} .q-et__expert-badge {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__expert-badge {
      width: 26px;
      height: 26px;
    }
  }

  .section-{{ section.id }} .q-et__expert-title {
    font-size: var(--et-expert-title-font);
    color: #1e1e1e;
    margin: 0;
    line-height: 1.5;
    font-weight: 400;
  }

  /* Swiper 分页 / 导航 */
  .section-{{ section.id }} .q-et__nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .q-et__nav {
      margin-top: 32px;
    }
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .q-et__nav {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .section-{{ section.id }} .q-et__nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(238, 244, 255, 0.70);
    background: rgba(238, 244, 255, 0.70);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #000;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
    padding: 0;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .q-et__nav-btn:hover:not(:disabled):not(.swiper-button-disabled) {
    background: rgba(238, 244, 255, 0.80);
    border-color: rgba(238, 244, 255, 0.80);
  }

  .section-{{ section.id }} .q-et__nav-btn:active:not(:disabled):not(.swiper-button-disabled) {
    background: rgba(238, 244, 255, 0.90);
  }

  .section-{{ section.id }} .q-et__nav-btn:disabled,
  .section-{{ section.id }} .q-et__nav-btn.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .section-{{ section.id }} .q-et__nav-btn svg {
    width: 16px;
    height: 16px;
    display: block;
  }
</style>

<div class="q-expert-testimonials section-{{ section.id }}">

  {%- if bg_image != blank -%}
    <div class="q-et__bg-image">
      {{- bg_image | image_url: width: 1440 | image_tag:
        loading: 'lazy',
        sizes: '100vw',
        widths: '375, 750, 1080, 1440',
        alt: bg_image.alt
      -}}
    </div>
  {%- endif -%}

  <div class="page-width">
    {%- render 'q-section-header', section: section -%}

    {%- if cards.size > 0 -%}
      <expert-testimonials-element
        client:visible
        data-section-id="{{ section.id }}"
        data-autoplay-carousel="{{ section.settings.autoplay_carousel }}"
        data-autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
      >
      <div class="q-et__swiper">
        <swiper-container
          id="q-et-swiper-{{ section.id }}"
          slides-per-view="1"
          space-between="0"
          loop
          navigation="true"
          navigation-prev-el="[data-carousel-prev='{{ section.id }}']"
          navigation-next-el="[data-carousel-next='{{ section.id }}']"
          pagination="false"
          {% if section.settings.autoplay_carousel %}autoplay="true" autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"{% endif %}
        >
          {%- for block in cards -%}
            {%- liquid
              assign local_video = block.settings.local_video
              assign video_url = block.settings.video
              assign has_local = false
              if local_video != blank
                assign has_local = true
              endif
              assign has_external = false
              assign external_url = ''
              if video_url != blank and video_url.url != blank
                assign has_external = true
                assign external_url = video_url.url
              elsif block.settings.video_url_alt != blank and block.settings.video_url_alt != '/'
                assign has_external = true
                assign external_url = block.settings.video_url_alt
              endif
              assign has_video = false
              if has_local or has_external
                assign has_video = true
              endif
              if local_video != blank and local_video.preview_image != blank
                assign poster_image = local_video.preview_image
              else
                assign poster_image = ''
              endif
              assign pills = ''
              if block.settings.pill_1 != blank
                assign pills = pills | append: block.settings.pill_1 | append: '||'
              endif
              if block.settings.pill_2 != blank
                assign pills = pills | append: block.settings.pill_2 | append: '||'
              endif
              if block.settings.pill_3 != blank
                assign pills = pills | append: block.settings.pill_3 | append: '||'
              endif
              assign pill_items = pills | split: '||'
            -%}
            <swiper-slide {{ block.shopify_attributes }}>
              <div class="q-et__card">

                <div class="q-et__media-col">
                  {%- liquid
                    assign et_poster_ratio = 1.6
                    if poster_image != blank and poster_image.aspect_ratio != blank
                      assign et_poster_ratio = poster_image.aspect_ratio
                    endif
                    assign et_poster_width = 980
                    assign et_poster_height = et_poster_width | divided_by: et_poster_ratio | round
                  -%}
                  <div
                    class="q-et__media-wrap{% if has_external %} q-et__media-wrap--has-video{% endif %}"
                    {% if has_external %}
                      role="button"
                      tabindex="0"
                      data-et-video-url="{{ external_url | escape }}"
                      aria-label="{{ 'sections.expert_testimonials.play_video' | t | default: 'Play video' }}"
                    {% endif %}
                  >
                    {%- comment -%} 封面：仅用视频预览图，尺寸统一 image_size 980 {%- endcomment -%}
                    {%- if poster_image != blank -%}
                      {{- poster_image | image_url: width: 980 | image_tag:
                        loading: 'lazy',
                        width: et_poster_width,
                        height: et_poster_height,
                        sizes: '(min-width: 750px) 490px, 100vw',
                        widths: '375, 490, 750, 980',
                        alt: poster_image.alt | default: block.settings.expert_name,
                        class: 'q-et__media-poster'
                      -}}
                    {%- else -%}
                      <div class="q-et__media-placeholder" style="width:100%;height:100%;background:#e5e7eb;"></div>
                    {%- endif -%}

                    {%- if has_local and local_video.sources.size > 0 -%}
                      <video
                        class="q-et__inline-video"
                        muted
                        playsinline
                        data-et-inline-video
                        preload="metadata"
                        poster="{{ poster_image | image_url: width: 714 }}"
                        aria-hidden="true"
                      >
                        {%- for source in local_video.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- endif -%}

                    {%- if has_external -%}
                      <span class="q-et__play-btn" aria-hidden="true">
                        <span class="q-et__play-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="103" height="103" viewBox="0 0 103 103" fill="none">
                            <path d="M100.878 26.7747C99.6905 22.3623 96.2116 18.8842 91.8 17.696C83.7398 15.4902 51.499 15.4902 51.499 15.4902C51.499 15.4902 19.259 15.4902 11.1988 17.612C6.87203 18.7993 3.30832 22.3631 2.12094 26.7747C0 34.8341 0 51.5486 0 51.5486C0 51.5486 0 68.3471 2.12094 76.3225C3.30911 80.7341 6.78717 84.2129 11.1996 85.4011C19.3439 87.6069 51.4998 87.6069 51.4998 87.6069C51.4998 87.6069 83.7398 87.6069 91.8 85.4852C96.2124 84.2978 99.6905 80.819 100.879 76.4073C103 68.3471 103 51.6334 103 51.6334C103 51.6334 103 34.8341 100.878 26.7747Z" fill="#FF0000"/>
                            <path d="M41.2338 66.9903L68.0437 51.5489L41.2338 36.1074V66.9903Z" fill="white"/>
                          </svg>
                        </span>
                      </span>
                    {%- endif -%}
                  </div>
                </div>

                <div class="q-et__content-col">

                  {%- if pill_items.size > 0 -%}
                    <ul class="q-et__pills" role="list">
                      {%- for pill in pill_items -%}
                        {%- if pill != blank -%}
                          <li class="q-et__pill">{{ pill }}</li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- if block.settings.quote != blank -%}
                    <div class="q-et__quote-wrap">
                      <svg class="q-et__quote-icon" xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 50 50" fill="none">
                        <path d="M37.258 25.9732H42.5915V39.5117H26.25V30.2402C26.25 20.8282 32.817 12.6742 42.023 10.7152C42.8475 10.5397 43.343 10.4887 43.343 10.4887L45 14.5257C37.6795 18.1757 37.258 25.9732 37.258 25.9732Z" fill="#ADC9E3"/>
                        <path d="M16.01 25.9732H21.3435V39.5117H5V30.2402C5 20.8282 11.5675 12.6742 20.7735 10.7152C21.598 10.5397 22.093 10.4887 22.093 10.4887L23.75 14.5257C16.432 18.1757 16.01 25.9732 16.01 25.9732Z" fill="#ADC9E3"/>
                      </svg>
                      <div class="q-et__quote-text">{{ block.settings.quote }}</div>
                    </div>
                  {%- endif -%}

                  {%- if block.settings.expert_name != blank or block.settings.expert_avatar != blank -%}
                    <div class="q-et__expert">
                      {%- if block.settings.expert_avatar != blank -%}
                        {{- block.settings.expert_avatar | image_url: width: 134 | image_tag:
                          class: 'q-et__avatar',
                          loading: 'lazy',
                          sizes: '67px',
                          widths: '44, 67, 88, 134',
                          alt: block.settings.expert_name
                        -}}
                      {%- endif -%}
                      <div class="q-et__expert-info">
                        {%- if block.settings.expert_name != blank -%}
                          <div class="q-et__expert-name-row">
                            <p class="q-et__expert-name">{{ block.settings.expert_name }}</p>
                            {%- if block.settings.show_verified_badge -%}
                              <svg class="q-et__expert-badge" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-label="{{ 'sections.expert_testimonials.verified' | t | default: 'Verified' }}">
