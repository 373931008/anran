    "q-faq": {
      "type": "q-faq",
      "blocks": {
        "tab-security": {
          "type": "tab",
          "settings": {
            "tab_label": "Security Camera"
          }
        },
        "tab-shipping": {
          "type": "tab",
          "settings": {
            "tab_label": "Shipping & Returns"
          }
        },
        "item-1": {
          "type": "item",
          "settings": {
            "question": "Does the camera come with an SD card?",
            "answer": "<p>Only the G1 model includes a built-in SD card in the package. Other camera models do NOT come with an SD card. You will need to purchase one separately.</p>",
            "tab_index": "1"
          }
        },
        "item-2": {
          "type": "item",
          "settings": {
            "question": "What format of SD card does the camera support?",
            "answer": "<p>The camera supports microSD cards up to 128GB in FAT32 or exFAT format.</p>",
            "tab_index": "1"
          }
        },
        "item-3": {
          "type": "item",
          "settings": {
            "question": "Do you have to have Alexa for this?",
            "answer": "<p>No, Alexa is not required. The camera works independently via the mobile app. Alexa integration is optional for voice control.</p>",
            "tab_index": "1"
          }
        },
        "item-4": {
          "type": "item",
          "settings": {
            "question": "What is the viewing angle and What range of coverage is it?",
            "answer": "<p>The camera has a 130° wide-angle lens with up to 30 feet of night vision range.</p>",
            "tab_index": "1"
          }
        },
        "item-5": {
          "type": "item",
          "settings": {
            "question": "How long does it take to fully charge a low-power battery camera?",
            "answer": "<p>It takes approximately 4-6 hours to fully charge the battery using the included USB-C cable.</p>",
            "tab_index": "1"
          }
        },
        "item-6": {
          "type": "item",
          "settings": {
            "question": "Will this camera record continuously if I insert an SD card?",
            "answer": "<p>Yes, with a microSD card inserted, the camera supports continuous local recording.</p>",
            "tab_index": "1"
          }
        },
        "item-7": {
          "type": "item",
          "settings": {
            "question": "Why the Solar Panel Might Not Be Charging?",
            "answer": "<p>Ensure the solar panel is placed in direct sunlight for at least 6 hours per day. Clean the panel surface if dirty and check the cable connection.</p>",
            "tab_index": "1"
          }
        },
        "item-8": {
          "type": "item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 5-7 business days. Expedited shipping (2-3 business days) is available at checkout.</p>",
            "tab_index": "2"
          }
        },
        "item-9": {
          "type": "item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day hassle-free return policy. Items must be in their original packaging and unused condition. Contact our support team to initiate a return.</p>",
            "tab_index": "2"
          }
        },
        "item-10": {
          "type": "item",
          "settings": {
            "question": "Do you offer free shipping?",
            "answer": "<p>Yes! Free standard shipping is available on all orders over $50. Orders below $50 have a flat shipping fee of $4.99.</p>",
            "tab_index": "2"
          }
        },
        "item-11": {
          "type": "item",
          "settings": {
            "question": "Can I track my order?",
            "answer": "<p>Absolutely. Once your order ships, you will receive a tracking number via email. You can also track your order through your account dashboard.</p>",
            "tab_index": "2"
          }
        }
      },
