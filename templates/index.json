        "text_Tmigdn": {
          "type": "text",
          "settings": {
            "text": "<h4>ANRAN delivers smart, wireless security solutions trusted by thousands of families and businesses worldwide. Our <a href=\"https://anran-cctv.com/products/anran-q3-4k-8mp-solar-battery-camera\">solar security cameras</a> and <a href=\"https://anran-cctv.com/products/anran-5mp-wifi-ptz-kit-4ch-nvr-2tb-hdd\">Wireless security CCTV systems</a> are easy to install, weatherproof, and designed for 24/7 protection — even in places without power or Wi-Fi. Whether you need a 4G <a href=\"https://anran-cctv.com/collections/all-product\">security camera</a> for remote areas, a smart <a href=\"https://anran-cctv.com/products/anran-5mp-wifi-ptz-kit-4ch-nvr-2tb-hdd\">home surveillance system</a>   for your front door, or a complete outdoor wireless CCTV setup, ANRAN has you covered.</h4>"
          }
