{
  "name": "shopify-vite-theme-template",
  "version": "1.0.0",
  "description": "Shopify主题开发模板 - 基于Vite + TailwindCSS + Island架构",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm start",
    "start": "concurrently --kill-others --passthrough-arguments \"pnpm run shopify:dev {@}\" \"pnpm run vite:dev\" --",
    "build": "vite build",
    "deploy": "pnpm run build && pnpm run shopify:deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "vite:dev": "vite",
    "shopify:dev": "shopify theme dev",
    "shopify:deploy": "shopify theme push",
    "shopify:check": "shopify theme check",
    "clean": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {}\""
  },
  "keywords": [
    "shopify",
    "vite",
    "tailwindcss",
    "theme",
    "ecommerce"
  ],
  "author": "Shopi8 Team",
  "license": "MIT",
  "devDependencies": {
    "@by-association-only/vite-plugin-shopify-clean": "^2.0.0",
    "@shopify/prettier-plugin-liquid": "^1.5.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^6.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "postcss": "^8.4.40",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.1.6",
    "vite": "^5.3.5",
    "vite-plugin-shopify": "^3.0.1"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@web-tracing/core": "^2.0.6",
    "lucky-canvas": "^1.7.27",
    "motion": "^12.4.2",
    "swiper": "^11.1.9",
    "tailwind-merge": "^2.5.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{liquid}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
