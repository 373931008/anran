      "type": "select",
      "id": "discount_font_weight",
      "label": "折扣字体粗细",
      "options": [
        { "value": "400", "label": "正常" },
        { "value": "500", "label": "中等" },
        { "value": "600", "label": "半粗" },
        { "value": "700", "label": "粗体" }
