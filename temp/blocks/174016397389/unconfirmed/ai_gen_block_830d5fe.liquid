    {
      "type": "image_picker",
      "id": "feature_icon",
      "label": "卖点图标"
    },
    {
      "type": "header",
      "content": "按钮设置"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字",
      "default": "立即购买"
    },
    {
      "type": "range",
      "id": "button_width",
