{% doc %}
  @prompt
    生成一个Product list, 促销设置
    产品图片（image picker）
    
    标题（text）
    
    评分（number）
    
    评论数（number）
    
    卖点1/卖点2（text）
    
    当前价格 / 原价（text）
    
    折扣（自动计算或手动）
    
    按钮链接（url）, 所有的内容靠左对齐，产品卖点再增加一条，另外可以设置上传卖点前面的icon图标，价格可以单独设置原价和优惠价还有折扣的字体大小，, 我需要做成可以设置一行做4个或者3个或者2个或者1个，购买的按钮我可以设置可以控制长宽。, 产品选择只要4个就够了，产品1，产品2，产品3，产品4；产品图标的图片选择功能可以删除；字体大小中需要增加产品卖点的字体大小调整；整个模块的布局宽度需要可以设置，以及两侧以及上下留白的大小设置, 我需要在颜色设置中可以设置整个模块的底色。我需要在字体大小中设置字体粗细。另外需要在价格前显示货币符号, 货币显示不需要我设置，直接按系统默认的可以吗, 产品图片和卡片上方，左右两个不需要留白, 我需要所有卡片 等高（equal height）
    
    底部元素（价格 + 按钮）底对齐（bottom aligned）
    
    中间内容用留白撑开（flexible spacing）, 在图片内部加一个内链，客户可以直接点击图片进入产品, 我需要的是可以自行上传图片，然后在点击图片进入产品页面，而不是选择产品。谢谢
    
    一列三个产品就行。
    
    使用中文的编辑器, 调整下，没添加产品不会显示模块
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign has_products = false
  for i in (1..4)
    assign image_key = 'product_' | append: i | append: '_image'
    assign title_key = 'product_' | append: i | append: '_title'
    if block.settings[image_key] != blank or block.settings[title_key] != blank
      assign has_products = true
      break
    endif
  endfor
%}

{% if has_products %}
  {% style %}
    .ai-promo-products-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      background-color: {{ block.settings.module_bg_color }};
      padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    }

    .ai-promo-products-container-{{ ai_gen_id }} {
      max-width: {{ block.settings.module_width }}px;
      margin: 0 auto;
    }

    .ai-promo-products-grid-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap }}px;
    }

    .ai-promo-product-card-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .ai-promo-product-image-wrapper-{{ ai_gen_id }} {
      position: relative;
      width: 100%;
      overflow: hidden;
    }

    .ai-promo-product-image-link-{{ ai_gen_id }} {
      display: block;
      width: 100%;
    }

    .ai-promo-product-image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      display: block;
    }

    .ai-promo-product-image-placeholder-{{ ai_gen_id }} {
      width: 100%;
      aspect-ratio: 1;
      background-color: #f4f4f4;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ai-promo-product-image-placeholder-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      max-width: 200px;
      max-height: 200px;
    }

    .ai-promo-product-content-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      text-align: left;
    }

    .ai-promo-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size }}px;
      font-weight: {{ block.settings.title_font_weight }};
      color: {{ block.settings.title_color }};
      margin: 12px 0 8px 0;
    }

    .ai-promo-product-rating-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .ai-promo-product-stars-{{ ai_gen_id }} {
      display: flex;
      gap: 2px;
    }

    .ai-promo-product-star-{{ ai_gen_id }} {
      width: 16px;
      height: 16px;
      fill: {{ block.settings.star_color }};
    }

    .ai-promo-product-star-empty-{{ ai_gen_id }} {
      fill: #e0e0e0;
    }

    .ai-promo-product-reviews-{{ ai_gen_id }} {
      font-size: {{ block.settings.reviews_font_size }}px;
      font-weight: {{ block.settings.reviews_font_weight }};
      color: {{ block.settings.reviews_color }};
    }

    .ai-promo-product-features-{{ ai_gen_id }} {
      margin: 8px 0;
      flex-grow: 1;
    }

    .ai-promo-product-feature-{{ ai_gen_id }} {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 6px;
      font-size: {{ block.settings.features_font_size }}px;
      font-weight: {{ block.settings.features_font_weight }};
      color: {{ block.settings.features_color }};
    }

    .ai-promo-product-feature-icon-{{ ai_gen_id }} {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .ai-promo-product-feature-icon-{{ ai_gen_id }} img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .ai-promo-product-bottom-{{ ai_gen_id }} {
      margin-top: auto;
      padding-top: 12px;
    }

    .ai-promo-product-price-wrapper-{{ ai_gen_id }} {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 12px;
    }

    .ai-promo-product-current-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.current_price_font_size }}px;
      font-weight: {{ block.settings.current_price_font_weight }};
      color: {{ block.settings.current_price_color }};
    }

    .ai-promo-product-original-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.original_price_font_size }}px;
      font-weight: {{ block.settings.original_price_font_weight }};
      color: {{ block.settings.original_price_color }};
      text-decoration: line-through;
    }

    .ai-promo-product-discount-{{ ai_gen_id }} {
      font-size: {{ block.settings.discount_font_size }}px;
      font-weight: {{ block.settings.discount_font_weight }};
      color: {{ block.settings.discount_color }};
      background-color: {{ block.settings.discount_bg_color }};
      padding: 2px 8px;
      border-radius: 4px;
    }

    .ai-promo-product-button-{{ ai_gen_id }} {
      display: inline-block;
      width: {{ block.settings.button_width }}px;
      height: {{ block.settings.button_height }}px;
      line-height: {{ block.settings.button_height }}px;
      text-align: center;
      background-color: {{ block.settings.button_bg_color }};
      color: {{ block.settings.button_text_color }};
      text-decoration: none;
      border-radius: {{ block.settings.button_border_radius }}px;
      font-size: {{ block.settings.button_font_size }}px;
      font-weight: {{ block.settings.button_font_weight }};
      transition: background-color 0.3s ease;
    }

    .ai-promo-product-button-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.button_hover_bg_color }};
    }

    @media screen and (max-width: 749px) {
      .ai-promo-products-grid-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
      }
    }
  {% endstyle %}

  <div class="ai-promo-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-promo-products-container-{{ ai_gen_id }}">
      <div class="ai-promo-products-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign image_key = 'product_' | append: i | append: '_image'
            assign title_key = 'product_' | append: i | append: '_title'
            assign rating_key = 'product_' | append: i | append: '_rating'
            assign reviews_key = 'product_' | append: i | append: '_reviews'
            assign feature1_key = 'product_' | append: i | append: '_feature1'
            assign feature2_key = 'product_' | append: i | append: '_feature2'
            assign feature3_key = 'product_' | append: i | append: '_feature3'
            assign current_price_key = 'product_' | append: i | append: '_current_price'
            assign original_price_key = 'product_' | append: i | append: '_original_price'
            assign discount_key = 'product_' | append: i | append: '_discount'
            assign link_key = 'product_' | append: i | append: '_link'

            assign product_image = block.settings[image_key]
            assign product_title = block.settings[title_key]
            assign product_rating = block.settings[rating_key]
            assign product_reviews = block.settings[reviews_key]
            assign product_feature1 = block.settings[feature1_key]
            assign product_feature2 = block.settings[feature2_key]
            assign product_feature3 = block.settings[feature3_key]
            assign product_current_price = block.settings[current_price_key]
            assign product_original_price = block.settings[original_price_key]
            assign product_discount = block.settings[discount_key]
            assign product_link = block.settings[link_key]
          %}

          {% if product_image != blank or product_title != blank %}
            <div class="ai-promo-product-card-{{ ai_gen_id }}">
              <div class="ai-promo-product-image-wrapper-{{ ai_gen_id }}">
                {% if product_link != blank %}
                  <a href="{{ product_link }}" class="ai-promo-product-image-link-{{ ai_gen_id }}">
                {% endif %}
                  {% if product_image %}
                    <img
                      src="{{ product_image | image_url: width: 800 }}"
                      alt="{{ product_title | escape }}"
                      class="ai-promo-product-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="800"
                    >
                  {% else %}
                    <div class="ai-promo-product-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                {% if product_link != blank %}
                  </a>
                {% endif %}
              </div>

              <div class="ai-promo-product-content-{{ ai_gen_id }}">
                {% if product_title != blank %}
                  <h3 class="ai-promo-product-title-{{ ai_gen_id }}">{{ product_title }}</h3>
                {% endif %}

                {% if product_rating > 0 %}
                  <div class="ai-promo-product-rating-{{ ai_gen_id }}">
                    <div class="ai-promo-product-stars-{{ ai_gen_id }}">
                      {% for star in (1..5) %}
                        {% if star <= product_rating %}
                          <svg class="ai-promo-product-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% else %}
                          <svg class="ai-promo-product-star-{{ ai_gen_id }} ai-promo-product-star-empty-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% endif %}
                      {% endfor %}
                    </div>
                    {% if product_reviews > 0 %}
                      <span class="ai-promo-product-reviews-{{ ai_gen_id }}">({{ product_reviews }})</span>
                    {% endif %}
                  </div>
                {% endif %}

                <div class="ai-promo-product-features-{{ ai_gen_id }}">
                  {% if product_feature1 != blank %}
                    <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                      {% if block.settings.feature_icon %}
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <img src="{{ block.settings.feature_icon | image_url: width: 32 }}" alt="">
                        </div>
                      {% endif %}
                      <span>{{ product_feature1 }}</span>
                    </div>
                  {% endif %}

                  {% if product_feature2 != blank %}
                    <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                      {% if block.settings.feature_icon %}
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <img src="{{ block.settings.feature_icon | image_url: width: 32 }}" alt="">
                        </div>
                      {% endif %}
                      <span>{{ product_feature2 }}</span>
                    </div>
                  {% endif %}

                  {% if product_feature3 != blank %}
                    <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                      {% if block.settings.feature_icon %}
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <img src="{{ block.settings.feature_icon | image_url: width: 32 }}" alt="">
                        </div>
                      {% endif %}
                      <span>{{ product_feature3 }}</span>
                    </div>
                  {% endif %}
                </div>

                <div class="ai-promo-product-bottom-{{ ai_gen_id }}">
                  {% if product_current_price != blank or product_original_price != blank %}
                    <div class="ai-promo-product-price-wrapper-{{ ai_gen_id }}">
                      {% if product_current_price != blank %}
                        <span class="ai-promo-product-current-price-{{ ai_gen_id }}">{{ cart.currency.symbol }}{{ product_current_price }}</span>
                      {% endif %}
                      {% if product_original_price != blank %}
                        <span class="ai-promo-product-original-price-{{ ai_gen_id }}">{{ cart.currency.symbol }}{{ product_original_price }}</span>
                      {% endif %}
                      {% if product_discount != blank %}
                        <span class="ai-promo-product-discount-{{ ai_gen_id }}">-{{ product_discount }}%</span>
                      {% endif %}
                    </div>
                  {% endif %}

                  {% if product_link != blank %}
                    <a href="{{ product_link }}" class="ai-promo-product-button-{{ ai_gen_id }}">
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "促销产品列表",
  "settings": [
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "module_width",
      "label": "模块宽度",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "左右留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上方留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下方留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "每行产品数量",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "产品间距",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "module_bg_color",
      "label": "模块背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
