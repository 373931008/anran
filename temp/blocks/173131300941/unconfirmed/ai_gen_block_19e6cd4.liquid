{% doc %}
  @prompt
    生成一个产品规格的列表，一开始显示10个，下方有查看更多的按钮，点击后直接显示剩下的, 不用一个一个填，我只要一个富文本设置就好，另外下文本下方有一个查看更多的按钮，点击后直接显示更多内容。另外模块宽度用px的单位来设置，另外我需要可以设置标题居中还是左边或者右边
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spec-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-spec-list__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-spec-list__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-spec-list__content-{{ ai_gen_id }} ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-spec-list__content-{{ ai_gen_id }} li {
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-spec-list__content-{{ ai_gen_id }} li:last-child {
    border-bottom: none;
  }

  .ai-spec-list__content-{{ ai_gen_id }} p {
    margin: 0;
    padding: {{ block.settings.item_padding }}px 0;
  }

  .ai-spec-list__hidden-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .ai-spec-list__hidden-content-{{ ai_gen_id }}.ai-spec-list__hidden-content--expanded-{{ ai_gen_id }} {
    max-height: 2000px;
  }

  .ai-spec-list__button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-spec-list__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-spec-list__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-spec-list__icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-spec-list__icon-{{ ai_gen_id }}.ai-spec-list__icon--rotated-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  @media screen and (max-width: 749px) {
    .ai-spec-list-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<product-spec-list-{{ ai_gen_id }} class="ai-spec-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h3 class="ai-spec-list__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  {% if block.settings.visible_content != blank %}
    <div class="ai-spec-list__content-{{ ai_gen_id }}">
      {{ block.settings.visible_content }}
    </div>
  {% endif %}

  {% if block.settings.hidden_content != blank %}
    <div class="ai-spec-list__hidden-content-{{ ai_gen_id }}" data-hidden-content>
      <div class="ai-spec-list__content-{{ ai_gen_id }}">
        {{ block.settings.hidden_content }}
      </div>
    </div>

    <div class="ai-spec-list__button-wrapper-{{ ai_gen_id }}">
      <button 
        class="ai-spec-list__button-{{ ai_gen_id }}"
        data-toggle-button
        aria-expanded="false"
      >
        <span data-button-text>{{ block.settings.show_more_text }}</span>
        <svg class="ai-spec-list__icon-{{ ai_gen_id }}" data-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</product-spec-list-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSpecList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('[data-toggle-button]');
        this.buttonText = this.querySelector('[data-button-text]');
        this.icon = this.querySelector('[data-icon]');
        this.hiddenContent = this.querySelector('[data-hidden-content]');
        this.showMoreText = '{{ block.settings.show_more_text }}';
        this.showLessText = '{{ block.settings.show_less_text }}';
        this.isExpanded = false;

        if (!this.button) return;

        this.button.addEventListener('click', () => this.toggleContent());
      }

      toggleContent() {
        this.isExpanded = !this.isExpanded;

        if (this.isExpanded) {
          this.hiddenContent.classList.add('ai-spec-list__hidden-content--expanded-{{ ai_gen_id }}');
        } else {
          this.hiddenContent.classList.remove('ai-spec-list__hidden-content--expanded-{{ ai_gen_id }}');
        }

        this.buttonText.textContent = this.isExpanded ? this.showLessText : this.showMoreText;
        this.icon.classList.toggle('ai-spec-list__icon--rotated-{{ ai_gen_id }}', this.isExpanded);
        this.button.setAttribute('aria-expanded', this.isExpanded);
      }
    }

    customElements.define('product-spec-list-{{ ai_gen_id }}', ProductSpecList{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "产品规格列表",
  "settings": [
    {
      "type": "header",
      "content": "标题"
    },
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "产品规格"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "标题对齐",
      "options": [
        {
          "value": "left",
          "label": "左对齐"
        },
        {
          "value": "center",
          "label": "居中"
        },
        {
          "value": "right",
          "label": "右对齐"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "标题大小",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "标题颜色",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "内容"
    },
    {
      "type": "richtext",
      "id": "visible_content",
      "label": "初始显示内容",
      "default": "<ul><li>分辨率：1080P</li><li>视角：110°</li><li>夜视距离：10米</li><li>防水等级：IP66</li><li>电池容量：10400mAh</li><li>太阳能板：5W</li><li>存储：最大128GB</li><li>连接方式：WiFi 2.4GHz</li><li>工作温度：-20°C ~ 50°C</li><li>尺寸：150 x 80 x 70mm</li></ul>"
    },
    {
      "type": "richtext",
      "id": "hidden_content",
      "label": "隐藏内容（点击查看更多后显示）",
      "default": "<ul><li>重量：500g</li><li>镜头：4mm</li><li>音频：双向对讲</li><li>移动侦测：支持</li><li>云存储：支持</li></ul>"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "文字大小",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字颜色",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "项目内边距",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "分隔线颜色",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "按钮"
    },
    {
      "type": "text",
      "id": "show_more_text",
      "label": "显示更多文本",
      "default": "查看更多"
    },
    {
      "type": "text",
      "id": "show_less_text",
      "label": "收起文本",
      "default": "收起"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "按钮对齐",
      "options": [
        {
          "value": "left",
          "label": "左对齐"
        },
        {
          "value": "center",
          "label": "居中"
        },
        {
          "value": "right",
          "label": "右对齐"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "按钮文字大小",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "按钮内边距",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "按钮圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "按钮背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "按钮文字颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "按钮边框颜色",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "按钮悬停背景色",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "按钮悬停文字颜色",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "样式"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "最大宽度",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding",
      "label": "内边距",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "间距",
      "min": 12,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "圆角",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "产品规格列表"
    }
  ]
}
{% endschema %}
