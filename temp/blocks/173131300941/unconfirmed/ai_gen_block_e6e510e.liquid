{% doc %}
  @prompt
    生成一个产品规格的列表，一开始显示10个，下方有查看更多的按钮，点击后直接显示剩下的
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spec-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-spec-list__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-spec-list__items-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-spec-list__item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    gap: 20px;
  }

  .ai-spec-list__item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-spec-list__item-{{ ai_gen_id }}.ai-spec-list__item--hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-spec-list__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 500;
    flex-shrink: 0;
    max-width: 50%;
  }

  .ai-spec-list__value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.value_color }};
    text-align: right;
    flex-grow: 1;
  }

  .ai-spec-list__button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-spec-list__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-spec-list__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-spec-list__button-{{ ai_gen_id }}.ai-spec-list__button--hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-spec-list__icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-spec-list__icon-{{ ai_gen_id }}.ai-spec-list__icon--rotated-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  @media screen and (max-width: 749px) {
    .ai-spec-list__label-{{ ai_gen_id }},
    .ai-spec-list__value-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-spec-list-{{ ai_gen_id }} class="ai-spec-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h3 class="ai-spec-list__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  <ul class="ai-spec-list__items-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% assign label_key = 'spec_' | append: i | append: '_label' %}
      {% assign value_key = 'spec_' | append: i | append: '_value' %}
      {% assign label = block.settings[label_key] %}
      {% assign value = block.settings[value_key] %}

      {% if label != blank and value != blank %}
        <li 
          class="ai-spec-list__item-{{ ai_gen_id }} {% if i > block.settings.initial_visible_count %}ai-spec-list__item--hidden-{{ ai_gen_id }}{% endif %}"
          data-spec-item
        >
          <span class="ai-spec-list__label-{{ ai_gen_id }}">{{ label }}</span>
          <span class="ai-spec-list__value-{{ ai_gen_id }}">{{ value }}</span>
        </li>
      {% endif %}
    {% endfor %}
  </ul>

  <div class="ai-spec-list__button-wrapper-{{ ai_gen_id }}">
    <button 
      class="ai-spec-list__button-{{ ai_gen_id }}"
      data-toggle-button
      aria-expanded="false"
    >
      <span data-button-text>{{ block.settings.show_more_text }}</span>
      <svg class="ai-spec-list__icon-{{ ai_gen_id }}" data-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
  </div>
</product-spec-list-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSpecList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('[data-toggle-button]');
        this.buttonText = this.querySelector('[data-button-text]');
        this.icon = this.querySelector('[data-icon]');
        this.hiddenItems = this.querySelectorAll('.ai-spec-list__item--hidden-{{ ai_gen_id }}');
        this.showMoreText = '{{ block.settings.show_more_text }}';
        this.showLessText = '{{ block.settings.show_less_text }}';
        this.isExpanded = false;

        if (this.hiddenItems.length === 0) {
          this.button.classList.add('ai-spec-list__button--hidden-{{ ai_gen_id }}');
        }

        this.button.addEventListener('click', () => this.toggleSpecs());
      }

      toggleSpecs() {
        this.isExpanded = !this.isExpanded;

        this.hiddenItems.forEach((item) => {
          if (this.isExpanded) {
            item.classList.remove('ai-spec-list__item--hidden-{{ ai_gen_id }}');
          } else {
            item.classList.add('ai-spec-list__item--hidden-{{ ai_gen_id }}');
          }
        });

        this.buttonText.textContent = this.isExpanded ? this.showLessText : this.showMoreText;
        this.icon.classList.toggle('ai-spec-list__icon--rotated-{{ ai_gen_id }}', this.isExpanded);
        this.button.setAttribute('aria-expanded', this.isExpanded);
      }
    }

    customElements.define('product-spec-list-{{ ai_gen_id }}', ProductSpecList{{ ai_gen_id }});
  })();
</script>

