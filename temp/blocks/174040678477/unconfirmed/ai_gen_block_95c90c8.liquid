<script>
  (function() {
    class ShopByCategory{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-shop-category-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-shop-category-content-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const categoryId = tab.getAttribute('data-category');
            this.switchCategory(categoryId);
          });
        });
      }

      switchCategory(categoryId) {
        this.tabs.forEach((tab) => {
          if (tab.getAttribute('data-category') === categoryId) {
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');
          } else {
            tab.classList.remove('active');
            tab.setAttribute('aria-selected', 'false');
          }
        });

        this.contents.forEach((content) => {
          if (content.getAttribute('data-content') === categoryId) {
            content.classList.add('active');
          } else {
            content.classList.remove('active');
          }
        });
      }
    }

    customElements.define('shop-by-category-{{ ai_gen_id }}', ShopByCategory{{ ai_gen_id }});
  })();
</script>

