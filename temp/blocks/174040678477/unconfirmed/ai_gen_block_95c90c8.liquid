        <div class="ai-shop-category-image-wrapper-{{ ai_gen_id }} large">
          {% if block.settings.cat1_large_link != blank %}
            <a href="{{ block.settings.cat1_large_link }}" class="ai-shop-category-image-link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-shop-category-image-link-{{ ai_gen_id }}">
          {% endif %}
            {% if block.settings.cat1_large_image %}
              <img
                src="{{ block.settings.cat1_large_image | image_url: width: 1200 }}"
                alt="{{ block.settings.cat1_large_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.cat1_large_image.width }}"
                height="{{ block.settings.cat1_large_image.height }}"
              >
            {% else %}
              <div class="ai-shop-category-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            {% if block.settings.show_content %}
              <div class="ai-shop-category-image-content-{{ ai_gen_id }}">
                {% if block.settings.cat1_large_title != blank %}
                  <h3 class="ai-shop-category-image-title-{{ ai_gen_id }}">{{ block.settings.cat1_large_title }}</h3>
                {% endif %}
                {% if block.settings.cat1_large_desc != blank %}
                  <p class="ai-shop-category-image-desc-{{ ai_gen_id }}">{{ block.settings.cat1_large_desc }}</p>
                {% endif %}
                {% if block.settings.cat1_large_button != blank %}
                  <span class="ai-shop-category-image-button-{{ ai_gen_id }}">{{ block.settings.cat1_large_button }}</span>
                {% endif %}
              </div>
            {% endif %}
          {% if block.settings.cat1_large_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>

        <div class="ai-shop-category-small-images-{{ ai_gen_id }}">
          <div class="ai-shop-category-image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.cat1_top_link != blank %}
              <a href="{{ block.settings.cat1_top_link }}" class="ai-shop-category-image-link-{{ ai_gen_id }}">
            {% else %}
