{% doc %}
  @prompt
    布局要求：
    左侧一张大图，右侧两张图片（上下排列），左右宽度比例为 942:464，整体对齐整齐，有间距。
    
    功能要求：
    - 每张图片都可以设置点击链接（整张图可点击）
    - 图片上可以添加内容：
      - 标题
      - 描述
      - 按钮（如“Shop Now”）
      - 按钮链接
    - 内容显示在图片内部（支持居中或左下角）
    
    响应式要求：
    - PC端保持当前布局
    - 移动端改为上下排列（3张图竖排）
    
    性能要求（重点）：
    - 代码结构尽量简洁，避免冗余
    - 不引入额外JS或第三方库
    - 优化图片加载（使用懒加载等）
    - 避免布局偏移（CLS问题）
    - 不影响页面加载速度
    
    技术要求：
    - 使用 Liquid + HTML + CSS
    - 兼容 Dawn 主题
    - 不影响原主题样式
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-split-gallery__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 942fr 464fr;
    gap: {{ block.settings.gap }}px;
  }

  .ai-split-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-split-gallery__item-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ai-split-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-split-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-split-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-split-gallery__content-{{ ai_gen_id }} {
    position: absolute;
    {% if block.settings.content_position == 'center' %}
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    {% else %}
      bottom: {{ block.settings.content_padding }}px;
      left: {{ block.settings.content_padding }}px;
      text-align: left;
    {% endif %}
    z-index: 2;
    max-width: calc(100% - {{ block.settings.content_padding | times: 2 }}px);
  }

  .ai-split-gallery__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 1;
  }

  .ai-split-gallery__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .ai-split-gallery__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 16px;
  }

  .ai-split-gallery__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    transition: background-color 0.3s ease;
  }

  .ai-split-gallery__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-split-gallery__right-{{ ai_gen_id }} {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-split-gallery__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap }}px;
    }

    .ai-split-gallery__right-{{ ai_gen_id }} {
      grid-template-rows: auto auto;
    }

    .ai-split-gallery__content-{{ ai_gen_id }} {
      {% if block.settings.content_position == 'center' %}
        max-width: 90%;
      {% else %}
        max-width: calc(100% - 32px);
        bottom: 16px;
        left: 16px;
      {% endif %}
    }

    .ai-split-gallery__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-split-gallery__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-split-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-gallery__container-{{ ai_gen_id }}">
    <div class="ai-split-gallery__item-{{ ai_gen_id }}">
      {% if block.settings.image_1_link != blank %}
        <a href="{{ block.settings.image_1_link }}" class="ai-split-gallery__item-link-{{ ai_gen_id }}">
      {% else %}
        <div class="ai-split-gallery__item-link-{{ ai_gen_id }}">
      {% endif %}
        <div class="ai-split-gallery__image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image_1 %}
            <img
              src="{{ block.settings.image_1 | image_url: width: 1200 }}"
              srcset="{{ block.settings.image_1 | image_url: width: 600 }} 600w,
                      {{ block.settings.image_1 | image_url: width: 900 }} 900w,
                      {{ block.settings.image_1 | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 749px) 100vw, 67vw"
              alt="{{ block.settings.image_1.alt | escape }}"
              class="ai-split-gallery__image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.image_1.width }}"
              height="{{ block.settings.image_1.height }}"
            >
          {% else %}
            <div class="ai-split-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if block.settings.overlay_opacity > 0 %}
            <div class="ai-split-gallery__overlay-{{ ai_gen_id }}"></div>
          {% endif %}
          {% if block.settings.image_1_title != blank or block.settings.image_1_description != blank or block.settings.image_1_button_text != blank %}
            <div class="ai-split-gallery__content-{{ ai_gen_id }}">
              {% if block.settings.image_1_title != blank %}
                <h3 class="ai-split-gallery__title-{{ ai_gen_id }}">{{ block.settings.image_1_title }}</h3>
              {% endif %}
              {% if block.settings.image_1_description != blank %}
                <p class="ai-split-gallery__description-{{ ai_gen_id }}">{{ block.settings.image_1_description }}</p>
              {% endif %}
              {% if block.settings.image_1_button_text != blank and block.settings.image_1_button_link != blank %}
                <span class="ai-split-gallery__button-{{ ai_gen_id }}">{{ block.settings.image_1_button_text }}</span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% if block.settings.image_1_link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    </div>

    <div class="ai-split-gallery__right-{{ ai_gen_id }}">
      <div class="ai-split-gallery__item-{{ ai_gen_id }}">
        {% if block.settings.image_2_link != blank %}
          <a href="{{ block.settings.image_2_link }}" class="ai-split-gallery__item-link-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-split-gallery__item-link-{{ ai_gen_id }}">
        {% endif %}
          <div class="ai-split-gallery__image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.image_2 %}
              <img
                src="{{ block.settings.image_2 | image_url: width: 600 }}"
                srcset="{{ block.settings.image_2 | image_url: width: 400 }} 400w,
                        {{ block.settings.image_2 | image_url: width: 600 }} 600w"
                sizes="(max-width: 749px) 100vw, 33vw"
                alt="{{ block.settings.image_2.alt | escape }}"
                class="ai-split-gallery__image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
              >
            {% else %}
              <div class="ai-split-gallery__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            {% if block.settings.overlay_opacity > 0 %}
              <div class="ai-split-gallery__overlay-{{ ai_gen_id }}"></div>
            {% endif %}
            {% if block.settings.image_2_title != blank or block.settings.image_2_description != blank or block.settings.image_2_button_text != blank %}
              <div class="ai-split-gallery__content-{{ ai_gen_id }}">
                {% if block.settings.image_2_title != blank %}
                  <h3 class="ai-split-gallery__title-{{ ai_gen_id }}">{{ block.settings.image_2_title }}</h3>
                {% endif %}
                {% if block.settings.image_2_description != blank %}
                  <p class="ai-split-gallery__description-{{ ai_gen_id }}">{{ block.settings.image_2_description }}</p>
                {% endif %}
                {% if block.settings.image_2_button_text != blank and block.settings.image_2_button_link != blank %}
                  <span class="ai-split-gallery__button-{{ ai_gen_id }}">{{ block.settings.image_2_button_text }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% if block.settings.image_2_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>

      <div class="ai-split-gallery__item-{{ ai_gen_id }}">
        {% if block.settings.image_3_link != blank %}
          <a href="{{ block.settings.image_3_link }}" class="ai-split-gallery__item-link-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-split-gallery__item-link-{{ ai_gen_id }}">
        {% endif %}
          <div class="ai-split-gallery__image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.image_3 %}
              <img
                src="{{ block.settings.image_3 | image_url: width: 600 }}"
                srcset="{{ block.settings.image_3 | image_url: width: 400 }} 400w,
                        {{ block.settings.image_3 | image_url: width: 600 }} 600w"
                sizes="(max-width: 749px) 100vw, 33vw"
                alt="{{ block.settings.image_3.alt | escape }}"
                class="ai-split-gallery__image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ block.settings.image_3.width }}"
                height="{{ block.settings.image_3.height }}"
              >
            {% else %}
              <div class="ai-split-gallery__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            {% if block.settings.overlay_opacity > 0 %}
              <div class="ai-split-gallery__overlay-{{ ai_gen_id }}"></div>
            {% endif %}
            {% if block.settings.image_3_title != blank or block.settings.image_3_description != blank or block.settings.image_3_button_text != blank %}
              <div class="ai-split-gallery__content-{{ ai_gen_id }}">
                {% if block.settings.image_3_title != blank %}
                  <h3 class="ai-split-gallery__title-{{ ai_gen_id }}">{{ block.settings.image_3_title }}</h3>
                {% endif %}
                {% if block.settings.image_3_description != blank %}
                  <p class="ai-split-gallery__description-{{ ai_gen_id }}">{{ block.settings.image_3_description }}</p>
                {% endif %}
                {% if block.settings.image_3_button_text != blank and block.settings.image_3_button_link != blank %}
                  <span class="ai-split-gallery__button-{{ ai_gen_id }}">{{ block.settings.image_3_button_text }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% if block.settings.image_3_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split gallery",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Wide (16:9)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_1_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "image_1_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "image_1_description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "image_1_button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "image_1_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_2_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "image_2_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "image_2_description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "image_2_button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "image_2_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_3_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "image_3_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "image_3_description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "image_3_button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "image_3_button_link",
