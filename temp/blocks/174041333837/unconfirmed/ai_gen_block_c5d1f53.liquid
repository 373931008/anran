      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "module_bg_color",
      "label": "模块背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "标题颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "rating_color",
      "label": "评论数颜色",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "星级颜色",
      "default": "#FFB800"
    },
    {
      "type": "color",
      "id": "feature_color",
      "label": "卖点文字颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "feature_icon_color",
      "label": "卖点图标颜色",
      "default": "#00AA00"
    },
    {
      "type": "color",
      "id": "current_price_color",
      "label": "当前价格颜色",
