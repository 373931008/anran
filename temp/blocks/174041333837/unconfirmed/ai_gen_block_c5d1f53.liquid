{% doc %}
  @prompt
    生成一个Product list, 促销设置
    产品图片（image picker）
    
    标题（text）
    
    评分（number）
    
    评论数（number）
    
    卖点1/卖点2（text）
    
    当前价格 / 原价（text）
    
    折扣（自动计算或手动）
    
    按钮链接（url）, 所有的内容靠左对齐，产品卖点再增加一条，另外可以设置上传卖点前面的icon图标，价格可以单独设置原价和优惠价还有折扣的字体大小，, 我需要做成可以设置一行做4个或者3个或者2个或者1个，购买的按钮我可以设置可以控制长宽。, 产品选择只要4个就够了，产品1，产品2，产品3，产品4；产品图标的图片选择功能可以删除；字体大小中需要增加产品卖点的字体大小调整；整个模块的布局宽度需要可以设置，以及两侧以及上下留白的大小设置, 我需要在颜色设置中可以设置整个模块的底色。我需要在字体大小中设置字体粗细。另外需要在价格前显示货币符号, 货币显示不需要我设置，直接按系统默认的可以吗, 产品图片和卡片上方，左右两个不需要留白, 我需要所有卡片 等高（equal height）
    
    底部元素（价格 + 按钮）底对齐（bottom aligned）
    
    中间内容用留白撑开（flexible spacing）, 在图片内部加一个内链，客户可以直接点击图片进入产品, 我需要的是可以自行上传图片，然后在点击图片进入产品页面，而不是选择产品。谢谢
    
    编辑器使用中文，在卖点文案前面加上√打勾的图标，加上图标颜色调整。
    
    价格不用居中，按钮居中，加上按钮背景颜色，按钮悬停颜色，和按钮文字颜色调整, 调整为我没添加产品跟产品图片不显示模块, 价格使用$符号不要USD，OFF后面不用加百分比符号%.
    
    按钮居中显示
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.module_bg_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-product-list-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.module_width }}px;
    margin: 0 auto;
  }

  .ai-product-list-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_size }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: left;
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
  }

  .ai-product-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-size: {{ block.settings.rating_font_size }}px;
    color: {{ block.settings.rating_color }};
  }

  .ai-product-stars-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
  }

  .ai-product-features-{{ ai_gen_id }} {
    margin-bottom: auto;
    padding-bottom: 16px;
  }

  .ai-product-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 6px;
    font-size: {{ block.settings.feature_font_size }}px;
    font-weight: {{ block.settings.feature_font_weight }};
    color: {{ block.settings.feature_color }};
  }

  .ai-product-feature-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    margin-top: 2px;
  }

  .ai-product-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.feature_icon_color }};
  }

  .ai-product-bottom-{{ ai_gen_id }} {
    margin-top: auto;
  }

  .ai-product-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .ai-product-current-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.current_price_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.current_price_color }};
  }

  .ai-product-original-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.original_price_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
  }

  .ai-product-discount-{{ ai_gen_id }} {
    font-size: {{ block.settings.discount_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.discount_color }};
    background-color: {{ block.settings.discount_bg_color }};
    padding: 2px 8px;
    border-radius: 4px;
  }

  .ai-product-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
  }

  .ai-product-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.button_width }}px;
    height: {{ block.settings.button_height }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease;
  }

  .ai-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-list-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<product-list-{{ ai_gen_id }} class="ai-product-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-list-container-{{ ai_gen_id }}">
    <div class="ai-product-list-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'product_' | append: i | append: '_image'
          assign title_key = 'product_' | append: i | append: '_title'
          assign rating_key = 'product_' | append: i | append: '_rating'
          assign reviews_key = 'product_' | append: i | append: '_reviews'
          assign feature1_key = 'product_' | append: i | append: '_feature1'
          assign feature2_key = 'product_' | append: i | append: '_feature2'
          assign feature3_key = 'product_' | append: i | append: '_feature3'
          assign current_price_key = 'product_' | append: i | append: '_current_price'
          assign original_price_key = 'product_' | append: i | append: '_original_price'
          assign discount_key = 'product_' | append: i | append: '_discount'
          assign link_key = 'product_' | append: i | append: '_link'

          assign product_image = block.settings[image_key]
          assign product_title = block.settings[title_key]
          assign product_rating = block.settings[rating_key]
          assign product_reviews = block.settings[reviews_key]
          assign product_feature1 = block.settings[feature1_key]
          assign product_feature2 = block.settings[feature2_key]
          assign product_feature3 = block.settings[feature3_key]
          assign product_current_price = block.settings[current_price_key]
          assign product_original_price = block.settings[original_price_key]
          assign product_discount = block.settings[discount_key]
          assign product_link = block.settings[link_key]

          assign has_content = false
          if product_image != blank or product_title != blank or product_current_price != blank
            assign has_content = true
          endif
        %}

        {% if has_content %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            {% if product_image != blank %}
              <a href="{{ product_link }}" class="ai-product-image-wrapper-{{ ai_gen_id }}">
                <img
                  src="{{ product_image | image_url: width: 800 }}"
                  alt="{{ product_title | escape }}"
                  loading="lazy"
                  class="ai-product-image-{{ ai_gen_id }}"
                >
              </a>
            {% endif %}

            <div class="ai-product-content-{{ ai_gen_id }}">
              {% if product_title != blank %}
                <h3 class="ai-product-title-{{ ai_gen_id }}">{{ product_title }}</h3>
              {% endif %}

              {% if product_rating > 0 %}
                <div class="ai-product-rating-{{ ai_gen_id }}">
                  <span class="ai-product-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      {% if star <= product_rating %}★{% else %}☆{% endif %}
                    {% endfor %}
                  </span>
                  {% if product_reviews > 0 %}
                    <span>({{ product_reviews }})</span>
                  {% endif %}
                </div>
              {% endif %}

              <div class="ai-product-features-{{ ai_gen_id }}">
                {% if product_feature1 != blank %}
                  <div class="ai-product-feature-{{ ai_gen_id }}">
                    <span class="ai-product-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    </span>
                    <span>{{ product_feature1 }}</span>
                  </div>
                {% endif %}

                {% if product_feature2 != blank %}
                  <div class="ai-product-feature-{{ ai_gen_id }}">
                    <span class="ai-product-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    </span>
                    <span>{{ product_feature2 }}</span>
                  </div>
                {% endif %}

                {% if product_feature3 != blank %}
                  <div class="ai-product-feature-{{ ai_gen_id }}">
                    <span class="ai-product-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    </span>
                    <span>{{ product_feature3 }}</span>
                  </div>
                {% endif %}
              </div>

              <div class="ai-product-bottom-{{ ai_gen_id }}">
                <div class="ai-product-price-wrapper-{{ ai_gen_id }}">
                  {% if product_current_price != blank %}
                    <span class="ai-product-current-price-{{ ai_gen_id }}">
                      ${{ product_current_price }}
                    </span>
                  {% endif %}

                  {% if product_original_price != blank %}
                    <span class="ai-product-original-price-{{ ai_gen_id }}">
                      ${{ product_original_price }}
                    </span>
                  {% endif %}

                  {% if product_discount != blank %}
                    <span class="ai-product-discount-{{ ai_gen_id }}">
                      {{ product_discount }} OFF
                    </span>
                  {% endif %}
                </div>

                {% if product_link != blank %}
                  <div class="ai-product-button-wrapper-{{ ai_gen_id }}">
                    <a href="{{ product_link }}" class="ai-product-button-{{ ai_gen_id }}">
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</product-list-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-list-{{ ai_gen_id }}', ProductList{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "促销产品列表",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "module_width",
      "label": "模块宽度",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "左右留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上方留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下方留白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "桌面端列数",
      "options": [
        { "value": "1", "label": "1列" },
        { "value": "2", "label": "2列" },
        { "value": "3", "label": "3列" },
        { "value": "4", "label": "4列" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "移动端列数",
