{% doc %}
  @prompt
    https://www.aosulife.com/pages/sales
    你可以根据这个页面的排版。帮忙弄一下吗, 按照这个网页，帮忙把里面所有的排版都弄出来
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sales-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-sales-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-sales-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-sales-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-sales-grid__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-sales-grid__product-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-sales-grid__product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-sales-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-sales-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-sales-grid__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-sales-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-sales-grid__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_radius }}px;
    font-size: 14px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-sales-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-sales-grid__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 12px;
    font-weight: 600;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-sales-grid__product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-sales-grid__product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-sales-grid__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .ai-sales-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-sales-grid__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-sales-grid__discount-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.discount_color }};
    font-weight: 600;
  }

  .ai-sales-grid__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-sales-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-sales-grid__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-sales-grid__empty-state-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-sales-grid__products-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }

    .ai-sales-grid__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-sales-grid__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: 16px;
    }

    .ai-sales-grid__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-sales-grid__content-{{ ai_gen_id }} {
      padding: 16px;
    }
  }
{% endstyle %}

<sales-product-grid-{{ ai_gen_id }} class="ai-sales-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-sales-grid__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-sales-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-sales-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.product_list != blank %}
    <div class="ai-sales-grid__products-{{ ai_gen_id }}">
      {% for product in block.settings.product_list %}
        <div class="ai-sales-grid__product-card-{{ ai_gen_id }}">
          <div class="ai-sales-grid__image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-sales-grid__image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-sales-grid__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if block.settings.show_badge and product.compare_at_price > product.price %}
              {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
              <div class="ai-sales-grid__badge-{{ ai_gen_id }}">
                -{{ discount_percent }}%
              </div>
            {% endif %}
          </div>

          <div class="ai-sales-grid__content-{{ ai_gen_id }}">
            <h3 class="ai-sales-grid__product-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>

            <div class="ai-sales-grid__price-wrapper-{{ ai_gen_id }}">
              <span class="ai-sales-grid__price-{{ ai_gen_id }}">
                {{ product.price | money }}
              </span>
              {% if product.compare_at_price > product.price %}
                <span class="ai-sales-grid__compare-price-{{ ai_gen_id }}">
                  {{ product.compare_at_price | money }}
                </span>
                {% if block.settings.show_discount_text %}
                  {% assign savings = product.compare_at_price | minus: product.price %}
                  <span class="ai-sales-grid__discount-{{ ai_gen_id }}">
                    Save {{ savings | money }}
                  </span>
                {% endif %}
              {% endif %}
            </div>

            {% if block.settings.show_button %}
              <a href="{{ product.url }}" class="ai-sales-grid__button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-sales-grid__empty-state-{{ ai_gen_id }}">
      {{ 'product-1' | placeholder_svg_tag }}
      <p>Select products to display in this sales grid</p>
    </div>
  {% endif %}
</sales-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class SalesProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeGrid();
      }

      initializeGrid() {
        const cards = this.querySelectorAll('.ai-sales-grid__product-card-{{ ai_gen_id }}');
        
        cards.forEach((card) => {
          card.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-4px)';
          });
          
          card.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
          });
        });
      }
    }

    customElements.define('sales-product-grid-{{ ai_gen_id }}', SalesProductGrid{{ ai_gen_id }});
  })();
</script>

