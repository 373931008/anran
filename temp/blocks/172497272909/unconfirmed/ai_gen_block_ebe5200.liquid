{% doc %}
  @prompt
    帮忙生成一个适合手机端的图片横幅，跟电脑端相互独立，自适应的模块
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-responsive-banner__container-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-responsive-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-responsive-banner__desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-responsive-banner__mobile-{{ ai_gen_id }} {
    display: block;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 200px;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 300px;
  }

  .ai-responsive-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-responsive-banner__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-responsive-banner__desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-responsive-banner__mobile-{{ ai_gen_id }} {
      display: none;
    }

    .ai-responsive-banner__container-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin: 0 auto;
    }
  }
{% endstyle %}

<responsive-banner-{{ ai_gen_id }} class="ai-responsive-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-banner__container-{{ ai_gen_id }}">
    {% if block.settings.banner_link != blank %}
      <a href="{{ block.settings.banner_link }}" class="ai-responsive-banner__link-{{ ai_gen_id }}">
    {% endif %}

    <div class="ai-responsive-banner__desktop-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-responsive-banner__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
            添加桌面端图片
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-responsive-banner__mobile-{{ ai_gen_id }}">
      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-responsive-banner__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
            添加移动端图片
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.banner_link != blank %}
      </a>
    {% endif %}
  </div>
</responsive-banner-{{ ai_gen_id }}>

{% schema %}
{
  "name": "响应式图片横幅",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "桌面端图片"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "桌面端图片"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面端宽度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "移动端图片"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "移动端图片"
    },
    {
      "type": "header",
      "content": "链接设置"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "横幅链接"
    },
    {
      "type": "header",
      "content": "样式设置"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "圆角半径",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "响应式图片横幅"
    }
  ]
}
{% endschema %}
