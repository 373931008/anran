{% doc %}
  @prompt
    帮忙生成一个图片横幅，需要可以上传电脑端跟手机端的banner图，用电脑端跟手机端打开页面显示分别对应的画面，大小图片自适应, 查看图片类型，在banner下面加上这种多买多折的模块，内容可以自己编辑的, 帮忙把多买多折模块删除
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0 auto;
  }

  .ai-responsive-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-responsive-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-responsive-banner__desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-responsive-banner__mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 400px;
  }

  .ai-responsive-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-banner__desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-responsive-banner__mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<responsive-banner-{{ ai_gen_id }} class="ai-responsive-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image or block.settings.mobile_image %}
      {% if block.settings.desktop_image %}
        <div class="ai-responsive-banner__desktop-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-responsive-banner__image-{{ ai_gen_id }}"
          >
        </div>
      {% endif %}

      {% if block.settings.mobile_image %}
        <div class="ai-responsive-banner__mobile-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
            class="ai-responsive-banner__image-{{ ai_gen_id }}"
          >
        </div>
      {% endif %}
    {% else %}
      <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
          添加桌面端和移动端横幅图片
        </div>
      </div>
    {% endif %}
  </div>
</responsive-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ResponsiveBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.checkImages();
      }

      checkImages() {
        const desktopImg = this.querySelector('.ai-responsive-banner__desktop-{{ ai_gen_id }}');
        const mobileImg = this.querySelector('.ai-responsive-banner__mobile-{{ ai_gen_id }}');

        if (desktopImg && !mobileImg) {
          desktopImg.style.display = 'block';
        }

        if (mobileImg && !desktopImg) {
          mobileImg.style.display = 'block';
        }
      }
    }

    customElements.define('responsive-banner-{{ ai_gen_id }}', ResponsiveBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "响应式横幅",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "横幅图片"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "桌面端图片"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "移动端图片"
    }
  ],
  "presets": [
    {
      "name": "响应式横幅"
    }
  ]
}
{% endschema %}
