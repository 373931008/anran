{% doc %}
  @prompt
    https://www.aosulife.com/pages/sales
    你可以根据这个页面的排版。帮忙弄一下吗
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sales-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-sales-banner__content-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-sales-banner__label-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.label_bg_color }};
    color: {{ block.settings.label_text_color }};
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-sales-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-sales-banner__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 30px;
    line-height: 1.6;
  }

  .ai-sales-banner__timer-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ai-sales-banner__timer-item-{{ ai_gen_id }} {
    background: {{ block.settings.timer_bg_color }};
    border-radius: 8px;
    padding: 16px 20px;
    min-width: 80px;
  }

  .ai-sales-banner__timer-value-{{ ai_gen_id }} {
    display: block;
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.timer_number_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-sales-banner__timer-label-{{ ai_gen_id }} {
    display: block;
    font-size: 12px;
    color: {{ block.settings.timer_label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-sales-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: 16px 40px;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-sales-banner__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-sales-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-sales-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-sales-banner__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-sales-banner__timer-item-{{ ai_gen_id }} {
      min-width: 70px;
      padding: 12px 16px;
    }

    .ai-sales-banner__timer-value-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<sales-banner-{{ ai_gen_id }} class="ai-sales-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sales-banner__content-{{ ai_gen_id }}">
    {% if block.settings.label != blank %}
      <div class="ai-sales-banner__label-{{ ai_gen_id }}">
        {{ block.settings.label }}
      </div>
    {% endif %}

    {% if block.settings.title != blank %}
      <h2 class="ai-sales-banner__title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-sales-banner__description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.show_timer %}
      <div class="ai-sales-banner__timer-{{ ai_gen_id }}" data-end-date="{{ block.settings.end_date }}" data-end-time="{{ block.settings.end_time }}">
        <div class="ai-sales-banner__timer-item-{{ ai_gen_id }}">
          <span class="ai-sales-banner__timer-value-{{ ai_gen_id }}" data-days>00</span>
          <span class="ai-sales-banner__timer-label-{{ ai_gen_id }}">Days</span>
        </div>
        <div class="ai-sales-banner__timer-item-{{ ai_gen_id }}">
          <span class="ai-sales-banner__timer-value-{{ ai_gen_id }}" data-hours>00</span>
          <span class="ai-sales-banner__timer-label-{{ ai_gen_id }}">Hours</span>
        </div>
        <div class="ai-sales-banner__timer-item-{{ ai_gen_id }}">
          <span class="ai-sales-banner__timer-value-{{ ai_gen_id }}" data-minutes>00</span>
          <span class="ai-sales-banner__timer-label-{{ ai_gen_id }}">Minutes</span>
        </div>
        <div class="ai-sales-banner__timer-item-{{ ai_gen_id }}">
          <span class="ai-sales-banner__timer-value-{{ ai_gen_id }}" data-seconds>00</span>
          <span class="ai-sales-banner__timer-label-{{ ai_gen_id }}">Seconds</span>
        </div>
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-sales-banner__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</sales-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class SalesBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timer = this.querySelector('.ai-sales-banner__timer-{{ ai_gen_id }}');
        if (this.timer) {
          this.initCountdown();
        }
      }

      initCountdown() {
        const endDate = this.timer.getAttribute('data-end-date');
        const endTime = this.timer.getAttribute('data-end-time');
        
        if (!endDate || !endTime) return;

        const endDateTime = new Date(endDate + 'T' + endTime).getTime();

        this.updateCountdown(endDateTime);
        this.interval = setInterval(() => this.updateCountdown(endDateTime), 1000);
      }

      updateCountdown(endDateTime) {
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          clearInterval(this.interval);
          this.timer.querySelector('[data-days]').textContent = '00';
          this.timer.querySelector('[data-hours]').textContent = '00';
          this.timer.querySelector('[data-minutes]').textContent = '00';
          this.timer.querySelector('[data-seconds]').textContent = '00';
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.timer.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
        this.timer.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
        this.timer.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
        this.timer.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }
    }

    customElements.define('sales-banner-{{ ai_gen_id }}', SalesBanner{{ ai_gen_id }});
  })();
</script>

