{% doc %}
  @prompt
    https://www.aosulife.com/pages/sales帮忙参考这个网页的模块排版。
    生成：Weekly Flash Sale
    Top Picks
    Save More in Bundle
    大小间距可以一模一样
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bundle-container-{{ ai_gen_id }} {
    max-width: 1500px;
    margin: 0 auto;
  }

  .ai-bundle-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-bundle-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-bundle-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-bundle-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  .ai-bundle-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
  }

  .ai-bundle-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  }

  .ai-bundle-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-bundle-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bundle-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: {{ block.settings.badge_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 700;
  }

  .ai-bundle-content-{{ ai_gen_id }} {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-bundle-card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 700;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    line-height: 1.4;
  }

  .ai-bundle-description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.description_color }};
    margin: 0 0 16px;
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-bundle-products-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-bundle-product-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .ai-bundle-product-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-bundle-product-thumb-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-bundle-product-thumb-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bundle-product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-bundle-product-name-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.product_name_color }};
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .ai-bundle-product-price-{{ ai_gen_id }} {
    font-size: 12px;
    color: #999;
  }

  .ai-bundle-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding: 16px;
    background-color: {{ block.settings.price_bg_color }};
    border-radius: 8px;
  }

  .ai-bundle-price-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_label_color }};
  }

  .ai-bundle-price-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
  }

  .ai-bundle-savings-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.savings_color }};
    font-weight: 600;
  }

  .ai-bundle-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-bundle-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bundle-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  @media screen and (max-width: 749px) {
    .ai-bundle-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-bundle-header-{{ ai_gen_id }} {
      margin-bottom: 32px;
    }

    .ai-bundle-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-bundle-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-bundle-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-bundle-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<bundle-section-{{ ai_gen_id }} class="ai-bundle-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bundle-container-{{ ai_gen_id }}">
    <div class="ai-bundle-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-bundle-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-bundle-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-bundle-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign bundle_title_key = 'bundle_' | append: i | append: '_title'
          assign bundle_desc_key = 'bundle_' | append: i | append: '_description'
          assign bundle_image_key = 'bundle_' | append: i | append: '_image'
          assign bundle_products_key = 'bundle_' | append: i | append: '_products'
          assign bundle_price_key = 'bundle_' | append: i | append: '_price'
          assign bundle_savings_key = 'bundle_' | append: i | append: '_savings'
          assign bundle_url_key = 'bundle_' | append: i | append: '_url'

          assign bundle_title = block.settings[bundle_title_key]
          assign bundle_desc = block.settings[bundle_desc_key]
          assign bundle_image = block.settings[bundle_image_key]
          assign bundle_products = block.settings[bundle_products_key]
          assign bundle_price = block.settings[bundle_price_key]
          assign bundle_savings = block.settings[bundle_savings_key]
          assign bundle_url = block.settings[bundle_url_key]
        %}

        {% if bundle_title != blank %}
          <div class="ai-bundle-card-{{ ai_gen_id }}">
            <div class="ai-bundle-image-wrapper-{{ ai_gen_id }}">
              {% if bundle_image %}
                <img
                  src="{{ bundle_image | image_url: width: 800 }}"
                  alt="{{ bundle_image.alt | escape }}"
                  class="ai-bundle-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="600"
                >
              {% else %}
                <div class="ai-bundle-image-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if bundle_savings != blank %}
                <span class="ai-bundle-badge-{{ ai_gen_id }}">{{ bundle_savings }}</span>
              {% endif %}
            </div>
            <div class="ai-bundle-content-{{ ai_gen_id }}">
              <h3 class="ai-bundle-card-title-{{ ai_gen_id }}">{{ bundle_title }}</h3>
              {% if bundle_desc != blank %}
                <p class="ai-bundle-description-{{ ai_gen_id }}">{{ bundle_desc }}</p>
              {% endif %}

              {% if bundle_products.count > 0 %}
                <div class="ai-bundle-products-{{ ai_gen_id }}">
                  {% for product in bundle_products limit: 3 %}
                    <div class="ai-bundle-product-item-{{ ai_gen_id }}">
                      <div class="ai-bundle-product-thumb-{{ ai_gen_id }}">
                        {% if product.featured_image %}
                          <img
                            src="{{ product.featured_image | image_url: width: 100 }}"
                            alt="{{ product.featured_image.alt | escape }}"
                            loading="lazy"
                          >
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag }}
                        {% endif %}
                      </div>
                      <div class="ai-bundle-product-info-{{ ai_gen_id }}">
                        <div class="ai-bundle-product-name-{{ ai_gen_id }}">{{ product.title }}</div>
                        <div class="ai-bundle-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              {% endif %}

              {% if bundle_price != blank %}
                <div class="ai-bundle-price-wrapper-{{ ai_gen_id }}">
                  <span class="ai-bundle-price-label-{{ ai_gen_id }}">Bundle Price:</span>
                  <span class="ai-bundle-price-{{ ai_gen_id }}">{{ bundle_price }}</span>
                </div>
              {% endif %}

              {% if bundle_url != blank %}
                <a href="{{ bundle_url }}" class="ai-bundle-button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% else %}
                <a href="#" class="ai-bundle-button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.bundle_1_title == blank and block.settings.bundle_2_title == blank and block.settings.bundle_3_title == blank %}
      <div class="ai-bundle-empty-{{ ai_gen_id }}">
        <p>Configure bundle offers in the block settings</p>
      </div>
    {% endif %}
  </div>
</bundle-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BundleSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('bundle-section-{{ ai_gen_id }}', BundleSection{{ ai_gen_id }});
  })();
</script>

