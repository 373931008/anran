{% doc %}
  @prompt
    帮忙生成一个图片横幅，需要可以上传电脑端跟手机端的banner图，用电脑端跟手机端打开页面显示分别对应的画面，大小图片自适应, 查看图片类型，在banner下面加上这种多买多折的模块，内容可以自己编辑的
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-discount-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bulk-discount__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-bulk-discount__title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 30px;
    font-weight: 600;
  }

  .ai-bulk-discount__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .ai-bulk-discount__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px 20px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-bulk-discount__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-bulk-discount__quantity-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_size }}px;
    color: {{ block.settings.quantity_color }};
    font-weight: 700;
    margin: 0 0 15px;
  }

  .ai-bulk-discount__discount-{{ ai_gen_id }} {
    font-size: {{ block.settings.discount_size }}px;
    color: {{ block.settings.discount_color }};
    font-weight: 700;
    margin: 0 0 10px;
  }

  .ai-bulk-discount__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-bulk-discount__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-discount-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-bulk-discount__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .ai-bulk-discount__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
      margin-bottom: 20px;
    }
  }
{% endstyle %}

<bulk-discount-{{ ai_gen_id }}
  class="ai-bulk-discount-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bulk-discount__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-bulk-discount__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    {% assign has_content = false %}
    {% if block.settings.tier_1_quantity != blank or block.settings.tier_2_quantity != blank or block.settings.tier_3_quantity != blank %}
      {% assign has_content = true %}
    {% endif %}

    {% if has_content %}
      <div class="ai-bulk-discount__grid-{{ ai_gen_id }}">
        {% if block.settings.tier_1_quantity != blank %}
          <div class="ai-bulk-discount__item-{{ ai_gen_id }}">
            <div class="ai-bulk-discount__quantity-{{ ai_gen_id }}">
              {{ block.settings.tier_1_quantity }}
            </div>
            <div class="ai-bulk-discount__discount-{{ ai_gen_id }}">
              {{ block.settings.tier_1_discount }}
            </div>
            {% if block.settings.tier_1_description != blank %}
              <div class="ai-bulk-discount__description-{{ ai_gen_id }}">
                {{ block.settings.tier_1_description }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.tier_2_quantity != blank %}
          <div class="ai-bulk-discount__item-{{ ai_gen_id }}">
            <div class="ai-bulk-discount__quantity-{{ ai_gen_id }}">
              {{ block.settings.tier_2_quantity }}
            </div>
            <div class="ai-bulk-discount__discount-{{ ai_gen_id }}">
              {{ block.settings.tier_2_discount }}
            </div>
            {% if block.settings.tier_2_description != blank %}
              <div class="ai-bulk-discount__description-{{ ai_gen_id }}">
                {{ block.settings.tier_2_description }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.tier_3_quantity != blank %}
          <div class="ai-bulk-discount__item-{{ ai_gen_id }}">
            <div class="ai-bulk-discount__quantity-{{ ai_gen_id }}">
              {{ block.settings.tier_3_quantity }}
            </div>
            <div class="ai-bulk-discount__discount-{{ ai_gen_id }}">
              {{ block.settings.tier_3_discount }}
            </div>
            {% if block.settings.tier_3_description != blank %}
              <div class="ai-bulk-discount__description-{{ ai_gen_id }}">
                {{ block.settings.tier_3_description }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="ai-bulk-discount__empty-state-{{ ai_gen_id }}">
        请在设置中添加折扣档位信息
      </div>
    {% endif %}
  </div>
</bulk-discount-{{ ai_gen_id }}>

<script>
  (function() {
    class BulkDiscount{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('bulk-discount-{{ ai_gen_id }}', BulkDiscount{{ ai_gen_id }});
  })();
</script>

