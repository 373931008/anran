      </div>
    {% endif %}

    {% if block.settings.item_5_text != blank %}
      <div class="ai-usp-item-{{ ai_gen_id }}">
        <div class="ai-usp-icon-{{ ai_gen_id }}">
          {% if block.settings.item_5_icon_image != blank %}
            <img
              src="{{ block.settings.item_5_icon_image | image_url: width: 100 }}"
              alt="{{ block.settings.item_5_text | escape }}"
              width="100"
