</usp-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class UspBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const container = this.querySelector('.ai-usp-bar-container-{{ ai_gen_id }}');
        if (container && window.innerWidth <= 749) {
          const mobileLayout = '{{ block.settings.mobile_layout }}';
          if (mobileLayout === 'scroll') {
            container.setAttribute('role', 'region');
            container.setAttribute('aria-label', 'Product benefits');
            container.setAttribute('tabindex', '0');
          }
        }
      }
    }

    customElements.define('usp-bar-{{ ai_gen_id }}', UspBar{{ ai_gen_id }});
  })();
</script>

