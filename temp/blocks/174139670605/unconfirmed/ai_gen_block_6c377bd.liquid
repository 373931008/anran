          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% endif %}
        </div>
        {% if block.settings.text_3 != blank %}
          <div class="ai-usp-text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.icon_4 != blank or block.settings.text_4 != blank %}
      <div class="ai-usp-item-{{ ai_gen_id }}">
        <div class="ai-usp-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_4 != blank %}
            <img
              src="{{ block.settings.icon_4 | image_url: width: 100 }}"
              alt="{{ block.settings.text_4 | escape }}"
              width="100"
              height="100"
              loading="lazy"
            >
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          {% endif %}
        </div>
        {% if block.settings.text_4 != blank %}
          <div class="ai-usp-text-{{ ai_gen_id }}">{{ block.settings.text_4 }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.icon_5 != blank or block.settings.text_5 != blank %}
      <div class="ai-usp-item-{{ ai_gen_id }}">
        <div class="ai-usp-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_5 != blank %}
            <img
              src="{{ block.settings.icon_5 | image_url: width: 100 }}"
              alt="{{ block.settings.text_5 | escape }}"
              width="100"
