{% doc %}
  @prompt
    生成一个规格参数列表
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spec-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
  }

  .ai-spec-list-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-spec-list-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-spec-list-item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    gap: 16px;
  }

  .ai-spec-list-item-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    flex-shrink: 0;
    min-width: 120px;
  }

  .ai-spec-list-item-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.value_color }};
    text-align: right;
    flex-grow: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-spec-list-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-spec-list-item-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .ai-spec-list-item-value-{{ ai_gen_id }} {
      text-align: left;
    }
  }
{% endstyle %}

<div class="ai-spec-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h3 class="ai-spec-list-title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  <div class="ai-spec-list-items-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign label_key = 'spec_' | append: i | append: '_label'
        assign value_key = 'spec_' | append: i | append: '_value'
        assign label = block.settings[label_key]
        assign value = block.settings[value_key]
      %}

      {% if label != blank and value != blank %}
        <div class="ai-spec-list-item-{{ ai_gen_id }}">
          <div class="ai-spec-list-item-label-{{ ai_gen_id }}">{{ label }}</div>
          <div class="ai-spec-list-item-value-{{ ai_gen_id }}">{{ value }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

