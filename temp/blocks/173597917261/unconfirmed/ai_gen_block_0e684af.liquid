{% doc %}
  @prompt
    生成一个Product list, 促销设置
    产品图片（image picker）
    
    标题（text）
    
    评分（number）
    
    评论数（number）
    
    卖点1/卖点2（text）
    
    当前价格 / 原价（text）
    
    折扣（自动计算或手动）
    
    按钮链接（url）, 所有的内容靠左对齐，产品卖点再增加一条，另外可以设置上传卖点前面的icon图标，价格可以单独设置原价和优惠价还有折扣的字体大小，, 我需要做成可以设置一行做4个或者3个或者2个或者1个，购买的按钮我可以设置可以控制长宽。, 产品选择只要4个就够了，产品1，产品2，产品3，产品4；产品图标的图片选择功能可以删除；字体大小中需要增加产品卖点的字体大小调整；整个模块的布局宽度需要可以设置，以及两侧以及上下留白的大小设置, 我需要在颜色设置中可以设置整个模块的底色。我需要在字体大小中设置字体粗细。另外需要在价格前显示货币符号, 货币显示不需要我设置，直接按系统默认的可以吗, 产品图片和卡片上方，左右两个不需要留白, 我需要所有卡片 等高（equal height）
    
    底部元素（价格 + 按钮）底对齐（bottom aligned）
    
    中间内容用留白撑开（flexible spacing）
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-product-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.module_bg_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-promo-product-list__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.module_width }}px;
    margin: 0 auto;
  }

  .ai-promo-product-list__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-promo-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
  }

  .ai-promo-product-card__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-promo-product-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-promo-product-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: left;
  }

  .ai-promo-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
  }

  .ai-promo-product-card__rating-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-promo-product-card__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-promo-product-card__star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-promo-product-card__star--empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-promo-product-card__reviews-{{ ai_gen_id }} {
    font-size: {{ block.settings.reviews_font_size }}px;
    font-weight: {{ block.settings.reviews_font_weight }};
    color: {{ block.settings.reviews_color }};
  }

  .ai-promo-product-card__features-{{ ai_gen_id }} {
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .ai-promo-product-card__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 8px;
    font-size: {{ block.settings.feature_font_size }}px;
    font-weight: {{ block.settings.feature_font_weight }};
    color: {{ block.settings.feature_color }};
  }

  .ai-promo-product-card__feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-promo-product-card__feature-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-promo-product-card__feature-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-promo-product-card__bottom-{{ ai_gen_id }} {
    margin-top: auto;
  }

  .ai-promo-product-card__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .ai-promo-product-card__current-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.current_price_font_size }}px;
    font-weight: {{ block.settings.current_price_font_weight }};
    color: {{ block.settings.current_price_color }};
  }

  .ai-promo-product-card__original-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.original_price_font_size }}px;
    font-weight: {{ block.settings.original_price_font_weight }};
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
  }

  .ai-promo-product-card__discount-{{ ai_gen_id }} {
    font-size: {{ block.settings.discount_font_size }}px;
    font-weight: {{ block.settings.discount_font_weight }};
    color: {{ block.settings.discount_color }};
    background-color: {{ block.settings.discount_bg_color }};
    padding: 4px 8px;
    border-radius: 4px;
  }

  .ai-promo-product-card__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.button_width }}px;
    height: {{ block.settings.button_height }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-promo-product-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-promo-product-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<promo-product-list-{{ ai_gen_id }} class="ai-promo-product-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-product-list__container-{{ ai_gen_id }}">
    <div class="ai-promo-product-list__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign title_key = 'product_' | append: i | append: '_title'
          assign rating_key = 'product_' | append: i | append: '_rating'
          assign reviews_key = 'product_' | append: i | append: '_reviews'
          assign feature1_key = 'product_' | append: i | append: '_feature1'
          assign feature2_key = 'product_' | append: i | append: '_feature2'
          assign feature3_key = 'product_' | append: i | append: '_feature3'
          assign current_price_key = 'product_' | append: i | append: '_current_price'
          assign original_price_key = 'product_' | append: i | append: '_original_price'
          assign discount_key = 'product_' | append: i | append: '_discount'
          assign button_link_key = 'product_' | append: i | append: '_button_link'
          assign product_key = 'product_' | append: i

          assign title = block.settings[title_key]
          assign rating = block.settings[rating_key]
          assign reviews = block.settings[reviews_key]
          assign feature1 = block.settings[feature1_key]
          assign feature2 = block.settings[feature2_key]
          assign feature3 = block.settings[feature3_key]
          assign current_price = block.settings[current_price_key]
          assign original_price = block.settings[original_price_key]
          assign discount = block.settings[discount_key]
          assign button_link = block.settings[button_link_key]
          assign product = block.settings[product_key]
        %}

        <div class="ai-promo-product-card-{{ ai_gen_id }}">
          <div class="ai-promo-product-card__image-wrapper-{{ ai_gen_id }}">
            {% if product != blank and product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-promo-product-card__image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
              >
            {% else %}
              <div class="ai-promo-product-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-promo-product-card__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-promo-product-card__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if rating > 0 %}
              <div class="ai-promo-product-card__rating-wrapper-{{ ai_gen_id }}">
                <div class="ai-promo-product-card__stars-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    {% if star <= rating %}
                      <svg class="ai-promo-product-card__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% else %}
                      <svg class="ai-promo-product-card__star-{{ ai_gen_id }} ai-promo-product-card__star--empty-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endif %}
                  {% endfor %}
                </div>
                {% if reviews > 0 %}
                  <span class="ai-promo-product-card__reviews-{{ ai_gen_id }}">({{ reviews }})</span>
                {% endif %}
              </div>
            {% endif %}

            <div class="ai-promo-product-card__features-{{ ai_gen_id }}">
              {% if feature1 != blank %}
                <div class="ai-promo-product-card__feature-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <div class="ai-promo-product-card__feature-icon-{{ ai_gen_id }}">
                      <img src="{{ block.settings.feature_icon | image_url: width: 100 }}" alt="" loading="lazy">
                    </div>
                  {% endif %}
                  <span class="ai-promo-product-card__feature-text-{{ ai_gen_id }}">{{ feature1 }}</span>
                </div>
              {% endif %}

              {% if feature2 != blank %}
                <div class="ai-promo-product-card__feature-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <div class="ai-promo-product-card__feature-icon-{{ ai_gen_id }}">
                      <img src="{{ block.settings.feature_icon | image_url: width: 100 }}" alt="" loading="lazy">
                    </div>
                  {% endif %}
                  <span class="ai-promo-product-card__feature-text-{{ ai_gen_id }}">{{ feature2 }}</span>
                </div>
              {% endif %}

              {% if feature3 != blank %}
                <div class="ai-promo-product-card__feature-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <div class="ai-promo-product-card__feature-icon-{{ ai_gen_id }}">
                      <img src="{{ block.settings.feature_icon | image_url: width: 100 }}" alt="" loading="lazy">
                    </div>
                  {% endif %}
                  <span class="ai-promo-product-card__feature-text-{{ ai_gen_id }}">{{ feature3 }}</span>
                </div>
              {% endif %}
            </div>

            <div class="ai-promo-product-card__bottom-{{ ai_gen_id }}">
              {% if current_price != blank or original_price != blank %}
                <div class="ai-promo-product-card__price-wrapper-{{ ai_gen_id }}">
                  {% if current_price != blank %}
                    <span class="ai-promo-product-card__current-price-{{ ai_gen_id }}">{{ cart.currency.symbol }}{{ current_price }}</span>
                  {% endif %}
                  {% if original_price != blank %}
                    <span class="ai-promo-product-card__original-price-{{ ai_gen_id }}">{{ cart.currency.symbol }}{{ original_price }}</span>
                  {% endif %}
                  {% if discount != blank %}
                    <span class="ai-promo-product-card__discount-{{ ai_gen_id }}">{{ discount }}</span>
                  {% endif %}
                </div>
              {% endif %}

              {% if button_link != blank %}
                <a href="{{ button_link }}" class="ai-promo-product-card__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</promo-product-list-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoProductList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('promo-product-list-{{ ai_gen_id }}', PromoProductList{{ ai_gen_id }});
  })();
</script>

