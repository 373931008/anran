{% doc %}
  @prompt
    帮我生成一个可以specs的模块，包含标题，描述，具体specs的列表，列表左侧是规格名称，右侧是具体的数据，名称和数据分别可以设置动态源, 我不需要一个一个设置，名称一列可以设置连接动态源到富文本，数据一列也可以设置连接动态源到富文本。两列对齐就好, 一开始只要展示8个，下方有一个查看更多的按钮，点击后可以显示剩下的内容
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-specs-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-specs-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-specs-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_bottom_spacing }}px 0;
    font-weight: 600;
  }

  .ai-specs-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-specs-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-specs-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-specs-column-{{ ai_gen_id }} p {
    margin: 0;
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-specs-column-{{ ai_gen_id }} p:last-child {
    border-bottom: none;
  }

  .ai-specs-column-{{ ai_gen_id }}--labels p {
    color: {{ block.settings.label_color }};
    font-weight: 600;
  }

  .ai-specs-column-{{ ai_gen_id }}--values p {
    color: {{ block.settings.value_color }};
    text-align: {{ block.settings.value_alignment }};
  }

  .ai-specs-column-{{ ai_gen_id }} p.ai-specs-hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-specs-toggle-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_top_spacing }}px;
    text-align: center;
  }

  .ai-specs-toggle-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_thickness }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-specs-toggle-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-specs-toggle-{{ ai_gen_id }}.ai-specs-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-specs-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-specs-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .ai-specs-column-{{ ai_gen_id }}--values {
      margin-top: -{{ block.settings.item_padding }}px;
    }

    .ai-specs-column-{{ ai_gen_id }}--values p {
      text-align: left;
      padding-top: {{ block.settings.item_padding | divided_by: 2 }}px;
      padding-bottom: {{ block.settings.item_padding | times: 1.5 }}px;
    }

    .ai-specs-column-{{ ai_gen_id }}--labels p {
      padding-bottom: {{ block.settings.item_padding | divided_by: 2 }}px;
      border-bottom: none;
    }
  }
{% endstyle %}

<product-specs-{{ ai_gen_id }} class="ai-specs-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.description != blank %}
    <div class="ai-specs-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-specs-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-specs-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-specs-content-{{ ai_gen_id }}">
    <div class="ai-specs-column-{{ ai_gen_id }} ai-specs-column-{{ ai_gen_id }}--labels" data-column="labels">
      {{ block.settings.spec_labels }}
    </div>
    <div class="ai-specs-column-{{ ai_gen_id }} ai-specs-column-{{ ai_gen_id }}--values" data-column="values">
      {{ block.settings.spec_values }}
    </div>
  </div>

  <div class="ai-specs-toggle-{{ ai_gen_id }}">
    <button class="ai-specs-toggle-btn-{{ ai_gen_id }}" data-toggle-btn>
      <span data-show-text>{{ block.settings.show_more_text }}</span>
      <span data-hide-text style="display: none;">{{ block.settings.show_less_text }}</span>
    </button>
  </div>
</product-specs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSpecs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.initialVisibleCount = {{ block.settings.initial_visible_count }};
        this.isExpanded = false;
      }

      connectedCallback() {
        this.labelColumn = this.querySelector('[data-column="labels"]');
        this.valueColumn = this.querySelector('[data-column="values"]');
        this.toggleBtn = this.querySelector('[data-toggle-btn]');
        this.toggleContainer = this.querySelector('.ai-specs-toggle-{{ ai_gen_id }}');
        this.showText = this.querySelector('[data-show-text]');
        this.hideText = this.querySelector('[data-hide-text]');

        if (!this.labelColumn || !this.valueColumn || !this.toggleBtn) return;

        this.labelItems = Array.from(this.labelColumn.querySelectorAll('p'));
        this.valueItems = Array.from(this.valueColumn.querySelectorAll('p'));

        this.init();
      }

      init() {
        if (this.labelItems.length <= this.initialVisibleCount) {
          this.toggleContainer.classList.add('ai-specs-hidden-{{ ai_gen_id }}');
          return;
        }

        this.hideExtraItems();

        this.toggleBtn.addEventListener('click', () => {
          this.toggleItems();
        });
      }

      hideExtraItems() {
        this.labelItems.forEach((item, index) => {
          if (index >= this.initialVisibleCount) {
            item.classList.add('ai-specs-hidden-{{ ai_gen_id }}');
          }
        });

        this.valueItems.forEach((item, index) => {
          if (index >= this.initialVisibleCount) {
            item.classList.add('ai-specs-hidden-{{ ai_gen_id }}');
          }
        });
      }

      toggleItems() {
        this.isExpanded = !this.isExpanded;

        this.labelItems.forEach((item, index) => {
          if (index >= this.initialVisibleCount) {
            if (this.isExpanded) {
              item.classList.remove('ai-specs-hidden-{{ ai_gen_id }}');
            } else {
              item.classList.add('ai-specs-hidden-{{ ai_gen_id }}');
            }
          }
        });

        this.valueItems.forEach((item, index) => {
          if (index >= this.initialVisibleCount) {
            if (this.isExpanded) {
              item.classList.remove('ai-specs-hidden-{{ ai_gen_id }}');
            } else {
              item.classList.add('ai-specs-hidden-{{ ai_gen_id }}');
            }
          }
        });

        if (this.isExpanded) {
          this.showText.style.display = 'none';
          this.hideText.style.display = 'inline';
        } else {
          this.showText.style.display = 'inline';
          this.hideText.style.display = 'none';
        }
      }
    }

    customElements.define('product-specs-{{ ai_gen_id }}', ProductSpecs{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "产品规格",
  "settings": [
    {
      "type": "header",
      "content": "标题和描述"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "标题",
      "default": "产品规格"
    },
    {
