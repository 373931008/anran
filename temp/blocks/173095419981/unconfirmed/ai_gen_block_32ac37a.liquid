{% doc %}
  @prompt
    帮我生成一个可以放图片的section，动态源可以链接图片文件的或者单张图片，模块格式标题，描述，图片三部分组成，图片设置中可以选择的素材高度自适应，以及Fill
    Fit
    Crop
    Tile的选择, 为什么无法选择元字段overview_extra_image_list这个图文文件列表呢, 改成可以上传文件的格式
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-display-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-display-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-image-display-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-display-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-display-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-image-display-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .ai-image-display-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  {% if block.settings.image_fit == 'fill' %}
    .ai-image-display-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height }}px;
    }
    .ai-image-display-image-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  {% elsif block.settings.image_fit == 'fit' %}
    .ai-image-display-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height }}px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: {{ block.settings.image_background_color }};
    }
    .ai-image-display-image-{{ ai_gen_id }} {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }
  {% elsif block.settings.image_fit == 'crop' %}
    .ai-image-display-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height }}px;
    }
    .ai-image-display-image-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: {{ block.settings.crop_position }};
    }
  {% elsif block.settings.image_fit == 'tile' %}
    .ai-image-display-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height }}px;
      background-size: {{ block.settings.tile_size }}px;
      background-repeat: repeat;
      background-position: center;
    }
    .ai-image-display-image-{{ ai_gen_id }} {
      display: none;
    }
  {% else %}
    .ai-image-display-image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
    }
  {% endif %}

  .ai-image-display-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    color: {{ block.settings.item_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-image-display-item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.item_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-image-display-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-display-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-display-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-display-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-image-display-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-image-display-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-image-display-image-wrapper-{{ ai_gen_id }},
    .ai-image-display-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<image-display-{{ ai_gen_id }}
  class="ai-image-display-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-display-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-image-display-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-image-display-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    <div class="ai-image-display-items-{{ ai_gen_id }}">
      {% liquid
        assign has_content = false
        
        if block.settings.file_1 != blank
          assign has_content = true
        elsif block.settings.file_2 != blank
          assign has_content = true
        elsif block.settings.file_3 != blank
          assign has_content = true
        elsif block.settings.file_4 != blank
          assign has_content = true
        elsif block.settings.file_5 != blank
          assign has_content = true
        endif
      %}

      {% if has_content %}
        {% for i in (1..5) %}
          {% liquid
            assign file_key = 'file_' | append: i
            assign title_key = 'item_title_' | append: i
            assign text_key = 'item_text_' | append: i
            
            assign current_file = block.settings[file_key]
            assign current_title = block.settings[title_key]
            assign current_text = block.settings[text_key]
          %}

          {% if current_file != blank %}
            <div class="ai-image-display-item-{{ ai_gen_id }}">
              <div class="ai-image-display-image-wrapper-{{ ai_gen_id }}"
                {% if block.settings.image_fit == 'tile' %}
                  style="background-image: url('{{ current_file | image_url: width: block.settings.tile_size }}');"
                {% endif %}
              >
                {% if block.settings.image_fit == 'adaptive' %}
                  <img
                    src="{{ current_file | image_url: width: 2000 }}"
                    alt="{{ current_file.alt | escape }}"
                    loading="lazy"
                    width="{{ current_file.width }}"
                    height="{{ current_file.height }}"
                    class="ai-image-display-image-{{ ai_gen_id }}"
                  >
                {% elsif block.settings.image_fit != 'tile' %}
                  <img
                    src="{{ current_file | image_url: width: 2000 }}"
                    alt="{{ current_file.alt | escape }}"
                    loading="lazy"
                    class="ai-image-display-image-{{ ai_gen_id }}"
                  >
                {% endif %}
              </div>

              {% if current_title != blank %}
                <h3 class="ai-image-display-item-title-{{ ai_gen_id }}">{{ current_title }}</h3>
              {% endif %}

              {% if current_text != blank %}
                <div class="ai-image-display-item-text-{{ ai_gen_id }}">{{ current_text }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-image-display-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-display-empty-state-{{ ai_gen_id }}">
            请上传图片文件或连接动态源
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</image-display-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageDisplay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const imageWrappers = this.querySelectorAll('.ai-image-display-image-wrapper-{{ ai_gen_id }}');
        imageWrappers.forEach((wrapper, index) => {
          wrapper.style.opacity = '0';
          setTimeout(() => {
            wrapper.style.transition = 'opacity 0.3s ease';
            wrapper.style.opacity = '1';
          }, 100 + (index * 50));
        });
      }
    }

    customElements.define('image-display-{{ ai_gen_id }}', ImageDisplay{{ ai_gen_id }});
  })();
</script>

