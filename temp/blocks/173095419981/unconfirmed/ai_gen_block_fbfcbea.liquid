{% doc %}
  @prompt
    帮我生成一个可以specs的模块，包含标题，描述，具体specs的列表，列表左侧是规格名称，右侧是具体的数据，名称和数据分别可以设置动态源
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-specs-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-specs-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-specs-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_bottom_spacing }}px 0;
    font-weight: 600;
  }

  .ai-specs-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-specs-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-specs-item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    gap: 20px;
  }

  .ai-specs-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-specs-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    flex-shrink: 0;
    max-width: 50%;
  }

  .ai-specs-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.value_color }};
    text-align: right;
    flex-grow: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-specs-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-specs-item-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 8px;
    }

    .ai-specs-label-{{ ai_gen_id }},
    .ai-specs-value-{{ ai_gen_id }} {
      max-width: 100%;
      text-align: left;
    }
  }
{% endstyle %}

<div class="ai-specs-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.description != blank %}
    <div class="ai-specs-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-specs-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-specs-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>
  {% endif %}

  <ul class="ai-specs-list-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign label_key = 'spec_' | append: i | append: '_label'
        assign value_key = 'spec_' | append: i | append: '_value'
        assign label = block.settings[label_key]
        assign value = block.settings[value_key]
      %}

      {% if label != blank and value != blank %}
        <li class="ai-specs-item-{{ ai_gen_id }}">
          <span class="ai-specs-label-{{ ai_gen_id }}">{{ label }}</span>
          <span class="ai-specs-value-{{ ai_gen_id }}">{{ value }}</span>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>

