{% doc %}
  @prompt
    帮我生成一个直接引用overview_extra_image_list文件列表的liquid, 我需要居中展示, 桌面端宽度改成跟随系统或者产品页默认的宽度布局，另外增加我可以控制两侧留白的边距
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-extra-images-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-extra-images-wrapper-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-extra-images-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.image_spacing }}px;
    width: 100%;
  }

  .ai-extra-images-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-extra-images-item-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-extra-images-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-extra-images-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-extra-images-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-extra-images-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-extra-images-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-extra-images-wrapper-{{ ai_gen_id }}">
    <div class="ai-extra-images-container-{{ ai_gen_id }}">
      {% if product.metafields.custom.overview_extra_image_list.value %}
        {% for file in product.metafields.custom.overview_extra_image_list.value %}
          <div class="ai-extra-images-item-{{ ai_gen_id }}">
            <img
              src="{{ file | image_url: width: 1000 }}"
              alt="{{ file.alt | default: product.title | escape }}"
              loading="lazy"
              width="{{ file.width }}"
              height="{{ file.height }}"
            >
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.columns_desktop) %}
          <div class="ai-extra-images-item-{{ ai_gen_id }}">
            <div class="ai-extra-images-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              {% if forloop.first %}
                <div class="ai-extra-images-empty-state-{{ ai_gen_id }}">
                  请在产品的 overview_extra_image_list 元字段中添加图片
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "产品额外图片列表",
  "settings": [
    {
      "type": "header",
      "content": "布局"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "桌面端列数",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "移动端列数",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "两侧留白边距",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "样式"
    },
    {
      "type": "range",
      "id": "image_spacing",
      "label": "图片间距",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "图片圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "上下内边距",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "产品额外图片列表"
    }
  ]
}
{% endschema %}
