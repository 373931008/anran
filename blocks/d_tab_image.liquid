{% doc %}
  @prompt
    生成一个可以添加tab和对应图片的模块，tab在图片上方，点击tab下方显示对应的图片, 需要整个模块上方增加一个标题和描述, 整个模块需要居中，另外桌面宽度设置单位为px，
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tab-image-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.desktop_width_px }}px;
    margin: 0 auto;
    display: block;
  }

  .ai-tab-image-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-tab-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-tab-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    font-weight: 600;
  }

  .ai-tab-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-tab-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_gap }}px;
    justify-content: {{ block.settings.tab_alignment }};
    flex-wrap: wrap;
  }

  .ai-tab-button-{{ ai_gen_id }} {
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    background-color: {{ block.settings.tab_bg_color }};
    color: {{ block.settings.tab_text_color }};
    border: {{ block.settings.tab_border_width }}px solid {{ block.settings.tab_border_color }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    font-size: {{ block.settings.tab_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-tab-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg_color }};
    color: {{ block.settings.tab_hover_text_color }};
    border-color: {{ block.settings.tab_hover_border_color }};
  }

  .ai-tab-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg_color }};
    color: {{ block.settings.tab_active_text_color }};
    border-color: {{ block.settings.tab_active_border_color }};
  }

  .ai-tab-images-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 300px;
  }

  .ai-tab-image-item-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-tab-image-item-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-tab-image-item-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-tab-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: 300px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-tab-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-tab-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-tab-image-container-{{ ai_gen_id }} {
      max-width: 100%;
      padding: 0 15px;
    }

    .ai-tab-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.8 }}px;
    }

    .ai-tab-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }

    .ai-tab-buttons-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_gap | times: 0.7 }}px;
    }

    .ai-tab-button-{{ ai_gen_id }} {
      padding: {{ block.settings.tab_padding_vertical | times: 0.8 }}px {{ block.settings.tab_padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<tab-image-switcher-{{ ai_gen_id }}
  class="ai-tab-image-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-tab-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-tab-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-tab-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-tab-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-tab-buttons-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
          assign tab_label_key = 'tab_' | append: i | append: '_label'
          assign tab_enabled = block.settings[tab_enabled_key]
          assign tab_label = block.settings[tab_label_key]
        %}

        {% if tab_enabled %}
          <button
            class="ai-tab-button-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-tab-index="{{ i }}"
            aria-label="{{ tab_label }}"
          >
            {{ tab_label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-tab-images-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
          assign tab_image_key = 'tab_' | append: i | append: '_image'
          assign tab_enabled = block.settings[tab_enabled_key]
          assign tab_image = block.settings[tab_image_key]
        %}

        {% if tab_enabled %}
          <div
            class="ai-tab-image-item-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-tab-content="{{ i }}"
          >
            {% if tab_image %}
              <img
                src="{{ tab_image | image_url: width: 2000 }}"
                alt="{{ tab_image.alt | escape }}"
                loading="lazy"
                width="{{ tab_image.width }}"
                height="{{ tab_image.height }}"
              >
            {% else %}
              <div class="ai-tab-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-tab-empty-state-{{ ai_gen_id }}">
                  为标签页 {{ i }} 添加图片
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</tab-image-switcher-{{ ai_gen_id }}>

<script>
  (function() {
    class TabImageSwitcher{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-tab-button-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-tab-image-item-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const tabIndex = button.getAttribute('data-tab-index');
            this.switchTab(tabIndex);
          });
        });
      }

      switchTab(index) {
        this.buttons.forEach((btn) => {
          btn.classList.remove('active');
        });

        this.contents.forEach((content) => {
          content.classList.remove('active');
        });

        const activeButton = this.querySelector(`[data-tab-index="${index}"]`);
        const activeContent = this.querySelector(`[data-tab-content="${index}"]`);

        if (activeButton) {
          activeButton.classList.add('active');
        }

        if (activeContent) {
          activeContent.classList.add('active');
        }
      }
    }

    customElements.define('tab-image-switcher-{{ ai_gen_id }}', TabImageSwitcher{{ ai_gen_id }});
  })();
</script>

