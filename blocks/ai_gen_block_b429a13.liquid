{% doc %}
  @prompt
    帮我生成一个直接引用overview_extra_image_list文件列表的liquid, 我需要居中展示, 桌面端宽度改成跟随系统或者产品页默认的宽度布局，另外增加我可以控制两侧留白的边距, 模版可以设置宽度，单位为px, 增加一个手机的两个留白边距设置, 可以增加一个我引用文件列表的名称设置吗, 再增加一个标题和描述的设置, 描述也需要可以添加动态源
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-extra-images-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-extra-images-wrapper-{{ ai_gen_id }} {
    max-width: {% if block.settings.container_width > 0 %}{{ block.settings.container_width }}px{% else %}{{ settings.page_width }}px{% endif %};
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-extra-images-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-extra-images-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-extra-images-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    color: {{ block.settings.description_color }};
  }

  .ai-extra-images-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.image_spacing }}px;
    width: 100%;
  }

  .ai-extra-images-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-extra-images-item-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-extra-images-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-extra-images-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-extra-images-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-extra-images-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-extra-images-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-extra-images-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-extra-images-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-extra-images-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-extra-images-wrapper-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-extra-images-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-extra-images-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-extra-images-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-extra-images-container-{{ ai_gen_id }}">
      {% assign metafield_key = block.settings.metafield_key %}
      {% assign file_list = product.metafields.custom[metafield_key].value %}
      
      {% if file_list %}
        {% for file in file_list %}
          <div class="ai-extra-images-item-{{ ai_gen_id }}">
            <img
              src="{{ file | image_url: width: 1000 }}"
              alt="{{ file.alt | default: product.title | escape }}"
              loading="lazy"
              width="{{ file.width }}"
              height="{{ file.height }}"
            >
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.columns_desktop) %}
          <div class="ai-extra-images-item-{{ ai_gen_id }}">
            <div class="ai-extra-images-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              {% if forloop.first %}
                <div class="ai-extra-images-empty-state-{{ ai_gen_id }}">
                  请在产品的 {{ metafield_key }} 元字段中添加图片
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "产品文件列表图片",
  "settings": [
    {
      "type": "header",
      "content": "数据源"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "元字段名称",
      "default": "overview_extra_image_list",
      "info": "输入产品元字段的 key 名称（例如：overview_extra_image_list）"
    },
    {
      "type": "header",
      "content": "标题和描述"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "描述"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文本对齐",
      "options": [
        {
          "value": "left",
          "label": "左对齐"
        },
        {
          "value": "center",
          "label": "居中"
        },
        {
          "value": "right",
          "label": "右对齐"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "标题字号",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "描述字号",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "标题颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "描述颜色",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "标题与描述间距",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "标题区域与图片间距",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "布局"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "容器宽度",
      "min": 0,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "default": 0,
      "info": "设置为 0 时跟随主题页面宽度"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "桌面端列数",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "移动端列数",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "桌面端两侧留白",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "horizontal_padding_mobile",
      "label": "移动端两侧留白",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "样式"
    },
    {
      "type": "range",
      "id": "image_spacing",
      "label": "图片间距",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "图片圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "上下内边距",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "产品文件列表图片"
    }
  ]
}
{% endschema %}
