{% doc %}
  @prompt
    生成一个产品规格的列表，一开始显示10个，下方有查看更多的按钮，点击后直接显示剩下的, 不用一个一个填，我只要一个富文本设置就好，另外下文本下方有一个查看更多的按钮，点击后直接显示更多内容。另外模块宽度用px的单位来设置，另外我需要可以设置标题居中还是左边或者右边, 初始显示内容和隐藏内容需要在同一个富文本里，这样我才方便直接链接一个动态源, 可以设置电脑2列，手机端一列吗, 电脑端可以设置1-3列，手机端可以设置1列或者2列, 代码可以简单点，现在只有电脑可以设置1列或者2列就好，手机只要1列。另外为什么点击显示更多，无法展示显示其他内容，你再看看修改显示更多的按钮功能, 点击显示更多后，需要有个收起的按钮，目前没有看到收起的按钮
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spec-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-spec-list__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-spec-list__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-spec-list__content-{{ ai_gen_id }} ul,
  .ai-spec-list__content-{{ ai_gen_id }} ol {
    list-style: none;
    padding: 0;
    margin: 0;
    {% if block.settings.desktop_columns == '2' %}
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0 {{ block.settings.column_gap }}px;
    {% endif %}
  }

  .ai-spec-list__content-{{ ai_gen_id }} li {
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-spec-list__content-{{ ai_gen_id }} li:last-child {
    border-bottom: none;
  }

  .ai-spec-list__content-{{ ai_gen_id }} p {
    margin: 0;
    padding: {{ block.settings.item_padding }}px 0;
  }

  .ai-spec-list__item--hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-spec-list__button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-spec-list__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-spec-list__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-spec-list__button--hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-spec-list__icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-spec-list__icon--rotated-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  @media screen and (max-width: 749px) {
    .ai-spec-list-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-spec-list__content-{{ ai_gen_id }} ul,
    .ai-spec-list__content-{{ ai_gen_id }} ol {
      display: block;
    }
  }
{% endstyle %}

<product-spec-list-{{ ai_gen_id }} 
  class="ai-spec-list-{{ ai_gen_id }}" 
  data-initial-items="{{ block.settings.initial_items }}"
  data-show-more-text="{{ block.settings.show_more_text | escape }}"
  data-show-less-text="{{ block.settings.show_less_text | escape }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h3 class="ai-spec-list__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  {% if block.settings.content != blank %}
    <div class="ai-spec-list__content-{{ ai_gen_id }}" data-content>
      {{ block.settings.content }}
    </div>

    <div class="ai-spec-list__button-wrapper-{{ ai_gen_id }}">
      <button 
        class="ai-spec-list__button-{{ ai_gen_id }}"
        data-toggle-button
        aria-expanded="false"
      >
        <span data-button-text>{{ block.settings.show_more_text }}</span>
        <svg class="ai-spec-list__icon-{{ ai_gen_id }}" data-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</product-spec-list-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSpecList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('[data-toggle-button]');
        this.buttonText = this.querySelector('[data-button-text]');
        this.icon = this.querySelector('[data-icon]');
        this.content = this.querySelector('[data-content]');
        this.showMoreText = this.dataset.showMoreText || '查看更多';
        this.showLessText = this.dataset.showLessText || '收起';
        this.initialItems = parseInt(this.dataset.initialItems) || 10;
        this.isExpanded = false;
        this.hiddenItems = [];

        if (!this.button || !this.content) return;

        this.setupItems();
        this.button.addEventListener('click', () => this.toggleContent());
      }

      setupItems() {
        const lists = this.content.querySelectorAll('ul, ol');
        let hasHiddenItems = false;
        
        lists.forEach(list => {
          const items = Array.from(list.children);
          
          if (items.length > this.initialItems) {
            hasHiddenItems = true;
            items.forEach((item, index) => {
              if (index >= this.initialItems) {
                item.classList.add('ai-spec-list__item--hidden-{{ ai_gen_id }}');
                this.hiddenItems.push(item);
              }
            });
          }
        });

        if (lists.length === 0) {
          const paragraphs = this.content.querySelectorAll('p');
          if (paragraphs.length > this.initialItems) {
            hasHiddenItems = true;
            paragraphs.forEach((p, index) => {
              if (index >= this.initialItems) {
                p.classList.add('ai-spec-list__item--hidden-{{ ai_gen_id }}');
                this.hiddenItems.push(p);
              }
            });
          }
        }

        if (!hasHiddenItems || this.hiddenItems.length === 0) {
          this.button.classList.add('ai-spec-list__button--hidden-{{ ai_gen_id }}');
        }
      }

      toggleContent() {
        this.isExpanded = !this.isExpanded;

        this.hiddenItems.forEach(item => {
          if (this.isExpanded) {
            item.classList.remove('ai-spec-list__item--hidden-{{ ai_gen_id }}');
          } else {
            item.classList.add('ai-spec-list__item--hidden-{{ ai_gen_id }}');
          }
        });

        this.buttonText.textContent = this.isExpanded ? this.showLessText : this.showMoreText;
        this.icon.classList.toggle('ai-spec-list__icon--rotated-{{ ai_gen_id }}', this.isExpanded);
        this.button.setAttribute('aria-expanded', this.isExpanded);
      }
    }

    customElements.define('product-spec-list-{{ ai_gen_id }}', ProductSpecList{{ ai_gen_id }});
  })();
</script>

{% schema %}
