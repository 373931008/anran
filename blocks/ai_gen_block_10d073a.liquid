{% doc %}
  @prompt
    帮我生成一个自适应图片的图片横幅模块
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-responsive-banner__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-responsive-banner__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    cursor: pointer;
  }

  .ai-responsive-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-responsive-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-responsive-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 90%;
    max-width: 600px;
    z-index: 2;
  }

  .ai-responsive-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-responsive-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-responsive-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-responsive-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-responsive-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-banner-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-responsive-banner__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-responsive-banner__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-responsive-banner__button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
      padding: 10px 24px;
    }
  }
{% endstyle %}

<div class="ai-responsive-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-banner__wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_link != blank %}
      <a href="{{ block.settings.banner_link }}" class="ai-responsive-banner__link-{{ ai_gen_id }}">
    {% endif %}

    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-responsive-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
          添加横幅图片
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-responsive-banner__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.show_content %}
      <div class="ai-responsive-banner__content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-responsive-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-responsive-banner__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}

        {% if block.settings.show_button and block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-responsive-banner__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.banner_link != blank %}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "自适应图片横幅",
  "settings": [
    {
      "type": "header",
      "content": "图片设置"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "横幅图片"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "图片链接"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "图片比例",
      "options": [
        {
          "value": "16/9",
          "label": "16:9 (宽屏)"
        },
        {
          "value": "21/9",
          "label": "21:9 (超宽屏)"
        },
        {
          "value": "4/3",
          "label": "4:3 (标准)"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "1/1",
          "label": "1:1 (正方形)"
        }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面宽度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "遮罩层"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "显示遮罩层",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "遮罩颜色",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "遮罩透明度",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "内容设置"
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "显示文字内容",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "标题"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "标题大小",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "标题颜色",
      "default": "#ffffff"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "描述文字"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "文字大小",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "按钮设置"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "显示按钮",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字",
      "default": "立即购买"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "按钮链接"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "按钮文字大小",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "按钮圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "按钮背景色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "按钮文字颜色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "悬停背景色",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "悬停文字颜色",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "自适应图片横幅"
    }
  ]
}
{% endschema %}
