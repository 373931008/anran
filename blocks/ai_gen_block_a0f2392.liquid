{% doc %}
  @prompt
    帮忙生成图片横幅，需要五张，可以选择页面跟产品链接大小为1920*800。上传的banner图点击图片可跳转链接。, 大小换为1920*900，加上每张图轮换时间间隔为3秒
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-banner-slider-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 46.875%;
  }

  .ai-banner-slider-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-banner-slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    flex-shrink: 0;
  }

  .ai-banner-slide-{{ ai_gen_id }} a {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-banner-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_icon_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: {{ block.settings.nav_button_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-banner-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-banner-nav-{{ ai_gen_id }}--prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-banner-nav-{{ ai_gen_id }}--next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-banner-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.5);
    height: calc({{ block.settings.nav_button_size }}px * 0.5);
  }

  .ai-banner-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .ai-banner-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-banner-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slider-container-{{ ai_gen_id }} {
      padding-bottom: 75%;
    }

    .ai-banner-nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_button_size }}px * 0.8);
      height: calc({{ block.settings.nav_button_size }}px * 0.8);
    }

    .ai-banner-nav-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }

    .ai-banner-nav-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.nav_button_offset }}px * 0.5);
    }
  }
{% endstyle %}

<banner-slider-{{ ai_gen_id }} class="ai-banner-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-slider-container-{{ ai_gen_id }}">
    <div class="ai-banner-slider-wrapper-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'banner_image_' | append: i
          assign link_type_key = 'banner_link_type_' | append: i
          assign page_key = 'banner_page_' | append: i
          assign product_key = 'banner_product_' | append: i
          assign url_key = 'banner_url_' | append: i

          assign banner_image = block.settings[image_key]
          assign link_type = block.settings[link_type_key]
          assign banner_page = block.settings[page_key]
          assign banner_product = block.settings[product_key]
          assign banner_url = block.settings[url_key]

          assign link_url = ''
          if link_type == 'page' and banner_page != blank
            assign link_url = banner_page.url
          elsif link_type == 'product' and banner_product != blank
            assign link_url = banner_product.url
          elsif link_type == 'url' and banner_url != blank
            assign link_url = banner_url
          endif
        %}

        <div class="ai-banner-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          {% if link_url != blank %}
            <a href="{{ link_url }}">
              {% if banner_image %}
                <img
                  src="{{ banner_image | image_url: width: 1920 }}"
                  alt="{{ banner_image.alt | escape }}"
                  loading="lazy"
                  width="1920"
                  height="900"
                >
              {% else %}
                <div class="ai-banner-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  <div class="ai-banner-empty-state-{{ ai_gen_id }}">
                    添加横幅图片 {{ i }}
                  </div>
                </div>
              {% endif %}
            </a>
          {% else %}
            {% if banner_image %}
              <img
                src="{{ banner_image | image_url: width: 1920 }}"
                alt="{{ banner_image.alt | escape }}"
                loading="lazy"
                width="1920"
                height="900"
              >
            {% else %}
              <div class="ai-banner-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                <div class="ai-banner-empty-state-{{ ai_gen_id }}">
                  添加横幅图片 {{ i }}
                </div>
              </div>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.show_navigation %}
      <button
        class="ai-banner-nav-{{ ai_gen_id }} ai-banner-nav-{{ ai_gen_id }}--prev"
        aria-label="上一张"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-banner-nav-{{ ai_gen_id }} ai-banner-nav-{{ ai_gen_id }}--next"
        aria-label="下一张"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-banner-dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          <button
            class="ai-banner-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
            data-slide="{{ i }}"
            aria-label="跳转到横幅 {{ i }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</banner-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 5;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-banner-slider-wrapper-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-banner-nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-banner-nav-{{ ai_gen_id }}--next');
        this.dots = this.querySelectorAll('.ai-banner-dot-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.startAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
          });
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goToSlide(slideNumber) {
        this.currentSlide = slideNumber;
        const offset = (slideNumber - 1) * -100;
        this.wrapper.style.transform = `translateX(${offset}%)`;
        this.updateDots();
      }

      goToNextSlide() {
        this.currentSlide = this.currentSlide >= this.totalSlides ? 1 : this.currentSlide + 1;
        this.goToSlide(this.currentSlide);
      }

      goToPrevSlide() {
        this.currentSlide = this.currentSlide <= 1 ? this.totalSlides : this.currentSlide - 1;
        this.goToSlide(this.currentSlide);
      }

      updateDots() {
        this.dots.forEach((dot, index) => {
          if (index + 1 === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        const autoplayEnabled = {{ block.settings.autoplay }};
        const autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (autoplayEnabled) {
          this.autoplayInterval = setInterval(() => {
            this.goToNextSlide();
          }, autoplaySpeed);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('banner-slider-{{ ai_gen_id }}', BannerSlider{{ ai_gen_id }});
  })();
</script>

