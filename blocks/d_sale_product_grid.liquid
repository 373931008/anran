{% doc %}
  @prompt
    生成一个Product list, 促销设置
    产品图片（image picker）
    
    标题（text）
    
    评分（number）
    
    评论数（number）
    
    卖点1/卖点2（text）
    
    当前价格 / 原价（text）
    
    折扣（自动计算或手动）
    
    按钮链接（url）, 所有的内容靠左对齐，产品卖点再增加一条，另外可以设置上传卖点前面的icon图标，价格可以单独设置原价和优惠价还有折扣的字体大小，, 我需要做成可以设置一行做4个或者3个或者2个或者1个，购买的按钮我可以设置可以控制长宽。, 产品选择只要4个就够了，产品1，产品2，产品3，产品4；产品图标的图片选择功能可以删除；字体大小中需要增加产品卖点的字体大小调整；整个模块的布局宽度需要可以设置，以及两侧以及上下留白的大小设置, 我需要在颜色设置中可以设置整个模块的底色。我需要在字体大小中设置字体粗细。另外需要在价格前显示货币符号, 货币显示不需要我设置，直接按系统默认的可以吗, 产品图片和卡片上方，左右两个不需要留白, 我需要所有卡片 等高（equal height）
    
    底部元素（价格 + 按钮）底对齐（bottom aligned）
    
    中间内容用留白撑开（flexible spacing）
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_horizontal }}px;
    background-color: {{ block.settings.section_bg_color }};
  }

  .ai-promo-product-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-promo-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-promo-product-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    text-align: left;
    height: 100%;
  }

  .ai-promo-product-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    position: relative;
    flex-shrink: 0;
  }

  .ai-promo-product-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-promo-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-promo-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-promo-product-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: {{ block.settings.padding }}px;
  }

  .ai-promo-product-top-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-promo-product-bottom-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: auto;
    padding-top: 12px;
  }

  .ai-promo-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-promo-product-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-promo-product-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-promo-product-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-promo-product-star-{{ ai_gen_id }}.empty {
    fill: #e0e0e0;
  }

  .ai-promo-product-reviews-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-promo-product-features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-promo-product-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.feature_size }}px;
    font-weight: {{ block.settings.feature_weight }};
    color: {{ block.settings.text_color }};
  }

  .ai-promo-product-feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-promo-product-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.feature_icon_color }};
  }

  .ai-promo-product-pricing-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-promo-product-current-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.current_price_size }}px;
    font-weight: {{ block.settings.current_price_weight }};
    color: {{ block.settings.sale_price_color }};
  }

  .ai-promo-product-original-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.original_price_size }}px;
    font-weight: {{ block.settings.original_price_weight }};
    color: {{ block.settings.text_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-promo-product-discount-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_bg_color }};
    color: {{ block.settings.discount_text_color }};
    padding: 4px 10px;
    border-radius: 20px;
    font-size: {{ block.settings.discount_size }}px;
    font-weight: {{ block.settings.discount_weight }};
  }

  .ai-promo-product-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    width: {{ block.settings.button_width }}%;
  }

  .ai-promo-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-promo-product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-promo-product-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<promo-product-grid-{{ ai_gen_id }} class="ai-promo-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-product-container-{{ ai_gen_id }}">
    <div class="ai-promo-product-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'product_image_' | append: i
          assign title_key = 'product_title_' | append: i
          assign rating_key = 'rating_' | append: i
          assign review_count_key = 'review_count_' | append: i
          assign feature_1_key = 'feature_1_' | append: i
          assign feature_2_key = 'feature_2_' | append: i
          assign feature_3_key = 'feature_3_' | append: i
          assign current_price_key = 'current_price_' | append: i
          assign original_price_key = 'original_price_' | append: i
          assign discount_key = 'discount_' | append: i
          assign link_key = 'button_link_' | append: i

          assign product_image = block.settings[image_key]
          assign product_title = block.settings[title_key]
          assign rating = block.settings[rating_key]
          assign review_count = block.settings[review_count_key]
          assign feature_1 = block.settings[feature_1_key]
          assign feature_2 = block.settings[feature_2_key]
          assign feature_3 = block.settings[feature_3_key]
          assign current_price = block.settings[current_price_key]
          assign original_price = block.settings[original_price_key]
          assign discount = block.settings[discount_key]
          assign button_link = block.settings[link_key]
        %}

        {% if product_title != blank or product_image != blank %}
          <div class="ai-promo-product-item-{{ ai_gen_id }}">
            <div class="ai-promo-product-image-wrapper-{{ ai_gen_id }}">
              {% if product_image %}
                <img
                  src="{{ product_image | image_url: width: 600 }}"
                  alt="{{ product_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-promo-product-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-promo-product-content-{{ ai_gen_id }}">
              <div class="ai-promo-product-top-content-{{ ai_gen_id }}">
                {% if product_title != blank %}
                  <h3 class="ai-promo-product-title-{{ ai_gen_id }}">{{ product_title }}</h3>
                {% endif %}

                {% if block.settings.show_rating %}
                  <div class="ai-promo-product-rating-{{ ai_gen_id }}">
                    <div class="ai-promo-product-stars-{{ ai_gen_id }}">
                      {% for j in (1..5) %}
                        {% if j <= rating %}
                          <svg class="ai-promo-product-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% else %}
                          <svg class="ai-promo-product-star-{{ ai_gen_id }} empty" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% endif %}
                      {% endfor %}
                    </div>
                    {% if review_count != blank %}
                      <span class="ai-promo-product-reviews-{{ ai_gen_id }}">({{ review_count }})</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if feature_1 != blank or feature_2 != blank or feature_3 != blank %}
                  <div class="ai-promo-product-features-{{ ai_gen_id }}">
                    {% if feature_1 != blank %}
                      <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                          </svg>
                        </div>
                        <span>{{ feature_1 }}</span>
                      </div>
                    {% endif %}
                    {% if feature_2 != blank %}
                      <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                          </svg>
                        </div>
                        <span>{{ feature_2 }}</span>
                      </div>
                    {% endif %}
                    {% if feature_3 != blank %}
                      <div class="ai-promo-product-feature-{{ ai_gen_id }}">
                        <div class="ai-promo-product-feature-icon-{{ ai_gen_id }}">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                          </svg>
                        </div>
                        <span>{{ feature_3 }}</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>

              <div class="ai-promo-product-bottom-content-{{ ai_gen_id }}">
                <div class="ai-promo-product-pricing-{{ ai_gen_id }}">
                  {% if current_price != blank %}
                    <span class="ai-promo-product-current-price-{{ ai_gen_id }}">{{ current_price | times: 100 | money }}</span>
                  {% endif %}
                  {% if original_price != blank %}
                    <span class="ai-promo-product-original-price-{{ ai_gen_id }}">{{ original_price | times: 100 | money }}</span>
                  {% endif %}
                  {% if discount != blank %}
                    <span class="ai-promo-product-discount-{{ ai_gen_id }}">{{ discount }}</span>
                  {% endif %}
                </div>

                {% if button_link != blank %}
                  <a href="{{ button_link }}" class="ai-promo-product-button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</promo-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('promo-product-grid-{{ ai_gen_id }}', PromoProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "促销产品网格",
  "settings": [
    {
      "type": "header",
      "content": "容器设置"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "容器最大宽度",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "上边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "下边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "左右边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "桌面每行列数",
      "options": [
        {
          "value": "1",
          "label": "1列"
        },
        {
          "value": "2",
          "label": "2列"
        },
        {
          "value": "3",
          "label": "3列"
        },
        {
          "value": "4",
          "label": "4列"
        }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "移动端每行列数",
      "options": [
        {
          "value": "1",
          "label": "1列"
        },
        {
          "value": "2",
          "label": "2列"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "网格间距",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding",
      "label": "卡片内边距",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "卡片圆角",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "评分设置"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "显示评分",
      "default": true
    },
    {
      "type": "header",
      "content": "按钮设置"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字",
      "default": "立即购买"
    },
    {
      "type": "range",
      "id": "button_width",
      "label": "按钮宽度",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "按钮上下内边距",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "按钮左右内边距",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "按钮字体大小",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "按钮圆角",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "整体模块背景颜色",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "卡片背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "标题颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字颜色",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "星星颜色",
      "default": "#ffa500"
    },
    {
      "type": "color",
      "id": "feature_icon_color",
      "label": "卖点图标颜色",
      "default": "#4caf50"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "促销价颜色",
      "default": "#e53935"
    },
    {
      "type": "color",
      "id": "discount_bg_color",
      "label": "折扣标签背景",
      "default": "#ff5252"
    },
    {
      "type": "color",
      "id": "discount_text_color",
      "label": "折扣标签文字",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "按钮背景颜色",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "按钮悬停颜色",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "按钮文字颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "字体大小和粗细"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "标题大小",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_weight",
      "label": "标题粗细",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 600
    },
    {
      "type": "range",
      "id": "feature_size",
      "label": "卖点字体大小",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "feature_weight",
      "label": "卖点字体粗细",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "range",
      "id": "current_price_size",
      "label": "当前价格字体大小",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "current_price_weight",
      "label": "当前价格字体粗细",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "original_price_size",
      "label": "原价字体大小",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "original_price_weight",
      "label": "原价字体粗细",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "range",
      "id": "discount_size",
      "label": "折扣字体大小",
      "min": 10,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "discount_weight",
      "label": "折扣字体粗细",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 600
    },
    {
