# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Tab indentation (no size specified)
[Makefile]
indent_style = tab

# Liquid files
[*.liquid]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
insert_final_newline = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# CSS files
[*.{css,scss,sass}]
indent_size = 2

# JavaScript files
[*.{js,mjs,cjs,ts}]
indent_size = 2
