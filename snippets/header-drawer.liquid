{% comment %}
  Renders a header drawer menu for mobile and desktop.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__header">
          {% render 'header-logo', logo_class: 'menu-drawer__logo', logo_sizes: '120px' %}
          <button type="button" class="menu-drawer__close-button-custom" aria-label="{{ 'accessibility.close' | t }}">
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                <path d="M13.7246 0.707107L0.724639 13.7071M0.704865 0.726942L13.7444 13.6873" stroke="currentColor" stroke-width="2"/>
              </svg>
            </span>
          </button>
        </div>

        {% comment %} <div class="menu-drawer__search">
          <form action="{{ routes.search_url }}" method="get" role="search" class="search">
            <div class="menu-drawer__search-field">
              <span class="svg-wrapper menu-drawer__search-icon">
                {{- 'icon-search.svg' | inline_asset_content -}}
              </span>
              <input
                class="search__input field__input menu-drawer__search-input"
                id="Search-In-Drawer"
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                placeholder="Search"
              >
            </div>
          </form>
        </div> {% endcomment %}

        <div class="menu-drawer__navigation-container">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- for link in section.settings.menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="menu-drawer__menu-item menu-drawer__menu-item--level-1 list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}"
                      >
                        <span>{{ link.title | escape }}</span>
                        <span class="svg-wrapper menu-drawer__arrow">
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                        </span>
                      </summary>

                      <div
                        id="link-{{ link.handle | escape }}"
                        class="menu-drawer__submenu has-submenu gradient motion-reduce"
                        tabindex="-1"
                      >
                        <div class="menu-drawer__inner-submenu">
                          <div class="menu-drawer__panel-header">
                            <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                              <span class="svg-wrapper">
                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                              </span>
                              <span>{{ link.title | escape }}</span>
                            </button>
                          </div>

                          {%- if link.levels == 2 -%}
                            <div class="menu-drawer__product-menu">
                              {%- for childlink in link.links -%}
                                {%- assign child_collection = childlink.object -%}
                                <div class="menu-drawer__category">
                                  {%- if childlink.links != blank -%}
                                    <details id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}">
                                      <summary
                                        id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                        class="menu-drawer__category-summary link link--text focus-inset"
                                      >
                                        <span class="menu-drawer__category-main">
                                          <span class="menu-drawer__category-media">
                                            {%- if child_collection != blank
                                              and child_collection.featured_image != blank
                                            -%}
                                              <img
                                                src="{{ child_collection.featured_image | image_url: width: 96 }}"
                                                alt=""
                                                class="menu-drawer__category-image"
                                                loading="lazy"
                                                width="48"
                                                height="48"
                                                aria-hidden="true"
                                              >
                                            {%- elsif child_collection != blank and child_collection.image != blank -%}
                                              <img
                                                src="{{ child_collection.image | image_url: width: 96 }}"
                                                alt=""
                                                class="menu-drawer__category-image"
                                                loading="lazy"
                                                width="48"
                                                height="48"
                                                aria-hidden="true"
                                              >
                                            {%- endif -%}
                                          </span>
                                          <span class="menu-drawer__category-title">
                                            {{- childlink.title | escape -}}
                                          </span>
                                        </span>
                                        <span class="svg-wrapper menu-drawer__arrow">
                                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                                        </span>
                                      </summary>

                                      <div
                                        id="childlink-{{ childlink.handle | escape }}"
                                        class="menu-drawer__submenu has-submenu gradient motion-reduce"
                                        tabindex="-1"
                                      >
                                        <div class="menu-drawer__inner-submenu">
                                          <div class="menu-drawer__panel-header">
                                            <button
                                              class="menu-drawer__close-button link link--text focus-inset"
                                              aria-expanded="true"
                                            >
                                              <span class="svg-wrapper">
                                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                                              </span>
                                              <span>{{ childlink.title | escape }}</span>
                                            </button>
                                            <a href="{{ childlink.url }}" class="menu-drawer__view-all">View all</a>
                                          </div>

                                          <div class="menu-drawer__collection-groups">
                                            {%- for grandchildlink in childlink.links -%}
                                              {%- assign collection = grandchildlink.object -%}
                                              <section class="menu-drawer__collection-group">
                                                <div class="menu-drawer__collection-heading">
                                                  <a
                                                    href="{{ grandchildlink.url }}"
                                                    class="menu-drawer__collection-title"
                                                  >
                                                    {{- grandchildlink.title | escape -}}
                                                  </a>
                                                  <a
                                                    href="{{ grandchildlink.url }}"
                                                    class="menu-drawer__collection-link"
                                                  >
                                                    View all
                                                  </a>
                                                </div>

                                                {%- if collection != blank and collection.products.size > 0 -%}
                                                  <div class="menu-drawer__product-row">
                                                    {%- for product in collection.products limit: 4 -%}
                                                      {% render 'header-drawer-product-card', product: product %}
                                                    {%- endfor -%}
                                                  </div>
                                                {%- endif -%}
                                              </section>
                                            {%- endfor -%}
                                          </div>
                                        </div>
                                      </div>
                                    </details>
                                  {%- else -%}
                                    <a
                                      id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                      href="{{ childlink.url }}"
                                      class="menu-drawer__category-link link link--text focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                      {% if childlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                    >
                                      <span class="menu-drawer__category-main">
                                        <span class="menu-drawer__category-media">
                                          {%- if child_collection != blank
                                            and child_collection.featured_image != blank
                                          -%}
                                            <img
                                              src="{{ child_collection.featured_image | image_url: width: 96 }}"
                                              alt=""
                                              class="menu-drawer__category-image"
                                              loading="lazy"
                                              width="48"
                                              height="48"
                                              aria-hidden="true"
                                            >
                                          {%- elsif child_collection != blank and child_collection.image != blank -%}
                                            <img
                                              src="{{ child_collection.image | image_url: width: 96 }}"
                                              alt=""
                                              class="menu-drawer__category-image"
                                              loading="lazy"
                                              width="48"
                                              height="48"
                                              aria-hidden="true"
                                            >
                                          {%- else -%}
                                            {{
                                              'collection-1'
                                              | placeholder_svg_tag: 'menu-drawer__category-image placeholder-svg'
                                            }}
                                          {%- endif -%}
                                        </span>
                                        <span class="menu-drawer__category-title">{{ childlink.title | escape }}</span>
                                      </span>
                                      <span class="menu-drawer__category-link-text">View all</span>
                                    </a>

                                    {%- if child_collection != blank and child_collection.products.size > 0 -%}
                                      <div class="menu-drawer__product-row menu-drawer__product-row--category">
                                        {%- for product in child_collection.products limit: 4 -%}
                                          {% render 'header-drawer-product-card', product: product %}
                                        {%- endfor -%}
                                      </div>
                                    {%- endif -%}
                                  {%- endif -%}
                                </div>
                              {%- endfor -%}
                            </div>
                          {%- else -%}
                            <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                              {%- for childlink in link.links -%}
                                <li>
                                  {%- if childlink.links == blank -%}
                                    <a
                                      id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                      href="{{ childlink.url }}"
                                      class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                      {% if childlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                    >
                                      <span>{{ childlink.title | escape }}</span>
                                    </a>
                                  {%- else -%}
                                    <details id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}">
                                      <summary
                                        id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                        class="menu-drawer__menu-item link link--text list-menu__item focus-inset"
                                      >
                                        <span>{{ childlink.title | escape }}</span>
                                        <span class="svg-wrapper menu-drawer__arrow">
                                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                                        </span>
                                      </summary>
                                      <div
                                        id="childlink-{{ childlink.handle | escape }}"
                                        class="menu-drawer__submenu has-submenu gradient motion-reduce"
                                        tabindex="-1"
                                      >
                                        <div class="menu-drawer__inner-submenu">
                                          <div class="menu-drawer__panel-header">
                                            <button
                                              class="menu-drawer__close-button link link--text focus-inset"
                                              aria-expanded="true"
                                            >
                                              <span class="svg-wrapper">
                                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                                              </span>
                                              <span>{{ childlink.title | escape }}</span>
                                            </button>
                                          </div>

                                          <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                            {%- for grandchildlink in childlink.links -%}
                                              <li>
                                                <a
                                                  id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                                  href="{{ grandchildlink.url }}"
                                                  class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                                  {% if grandchildlink.current %}
                                                    aria-current="page"
                                                  {% endif %}
                                                >
                                                  <span>{{ grandchildlink.title | escape }}</span>
                                                </a>
                                              </li>
                                            {%- endfor -%}
                                          </ul>
                                        </div>
                                      </div>
                                    </details>
                                  {%- endif -%}
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="menu-drawer__menu-item menu-drawer__menu-item--level-1 list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                      {% if link.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      <span>{{ link.title | escape }}</span>
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>

          <div class="menu-drawer__footer">
            <div class="menu-drawer__service-grid">
              {%- for i in (1..4) -%}
                {%- assign icon_key = 'trust_badge_' | append: i | append: '_icon' -%}
                {%- assign svg_key = 'trust_badge_' | append: i | append: '_svg' -%}
                {%- assign text_key = 'trust_badge_' | append: i | append: '_text' -%}

                {%- assign badge_icon = section.settings[icon_key] -%}
                {%- assign badge_svg = section.settings[svg_key] -%}
                {%- assign badge_text = section.settings[text_key] -%}

                {%- if badge_svg != blank or badge_icon != blank or badge_text != blank -%}
                  <div class="menu-drawer__service-item">
                    <span class="menu-drawer__service-icon">
                      {%- if badge_svg != blank -%}
                        {{ badge_svg }}
                      {%- elsif badge_icon != blank -%}
                        {{ badge_icon | image_url: width: 48 | image_tag: loading: 'lazy', widths: '24,48' }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </span>
                    <span>{{ badge_text }}</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if section.settings.enable_payment_secured -%}
              <div class="menu-drawer__payment">
                <div class="menu-drawer__payment-icon">
                  {%- if section.settings.payment_secured_svg != blank -%}
                    {{ section.settings.payment_secured_svg }}
                  {%- elsif section.settings.payment_secured_image != blank -%}
                    {{
                      section.settings.payment_secured_image
                      | image_url: width: 50
                      | image_tag: loading: 'lazy', widths: '25,50'
                    }}
                  {%- else -%}
                    <span class="menu-drawer__payment-dot" aria-hidden="true"></span>
                  {%- endif -%}
                </div>
                <div class="menu-drawer__payment-content">
                  <div class="menu-drawer__payment-title">{{ section.settings.payment_secured_title }}</div>
                  <p class="menu-drawer__payment-desc">{{ section.settings.payment_secured_desc }}</p>
                </div>
              </div>
            {%- endif -%}

            <div class="menu-drawer__account-row">
              {%- if shop.customer_accounts_enabled -%}
                <a
                  href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif %}"
                  class="menu-drawer__login-link"
                >
                  <span class="svg-wrapper">{{- 'icon-account.svg' | inline_asset_content -}}</span>
                  <span>
                    {%- liquid
                      if customer
                        echo 'customer.account_fallback' | t
                      else
                        echo 'Log in'
                      endif
                    -%}
                  </span>
                </a>
              {%- endif -%}

              {% render 'social-icons', class: 'footer__list-social' %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </details>
</header-drawer>
