{%- comment -%}
  Block: q_warranty (main-product-v2)
  保修/延保条：浅蓝背景，左侧标题 + “View all warranty” 链接，右侧 “Free” + 复选 SVG；点击链接弹窗显示详细内容。
  Figma: 桌面 195:8 / 移动 196:120
  需传入: block, section
{%- endcomment -%}
<style>
  .section-{{ section.id }} .product__warranty {
    --warranty-bg: {{ block.settings.bg_color }};
    --warranty-radius: 10px;
    --warranty-padding: 9px 16px;
    --warranty-title-size: 13px;
    --warranty-title-line-height: 1.4;
    --warranty-link-size: 12px;
    --warranty-label-size: 12px;
    --warranty-check-size: 28px;
    --warranty-check-radius: 2px;

    font-family: var(--font-body-family);
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .product__warranty {
      --warranty-padding: 15px 26px;
      --warranty-title-size: 16px;
      --warranty-title-line-height: 1.5;
      --warranty-link-size: 12px;
      --warranty-label-size: 16px;
      --warranty-check-size: 36px;
      min-height: 84px;
      box-sizing: border-box;
    }
  }
  .section-{{ section.id }} .product__warranty {
    background: var(--warranty-bg);
    border-radius: var(--warranty-radius);
    padding: var(--warranty-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    box-sizing: border-box;
  }
  .section-{{ section.id }} .product__warranty-left {
    flex: 1;
    min-width: 0;
  }
  .section-{{ section.id }} .product__warranty-title {
    font-size: var(--warranty-title-size);
    line-height: var(--warranty-title-line-height);
    color: #1e1e1e;
    margin: 0;
    font-weight: 400;
  }
  .section-{{ section.id }} .product__warranty-opener {
    display: inline;
    font-size: var(--warranty-link-size);
    font-weight: 500;
    color: #1565d8;
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .section-{{ section.id }} .product__warranty-opener:hover {
    text-decoration: underline;
  }
  .section-{{ section.id }} .product__warranty-link-suffix {
    font-weight: 700;
    text-decoration: underline;
    margin-left: 2px;
  }
  .section-{{ section.id }} .product__warranty-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .section-{{ section.id }} .product__warranty-free {
    font-size: var(--warranty-label-size);
    font-weight: 700;
    color: #1565d8;
  }
  .section-{{ section.id }} .product__warranty-check {
    width: var(--warranty-check-size);
    height: var(--warranty-check-size);
    border: 1px solid #1565d8;
    border-radius: var(--warranty-check-radius);
    background: linear-gradient(to bottom, #f1f1f1, #fff);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .section-{{ section.id }} .product__warranty-check svg {
    width: calc(var(--warranty-check-size) * 0.72);
    height: calc(var(--warranty-check-size) * 0.72);
  }
</style>
<div class="product__warranty" {{ block.shopify_attributes }}>
  <div class="product__warranty-left">
    {%- if block.settings.title != blank -%}
      <p class="product__warranty-title">{{ block.settings.title | escape }}</p>
    {%- endif -%}
    {%- if block.settings.modal_content != blank -%}
      <modal-opener
        class="product-popup-modal__opener"
        data-modal="#WarrantyModal-{{ block.id }}"
      >
        <button
          type="button"
          class="product__warranty-opener"
          aria-haspopup="dialog"
        >
          {%- if block.settings.link_prefix != blank or block.settings.link_suffix != blank -%}
            {{ block.settings.link_prefix | escape }}<span class="product__warranty-link-suffix">{{ block.settings.link_suffix | escape }}</span>
          {%- else -%}
            View all <span class="product__warranty-link-suffix">warranty</span>
          {%- endif -%}
        </button>
      </modal-opener>
    {%- endif -%}
  </div>
  <div class="product__warranty-right">
    {%- if block.settings.label != blank -%}
      <span class="product__warranty-free" aria-hidden="true">{{ block.settings.label | escape }}</span>
    {%- endif -%}
    <span class="product__warranty-check" aria-hidden="true">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M28.05 11.7996C27.45 11.1996 26.55 11.1996 25.95 11.7996L14.7 23.0496L10.05 18.3996C9.45 17.7996 8.55 17.7996 7.95 18.3996C7.35 18.9996 7.35 19.8996 7.95 20.4996L13.65 26.1996C13.95 26.4996 14.25 26.6496 14.7 26.6496C15.15 26.6496 15.45 26.4996 15.75 26.1996L28.05 13.8996C28.65 13.2996 28.65 12.3996 28.05 11.7996Z" fill="black"/>
      </svg>
    </span>
  </div>
</div>
