{%- comment -%}
  产品页底部固定购物栏（main-product-v2）
  @param product {Object}
  @param section {Object}
  @param product_form_id {String}
{%- endcomment -%}
{%- liquid
  assign sticky_variant = product.selected_or_first_available_variant
  assign buy_buttons_v2_block = section.blocks | where: 'type', 'buy_buttons_v2' | first
  assign sticky_secondary_checkout = 'direct'
  if buy_buttons_v2_block
    assign sticky_secondary_checkout = buy_buttons_v2_block.settings.secondary_checkout | default: 'direct'
  endif
  assign gift_checkout_hidden = false
  if buy_buttons_v2_block and buy_buttons_v2_block.settings.show_gift_card_recipient and product.gift_card?
    assign gift_checkout_hidden = true
  endif

  assign sticky_show_direct_checkout = false
  if gift_checkout_hidden == false and sticky_secondary_checkout == 'direct'
    assign sticky_show_direct_checkout = true
  endif

  assign sticky_media = sticky_variant.featured_media
  if sticky_media == blank and sticky_variant.featured_image
    assign sticky_image = sticky_variant.featured_image
  elsif sticky_media != blank and sticky_media.preview_image
    assign sticky_image = sticky_media.preview_image
  else
    assign sticky_image = product.featured_media.preview_image | default: product.featured_image
  endif

  assign check_against_inventory = true
  if sticky_variant != blank
    if sticky_variant.inventory_management != 'shopify' or sticky_variant.inventory_policy == 'continue'
      assign check_against_inventory = false
    endif
  endif
  assign quantity_rule_soldout = false
  if sticky_variant != blank and check_against_inventory and sticky_variant.quantity_rule.min > sticky_variant.inventory_quantity
    assign quantity_rule_soldout = true
  endif

  assign atc_disabled = false
  if sticky_variant == null or sticky_variant.available == false or quantity_rule_soldout
    assign atc_disabled = true
  endif
-%}

<div
  id="ProductStickyBar-{{ section.id }}"
  class="product-sticky-bar section-{{ section.id }} hidden"
  role="region"
  aria-label="{{ 'products.product.sticky_bar.region_label' | t }}"
  data-sticky-reveal="buy-out-of-view"
>
  <div class="product-sticky-bar__inner page-width">
    <div class="product-sticky-bar__meta">
      <div id="StickyBarImage-{{ section.id }}" class="product-sticky-bar__image-wrap">
        {%- if sticky_image != blank -%}
          {%- assign sticky_img_alt = sticky_image.alt | default: product.title | escape -%}
          {{-
            sticky_image
            | image_url: width: 92
            | image_tag:
              loading: 'lazy',
              class: 'product-sticky-bar__image',
              widths: '46, 92, 138',
              alt: sticky_img_alt
          -}}
        {%- endif -%}
      </div>
      <p class="product-sticky-bar__title">{{ product.title | escape }}</p>
    </div>

    <div id="StickyBarPrice-{{ section.id }}" class="product-sticky-bar__price-slot">
      {%- render 'price-v2', product: product, use_variant: true, show_badges: false, price_class: 'product-sticky-bar__price' -%}
    </div>

    <div class="product-sticky-bar__actions product-sticky-bar__actions--desktop">
      <button
        type="submit"
        name="add"
        form="{{ product_form_id }}"
        class="button buy-buttons-v2__btn buy-buttons-v2__btn--atc product-sticky-bar__atc"
        {% if atc_disabled %}
          disabled
        {% endif %}
      >
        <span class="buy-buttons-v2__btn-label product-sticky-bar__atc-text">{{ 'products.product.add_to_cart' | t }}</span>
        {%- render 'loading-spinner' -%}
      </button>
      {%- if sticky_show_direct_checkout -%}
        <button
          type="submit"
          form="ProductStickyCheckout-{{ section.id }}"
          class="button buy-buttons-v2__btn buy-buttons-v2__btn--checkout buy-buttons-v2__checkout product-sticky-bar__checkout"
          {% if atc_disabled %}
            disabled
          {% endif %}
        >
          <span class="buy-buttons-v2__btn-label product-sticky-bar__checkout-text">{{ 'products.product.sticky_bar.buy_now' | t }}</span>
          {%- render 'loading-spinner' -%}
        </button>
      {%- endif -%}
    </div>

    <div class="product-sticky-bar__actions product-sticky-bar__actions--mobile">
      <div class="product-sticky-bar__pill{% unless sticky_show_direct_checkout %} product-sticky-bar__pill--atc-only{% endunless %}">
        <button
          type="submit"
          name="add"
          form="{{ product_form_id }}"
          class="button buy-buttons-v2__btn buy-buttons-v2__btn--atc product-sticky-bar__atc product-sticky-bar__atc--icon"
          aria-label="{{ 'products.product.add_to_cart' | t }}"
          {% if atc_disabled %}
            disabled
          {% endif %}
        >
          <span class="visually-hidden buy-buttons-v2__btn-label product-sticky-bar__atc-text">{{ 'products.product.add_to_cart' | t }}</span>
          <span class="product-sticky-bar__atc-icon svg-wrapper" aria-hidden="true">
            {{- 'icon-cart.svg' | inline_asset_content -}}
          </span>
          {%- render 'loading-spinner' -%}
        </button>
        {%- if sticky_show_direct_checkout -%}
          <button
            type="submit"
            form="ProductStickyCheckout-{{ section.id }}"
            class="button buy-buttons-v2__btn buy-buttons-v2__btn--checkout buy-buttons-v2__checkout product-sticky-bar__checkout product-sticky-bar__checkout--pill"
            {% if atc_disabled %}
              disabled
            {% endif %}
          >
            <span class="buy-buttons-v2__btn-label product-sticky-bar__checkout-text">{{ 'products.product.sticky_bar.buy_now' | t }}</span>
            {%- render 'loading-spinner' -%}
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if sticky_show_direct_checkout -%}
    <form
      id="ProductStickyCheckout-{{ section.id }}"
      class="product-sticky-bar__checkout-form product-info__direct-checkout-form"
      method="post"
      action="{{ routes.cart_add_url }}"
      hidden
      aria-hidden="true"
    >
      <input type="hidden" name="id" value="{{ sticky_variant.id }}">
      <input type="hidden" name="quantity" value="{{ sticky_variant.quantity_rule.min | default: 1 }}">
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .product-sticky-bar {
    padding: 8px 0;
  }
  @media screen and (min-width: 750px) {
    .product-sticky-bar {
      padding: 12px 0;
    }
  }
  /* 与 buy-buttons-v2 一致的按钮皮肤（自包含，不依赖购买块是否渲染） */
  .product-sticky-bar .buy-buttons-v2__btn {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    margin: 0;
    min-height: 36px !important;
    height: 36px !important;
    padding: 0 16px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: none;
    font-family: 'Poppins', var(--font-body-family, inherit);
    font-weight: 600;
    font-size: 12px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    border: none;
    cursor: pointer;

    --buttons-radius-outset: 10px;
    --buttons-radius: 10px;
    --buttons-border-width: 0px;
    --border-offset: 0px;
    --border-opacity: 0;
    --buttons-shadow-horizontal-offset: 0px;
    --buttons-shadow-vertical-offset: 0px;
    --buttons-shadow-blur-radius: 0px;
    --buttons-shadow-opacity: 0;
    --buttons-shadow-visible: 0;

    transition:
      background-color 0.2s ease,
      opacity 0.2s ease,
      transform 0.15s ease;
  }

  .product-sticky-bar .buy-buttons-v2__btn:focus-visible {
    outline: 0.2rem solid rgba(44, 119, 253, 0.45);
    outline-offset: 0.2rem;
    box-shadow: none;
  }

  .product-sticky-bar .buy-buttons-v2__btn::before {
    box-shadow: none;
  }

  .product-sticky-bar .buy-buttons-v2__btn::after {
    box-shadow: none;
  }

  .product-sticky-bar .buy-buttons-v2__btn:not([disabled]):hover::after {
    box-shadow: none;
  }

  .product-sticky-bar .buy-buttons-v2__btn--atc {
    background-color: #2c77fd;
    color: #ffffff;
    --color-button: 44 119 253;
    --alpha-button-background: 1;
    --color-button-text: 255 255 255;
  }

  .product-sticky-bar .buy-buttons-v2__btn--atc .loading__spinner .path {
    stroke: rgb(var(--color-button-text));
  }

  .product-sticky-bar .buy-buttons-v2__btn--atc:hover {
    background-color: #2464dc;
  }

  .product-sticky-bar .buy-buttons-v2__btn--checkout {
    background-color: #faa61a;
    color: #ffffff;
    --color-button: 250 166 26;
    --alpha-button-background: 1;
    --color-button-text: 255 255 255;
  }

  .product-sticky-bar .buy-buttons-v2__btn--checkout .loading__spinner .path {
    stroke: rgb(var(--color-button-text));
  }

  .product-sticky-bar .buy-buttons-v2__btn--checkout:hover {
    background-color: #e8940f;
  }

  .product-sticky-bar .buy-buttons-v2__btn:active {
    opacity: 0.88;
    transform: scale(0.98);
  }

  .product-sticky-bar .buy-buttons-v2__btn[disabled] {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .product-sticky-bar .buy-buttons-v2__btn[disabled]:active {
    transform: none;
  }

  .product-sticky-bar .buy-buttons-v2__btn-label {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-sticky-bar .buy-buttons-v2__btn.loading > .loading__spinner {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    position: absolute;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .product-sticky-bar .buy-buttons-v2__btn.loading .buy-buttons-v2__btn-label {
    opacity: 0;
  }

  .product-sticky-bar .buy-buttons-v2__btn.loading .product-sticky-bar__atc-icon {
    opacity: 0;
  }

  /* 提交中使用 aria-disabled，非原生 disabled；避免与售罄态 0.55 透明度冲突 */
  .product-sticky-bar .buy-buttons-v2__btn.loading:not([disabled]) {
    opacity: 1;
    cursor: wait;
  }

  .product-sticky-bar .buy-buttons-v2__btn.loading:not([disabled]):active {
    transform: none;
  }

  .product-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 8;
    background: rgb(var(--color-background));
    border-radius: 0.8rem 0.8rem 0 0;
    box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.1);
  }

  .product-sticky-bar__inner {
    padding: 1.2rem 1.5rem;
    max-width: 120rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: 'price pill';
    align-items: center;
    gap: 1.2rem 1rem;
  }

  .product-sticky-bar__meta {
    display: none;
  }

  .product-sticky-bar__price-slot {
    grid-area: price;
  }

  .product-sticky-bar__price-slot .price {
    margin: 0;
  }

  .product-sticky-bar__actions--desktop {
    display: none;
  }

  .product-sticky-bar__actions--mobile {
    grid-area: pill;
    justify-self: end;
  }

  .product-sticky-bar__pill {
    display: flex;
    gap: 8px;
    align-items: stretch;
    border-radius: 10px;
    overflow: hidden;
    max-width: min(100vw - 3rem, 28rem);
  }

  .product-sticky-bar__pill .svg-wrapper {
    width: 28px;
    height: 28px;
  }

  .product-sticky-bar__pill .buy-buttons-v2__btn--atc {
    flex: 0 0 auto;
    border-radius: 0;
  }

  .product-sticky-bar__pill:not(.product-sticky-bar__pill--atc-only) .buy-buttons-v2__btn--atc {
    border-radius: 10px;
  }

  .product-sticky-bar__pill .buy-buttons-v2__btn--checkout {
    border-radius: 10px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .product-sticky-bar__pill--atc-only .buy-buttons-v2__btn--atc {
    border-radius: 10px;
  }

  .product-sticky-bar__atc--icon {
    min-width: 44px;
    padding: 0 12px;
  }

  .product-sticky-bar__atc-icon svg {
    width: 2rem;
    height: 2rem;
  }

  @media screen and (min-width: 750px) {
    .product-sticky-bar .buy-buttons-v2__btn {
      min-height: 44px !important;
      height: 44px !important;
      padding: 0 24px;
      font-size: 18px;
      font-weight: 700;
      min-width: 170px !important;
    }

    .product-sticky-bar__inner {
      grid-template-columns: minmax(0, 1fr) auto auto;
      grid-template-areas: 'meta price actions';
      gap: 1.2rem 1.6rem;
    }

    .product-sticky-bar__meta {
      grid-area: meta;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      justify-self: end;
      text-align: right;
      gap: 1.2rem;
      min-width: 0;
    }

    .product-sticky-bar__image-wrap {
      flex-shrink: 0;
      width: 4.6rem;
      height: 4.6rem;
      border-radius: 0.4rem;
      overflow: hidden;
    }

    .product-sticky-bar__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .product-sticky-bar__title {
      margin: 0;
      font-size: 1.4rem;
      line-height: 1.35;
      font-weight: 500;
      max-width: 43.8rem;
      overflow: hidden;
      display: -webkit-box;
      line-clamp: 2;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      text-align: right;
    }

    .product-sticky-bar__price-slot {
      text-align: right;
      justify-self: end;
    }

    .product-sticky-bar__actions--mobile {
      display: none;
    }

    .product-sticky-bar__actions--desktop {
      grid-area: actions;
      display: flex;
      align-items: center;
      gap: 20px;
      flex-shrink: 0;
    }

    .product-sticky-bar__actions--desktop .buy-buttons-v2__btn {
      flex: 1 1 50%;
      min-width: 0;
    }
  }
{% endstylesheet %}
