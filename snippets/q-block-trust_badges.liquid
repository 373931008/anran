{%- comment -%}
  Block: q_trust_badges (main-product-v2)
  信任徽章：3 个图标+标题（可点击弹窗）+ 底部 Trust Guard 徽章图。
  布局：桌面端 4 项一行；移动端 3 项一行、徽章图居中在下方。
  需传入: block, section
  Figma: 桌面 195:11 / 移动 196:123
{%- endcomment -%}
<style>
  .section-{{ section.id }}.product__trust-badges {
    margin-top: 1.6rem;
    margin-bottom: 0;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 1.2rem 1.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-item {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 9.2rem;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-trigger {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    color: #404040;
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    line-height: 1.3;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-trigger:hover {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-trigger--no-popup {
    cursor: default;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-trigger--no-popup:hover {
    text-decoration: none;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 27px;
    height: 27px;
    flex-shrink: 0;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-item.product__trust-badges-badge-wrap {
    width: 100%;
    margin-top: 1.2rem;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-badge-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .section-{{ section.id }}.product__trust-badges .product__trust-badges-badge-wrap img {
    max-width: 127px;
    height: auto;
    object-fit: contain;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-row {
      gap: 2rem;
      flex-wrap: nowrap;
      justify-content: center;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-item {
      max-width: 15.2rem;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-trigger {
      font-size: 13px;
      gap: 0.6rem;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-icon {
      width: 36px;
      height: 36px;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-item.product__trust-badges-badge-wrap {
      width: auto;
      margin-top: 0;
      flex: 0 0 auto;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-badge-wrap {
      margin-top: 0;
      width: auto;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-row--with-badge {
      flex-wrap: nowrap;
    }
    .section-{{ section.id }}.product__trust-badges .product__trust-badges-badge-wrap img {
      max-width: 148px;
    }
  }
</style>
<div class="section-{{ section.id }} product__trust-badges product__trust-badges--{{ section.id }}-{{ block.id }}" {{ block.shopify_attributes }}>
  <ul class="product__trust-badges-row product__trust-badges-row--with-badge list-unstyled" role="list">
    {%- if block.settings.card_1_label != blank or block.settings.card_1_icon != blank -%}
      <li class="product__trust-badges-item">
        {%- if block.settings.card_1_content != blank -%}
          <modal-opener class="product-popup-modal__opener" data-modal="#TrustBadgeModal-{{ section.id }}-{{ block.id }}-1">
            <button type="button" class="product__trust-badges-trigger product-popup-modal__button link" aria-haspopup="dialog">
              {%- if block.settings.card_1_icon != blank -%}
                <span class="product__trust-badges-icon">
                  {{- block.settings.card_1_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
                </span>
              {%- endif -%}
              <span class="product__trust-badges-label">{{ block.settings.card_1_label }}</span>
            </button>
          </modal-opener>
        {%- else -%}
          <div class="product__trust-badges-trigger product__trust-badges-trigger--no-popup">
            {%- if block.settings.card_1_icon != blank -%}
              <span class="product__trust-badges-icon">
                {{- block.settings.card_1_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
              </span>
            {%- endif -%}
            <span class="product__trust-badges-label">{{ block.settings.card_1_label }}</span>
          </div>
        {%- endif -%}
      </li>
    {%- endif -%}
    {%- if block.settings.card_2_label != blank or block.settings.card_2_icon != blank -%}
      <li class="product__trust-badges-item">
        {%- if block.settings.card_2_content != blank -%}
          <modal-opener class="product-popup-modal__opener" data-modal="#TrustBadgeModal-{{ section.id }}-{{ block.id }}-2">
            <button type="button" class="product__trust-badges-trigger product-popup-modal__button link" aria-haspopup="dialog">
              {%- if block.settings.card_2_icon != blank -%}
                <span class="product__trust-badges-icon">
                  {{- block.settings.card_2_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
                </span>
              {%- endif -%}
              <span class="product__trust-badges-label">{{ block.settings.card_2_label }}</span>
            </button>
          </modal-opener>
        {%- else -%}
          <div class="product__trust-badges-trigger product__trust-badges-trigger--no-popup">
            {%- if block.settings.card_2_icon != blank -%}
              <span class="product__trust-badges-icon">
                {{- block.settings.card_2_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
              </span>
            {%- endif -%}
            <span class="product__trust-badges-label">{{ block.settings.card_2_label }}</span>
          </div>
        {%- endif -%}
      </li>
    {%- endif -%}
    {%- if block.settings.card_3_label != blank or block.settings.card_3_icon != blank -%}
      <li class="product__trust-badges-item">
        {%- if block.settings.card_3_content != blank -%}
          <modal-opener class="product-popup-modal__opener" data-modal="#TrustBadgeModal-{{ section.id }}-{{ block.id }}-3">
            <button type="button" class="product__trust-badges-trigger product-popup-modal__button link" aria-haspopup="dialog">
              {%- if block.settings.card_3_icon != blank -%}
                <span class="product__trust-badges-icon">
                  {{- block.settings.card_3_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
                </span>
              {%- endif -%}
              <span class="product__trust-badges-label">{{ block.settings.card_3_label }}</span>
            </button>
          </modal-opener>
        {%- else -%}
          <div class="product__trust-badges-trigger product__trust-badges-trigger--no-popup">
            {%- if block.settings.card_3_icon != blank -%}
              <span class="product__trust-badges-icon">
                {{- block.settings.card_3_icon | image_url: width: 72 | image_tag: loading: 'lazy', widths: '54,72', sizes: '27px', alt: '' -}}
              </span>
            {%- endif -%}
            <span class="product__trust-badges-label">{{ block.settings.card_3_label }}</span>
          </div>
        {%- endif -%}
      </li>
    {%- endif -%}
    {%- if block.settings.badge_image != blank -%}
      <li class="product__trust-badges-item product__trust-badges-badge-wrap">
        <div class="product__trust-badges-badge-wrap">
          {{- block.settings.badge_image | image_url: width: 296 | image_tag: loading: 'lazy', widths: '127,148,296', sizes: '(min-width: 750px) 148px, 127px', alt: block.settings.badge_image.alt | default: 'Trust Guard Secure' | escape -}}
        </div>
      </li>
    {%- endif -%}
  </ul>
</div>
