{%- comment -%}
  Snippet: q-section-header
  
  功能说明：
  - 通用板块头部组件，包含标题和描述
  - 标题使用 inline_richtext（支持 em、strong、a 等行内格式）
  - 描述使用 richtext（支持段落、加粗、斜体、链接）
  - em 标签支持纯色或双色渐变配置
  - 支持居中对齐、字号可配置、上下边距可配置

  使用方式：
  1. 在 section 中调用：{%- render 'q-section-header', section: section -%}
  2. 在 section 的 schema settings 中加入以下配置项（复制到对应 section 的 schema）：

  {
    "type": "header",
    "content": "板块标题"
  },
  {
    "type": "inline_richtext",
    "id": "header_title",
    "label": "标题",
    "default": "Section Title"
  },
  {
    "type": "richtext",
    "id": "header_description",
    "label": "描述",
    "default": "<p>Section description</p>"
  },
  {
    "type": "checkbox",
    "id": "header_center",
    "label": "居中对齐",
    "default": false
  },
  {
    "type": "color_background",
    "id": "header_em_color",
    "label": "em 高亮色",
    "default": "#FF6B35"
  },
  {
    "type": "range",
    "id": "header_title_size_desktop",
    "label": "标题字号（桌面端）",
    "min": 20,
    "max": 80,
    "step": 2,
    "unit": "px",
    "default": 42
  },
  {
    "type": "range",
    "id": "header_title_size_mobile",
    "label": "标题字号（移动端）",
    "min": 16,
    "max": 50,
    "step": 2,
    "unit": "px",
    "default": 26
  },
  {
    "type": "range",
    "id": "header_desc_size_desktop",
    "label": "描述字号（桌面端）",
    "min": 10,
    "max": 30,
    "step": 1,
    "unit": "px",
    "default": 16
  },
  {
    "type": "range",
    "id": "header_desc_size_mobile",
    "label": "描述字号（移动端）",
    "min": 10,
    "max": 24,
    "step": 1,
    "unit": "px",
    "default": 12
  },
  {
    "type": "range",
    "id": "header_margin_bottom_desktop",
    "label": "下边距（桌面端）",
    "min": 0,
    "max": 120,
    "step": 4,
    "unit": "px",
    "default": 60
  },
  {
    "type": "range",
    "id": "header_margin_bottom_mobile",
    "label": "下边距（移动端）",
    "min": 0,
    "max": 80,
    "step": 4,
    "unit": "px",
    "default": 40
  }
{%- endcomment -%}

{%- liquid
  assign header_title = section.settings.header_title
  assign header_desc = section.settings.header_description
  assign header_center = section.settings.header_center
  assign em_color = section.settings.header_em_color
  assign title_size_desktop = section.settings.header_title_size_desktop | default: 42
  assign title_size_mobile = section.settings.header_title_size_mobile | default: 26
  assign desc_size_desktop = section.settings.header_desc_size_desktop | default: 16
  assign desc_size_mobile = section.settings.header_desc_size_mobile | default: 12
  assign mb_desktop = section.settings.header_margin_bottom_desktop | default: 60
  assign mb_mobile = section.settings.header_margin_bottom_mobile | default: 40
-%}

<style>
  .q-section-header--{{ section.id }} {
    margin-bottom: {{ mb_mobile }}px;
  }

  .q-section-header--{{ section.id }} .q-section-header__title {
    font-size: {{ title_size_mobile }}px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
  }

  .q-section-header--{{ section.id }} .q-section-header__title p {
    margin: 0;
  }

  .q-section-header--{{ section.id }} .q-section-header__desc {
    font-size: {{ desc_size_mobile }}px;
    margin: 12px 0 0;
  }

  .q-section-header--{{ section.id }} .q-section-header__desc p {
    margin: 0;
  }

  {%- if em_color != blank -%}
    .q-section-header--{{ section.id }} em {
      font-style: normal;
      background: {{ em_color }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    .q-section-header--{{ section.id }} {
      margin-bottom: {{ mb_desktop }}px;
    }

    .q-section-header--{{ section.id }} .q-section-header__title {
      font-size: {{ title_size_desktop }}px;
    }

    .q-section-header--{{ section.id }} .q-section-header__desc {
      font-size: {{ desc_size_desktop }}px;
      margin-top: 24px;
    }
  }
</style>

{%- if header_title != blank or header_desc != blank -%}
  <div class="q-section-header q-section-header--{{ section.id }}{% if header_center %} q-section-header--center{% endif %}">
    {%- if header_title != blank -%}
      <h2 class="q-section-header__title">{{ header_title }}</h2>
    {%- endif -%}

    {%- if header_desc != blank -%}
      <div class="q-section-header__desc">{{ header_desc }}</div>
    {%- endif -%}
  </div>
{%- endif -%}

<style>
  .q-section-header--center {
    text-align: center;
  }

  .q-section-header__desc p:not(:first-child) {
    margin-top: 0.5em;
  }
</style>
