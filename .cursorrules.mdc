#### 在Island组件中的使用模式
```javascript
import { debounce, storage, dom } from '@/components/utils.js'

export default class SearchComponent extends HTMLElement {
  constructor() {
    super()
    this.state = { query: '', results: [] }
    
    // 使用防抖优化搜索性能
    this.debouncedSearch = debounce(this.performSearch.bind(this), 300)
    this.handleInput = this.handleInput.bind(this)
  }

  connectedCallback() {
    try {
      this.render()
      this.setupEventListeners()
      this.loadSavedQuery()
    } catch (error) {
      console.error('Search component initialization failed:', error)
      this.renderErrorState()
    }
  }

  setupEventListeners() {
    const input = dom.find('.search-input', this)
    input.addEventListener('input', this.handleInput)
  }

  handleInput(event) {
    const query = event.target.value
    this.updateState({ query })
    
    if (query.trim()) {
      this.debouncedSearch(query)
      storage.set('last_search', query) // 保存搜索历史
    }
  }

  loadSavedQuery() {
    const savedQuery = storage.get('last_search', '')
    if (savedQuery) {
      const input = dom.find('.search-input', this)
      input.value = savedQuery
      this.updateState({ query: savedQuery })
    }
  }

  disconnectedCallback() {
    const input = dom.find('.search-input', this)
    input?.removeEventListener('input', this.handleInput)
  }
}
```

**工具库优势**：
- ✅ 纯原生JavaScript，无外部依赖
- ✅ 完整的中文注释和文档
- ✅ 模块化设计，按需导入
- ✅ 涵盖日常开发90%的需求
- ✅ 完善的错误处理
- ✅ 可扩展性强，随时添加新工具

### 轮播图组件规范 (Swiper)

**使用 `swiper/element/bundle` 实现所有轮播功能**

#### 核心模板

```liquid
<!-- 基础模板：3个关键点 -->
<swiper-container 
  class="tw-flex tw-w-full tw-aspect-[16/9]"  <!-- 1. aspect-ratio自适应 -->
  slides-per-view="1" 
  loop="true">
  <swiper-slide class="tw-flex tw-shrink-0">  <!-- 2. tw-shrink-0防止压缩 -->
    <!-- 3. 图片预设尺寸：使用 image_url + img 或 image_tag -->
    {{- image | image_url: width: 1920 | image_tag: 
        class: 'tw-w-full tw-h-full tw-object-cover' -}}
  </swiper-slide>
</swiper-container>
```

**3个防止CLS的关键点**：
1. `tw-aspect-[x/y]` - 容器宽高比（根据宽度自适应高度）
2. `tw-shrink-0` - slide不被压缩
3. `width/height` - 图片预设尺寸（使用 `image_url` 或 `image_tag`）

#### 使用场景

##### 1. Banner轮播
```liquid
<swiper-container 
  class="tw-flex tw-w-full tw-aspect-[16/9] lg:tw-aspect-[21/9]"
  slides-per-view="1"
  loop="true"
  autoplay="true"
  pagination="true">
  {% for banner in section.settings.banners %}
    <swiper-slide class="tw-flex tw-shrink-0">
      <!-- 方式1: 使用 image_url 过滤器 -->
      <img 
        src="{{ banner.image | image_url: width: 1920 }}" 
        srcset="{{ banner.image | image_url: width: 768 }} 768w,
                {{ banner.image | image_url: width: 1024 }} 1024w,
                {{ banner.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ banner.title }}"
        width="1920"
        height="1080"
        class="tw-w-full tw-h-full tw-object-cover">
    </swiper-slide>
  {% endfor %}
</swiper-container>
```

##### 2. 产品轮播
```liquid
<swiper-container 
  class="tw-flex tw-w-full"
  slides-per-view="1.2"
  space-between="16"
  breakpoints='{"640": {"slidesPerView": 2}, "768": {"slidesPerView": 3}, "1024": {"slidesPerView": 4}}'>
  {% for product in collection.products %}
    <swiper-slide class="tw-flex tw-shrink-0">
      <div class="tw-flex tw-flex-col tw-w-full tw-bg-white tw-rounded-lg tw-overflow-hidden">
        <div class="tw-aspect-square">
          <!-- 方式2: 使用 image_tag -->
          {{- product.featured_image | image_url: width: 400 | image_tag: 
              class: 'tw-w-full tw-h-full tw-object-cover',
              alt: product.title -}}
        </div>
        <div class="tw-p-4">
          <h3 class="tw-font-semibold tw-line-clamp-2">{{ product.title }}</h3>
          <p class="tw-text-lg tw-font-bold tw-mt-2">{{ product.price | money }}</p>
        </div>
      </div>
    </swiper-slide>
  {% endfor %}
</swiper-container>
```

##### 3. JavaScript控制（可选）
```javascript
// frontend/islands/banner-slider.js
export default class BannerSlider extends HTMLElement {
  connectedCallback() {
    const swiper = this.querySelector('swiper-container')
    if (!swiper) return

    Object.assign(swiper, {
      slidesPerView: 1,
      loop: true,
      autoplay: { delay: 3000, disableOnInteraction: false }
    })

    swiper.initialize()
  }
}

customElements.define('banner-slider', BannerSlider)
```

